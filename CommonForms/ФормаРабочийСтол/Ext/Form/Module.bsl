// Отображает актуальное представление пользователя ПользовательВход.
&НаСервере
Процедура ОбновитьПредставлениеПользователя(ПользовательВход)
	СтруктураДанныхПользователя = Справочники.Пользователи.ВернутьДанныеПользователя(ПользовательВход);
	Уровень = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхПользователя, "Уровень", 1);
	ПредставлениеПользователя = Строка(ТекПользователь) + " [" + Строка(Уровень) + "]";
	Элементы.ОткрытьПрофильПользователя.Заголовок = ПредставлениеПользователя;
КонецПроцедуры		// ОбновитьПредставлениеПользователя()	

// Отображает актуальное представление текущего пользователя.
&НаСервере
Процедура ОбновитьПредставлениеТекущегоПользователя()
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	Если ЗначениеЗаполнено(ТекПользователь) Тогда
		ОбновитьПредставлениеПользователя(ТекПользователь);
		Элементы.ОткрытьПрофильПользователя.Видимость = Истина;
	Иначе
		Элементы.ОткрытьПрофильПользователя.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры		// ОбновитьПредставлениеТекущегоПользователя()

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбновитьПредставлениеТекущегоПользователя();
КонецПроцедуры

