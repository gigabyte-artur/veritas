		<query>ВЫБРАТЬ
	РезультатыТестированияЗнаний.ЗаданоВопросов КАК ЗаданоВопросов,
	РезультатыТестированияЗнаний.ОтвеченоВерно КАК ОтвеченоВерно,
	РезультатыТестированияЗнаний.Сборник КАК Сборник,
	НАЧАЛОПЕРИОДА(РезультатыТестированияЗнаний.Период, ДЕНЬ) КАК Период
ПОМЕСТИТЬ ВТ_ДанныеРегистра
ИЗ
	РегистрСведений.РезультатыТестированияЗнаний КАК РезультатыТестированияЗнаний
ГДЕ
	РезультатыТестированияЗнаний.Период &lt;= &amp;КонецПериода
	И РезультатыТестированияЗнаний.Период &gt;= &amp;НачалоПериода
	И РезультатыТестированияЗнаний.Пользователь = &amp;Пользователь
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СУММА(ВТ_ДанныеРегистра.ЗаданоВопросов) КАК ЗаданоВопросов,
	СУММА(ВТ_ДанныеРегистра.ОтвеченоВерно) КАК ОтвеченоВерно,
	ВТ_ДанныеРегистра.Сборник КАК Сборник,
	ВТ_ДанныеРегистра.Период КАК Период
ПОМЕСТИТЬ ВТ_Группировка
ИЗ
	ВТ_ДанныеРегистра КАК ВТ_ДанныеРегистра

СГРУППИРОВАТЬ ПО
	ВТ_ДанныеРегистра.Сборник,
	ВТ_ДанныеРегистра.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Группировка.ЗаданоВопросов КАК ЗаданоВопросов,
	ВТ_Группировка.ОтвеченоВерно КАК ОтвеченоВерно,
	ВТ_Группировка.Сборник КАК Сборник,
	ВТ_Группировка.Период КАК Период,
	ВЫБОР
		КОГДА ВТ_Группировка.ЗаданоВопросов = 0
			ТОГДА 0
		ИНАЧЕ 100 * ВТ_Группировка.ОтвеченоВерно / ВТ_Группировка.ЗаданоВопросов
	КОНЕЦ КАК Точность
ИЗ
	ВТ_Группировка КАК ВТ_Группировка</query>
