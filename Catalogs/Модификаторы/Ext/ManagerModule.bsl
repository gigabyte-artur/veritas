
// Возвращает случайный модификатор, который имеет признак положительности ПоложительныйВход.
//
// Параметры:
//  ПоложительныйВход - Булево - признак, что модификатор должен быть положительным.
//  Гсч   - ГенераторСлучайныхЧисел - генератор случайных чисел.
//  ИсключаемыеМодификаторыВход - Массив - массив ссылок на модификаторы, которые нужно исключить.
// 
// Возвращаемое значение:
//   - СправочникСсылка.Модификаторы - случайный модификатор.
//
Функция ВернутьМодификатор(ПоложительныйВход, Гсч, ИсключаемыеМодификаторыВход = Неопределено) Экспорт
	ПустойМодификатор = Справочники.Модификаторы.ПустаяСсылка();
	РезультатФункции = ПустойМодификатор;
	// Получим случайный модификатор, не помеченный на удаление, ориентируясь на признак положительного.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Модификаторы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Модификаторы КАК Модификаторы
	|ГДЕ
	|	НЕ Модификаторы.ПометкаУдаления
	|	И Модификаторы.Положительный = &ПоложительныйВход
	|	И Модификаторы.Открыт
	|	И НЕ Модификаторы.Ссылка В (&ИсключаемыеМодификаторы)";
	Запрос.УстановитьПараметр("ПоложительныйВход", ПоложительныйВход);
	Если ИсключаемыеМодификаторыВход <> Неопределено И ТипЗнч(ИсключаемыеМодификаторыВход) = Тип("Массив") Тогда
		Запрос.УстановитьПараметр("ИсключаемыеМодификаторы", ИсключаемыеМодификаторыВход);
	Иначе
		Запрос.УстановитьПараметр("ИсключаемыеМодификаторы", Новый Массив);
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		КоличествоВыборки = РезультатЗапроса.Выбрать().Количество();
		СлучайноеЧисло = Гсч.СлучайноеЧисло(0, КоличествоВыборки - 1);
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Счетчик = 0;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			РезультатФункции = ВыборкаДетальныеЗаписи.Ссылка;
			Счетчик = Счетчик + 1;
			Если Счетчик = СлучайноеЧисло Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		// Не удалось получить модификатор. Вернём пустой.
		РезультатФункции = ПустойМодификатор;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции

// Возвращает массив ссылок на неоткрытые модификаторы.
//
// Возвращаемое значение:
//   - Массив — ссылки на модификаторы, у которых Открыт = Ложь.
//
Функция ПолучитьНеоткрытыеМодификаторы() Экспорт
	РезультатФункции = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Модификаторы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Модификаторы КАК Модификаторы
		|ГДЕ
		|	НЕ Модификаторы.Открыт";
	РезультатЗапроса = Запрос.Выполнить();
	Выгрузка = РезультатЗапроса.Выгрузить();
	РезультатФункции = Выгрузка.ВыгрузитьКолонку("Ссылка");
	Возврат РезультатФункции;
КонецФункции

// Открывает случайный модификатор, у которого признак Открыт = Ложь.
// Устанавливает Открыт = Истина и возвращает ссылку на модификатор.
// Если неоткрытых модификаторов нет — возвращает пустую ссылку.
//
// Возвращаемое значение:
//   - СправочникСсылка.Модификаторы — ссылка на открытый модификатор или пустая ссылка.
//
Функция ОткрытьСлучайныйМодификатор() Экспорт
	ПустойМодификатор = Справочники.Модификаторы.ПустаяСсылка();
	РезультатФункции = ПустойМодификатор;
	Гсч = Новый ГенераторСлучайныхЧисел;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Модификаторы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Модификаторы КАК Модификаторы
		|ГДЕ
		|	НЕ Модификаторы.Открыт
		|	И НЕ Модификаторы.ПометкаУдаления";
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выгрузка = РезультатЗапроса.Выгрузить();
		МассивМодификаторов = Выгрузка.ВыгрузитьКолонку("Ссылка");
		СлучайныйИндекс = Гсч.СлучайноеЧисло(0, МассивМодификаторов.Количество() - 1);
		ВыбранныйМодификатор = МассивМодификаторов[СлучайныйИндекс];
		ОбъектМодификатора = ВыбранныйМодификатор.ПолучитьОбъект();
		ОбъектМодификатора.Открыт = Истина;
		ОбъектМодификатора.Записать();
		РезультатФункции = ВыбранныйМодификатор;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции
