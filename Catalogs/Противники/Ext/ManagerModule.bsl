
// Возвращает случайного противоника из справочника.
// 
// Параметры:
// 	ГСЧ - ГенераторСлучайныхЧисел - переменная для генерации случайных чисел.
//
// Возвращаемое значение:
// 	СправочникСсылка.Противники - ссылка на случайного противоника.
//
Функция ПолучитьСлучайногоПротивника(ГСЧ) Экспорт
	РезультатФункции = Справочники.Противники.ПустаяСсылка();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
		|	Противники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Противники КАК Противники
		|ГДЕ
		|	Противники.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Противники.Код УБЫВ";
	РезультатЗапроса = Запрос.Выполнить();
	Выгрузка = РезультатЗапроса.Выгрузить();
	Если Выгрузка.Количество() > 0 Тогда
		Индекс = ГСЧ.СлучайноеЧисло(0, Выгрузка.Количество() - 1);
		РезультатФункции = Выгрузка[Индекс].Ссылка;
	Иначе
		РезультатФункции = Справочники.Противники.ПустаяСсылка();
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьСлучайногоПротивника()

// Возвращает максимальную силу из табличной части ДействияЦикла противника.
// 
// Параметры:
// 	СсылкаНаПротивника - СправочникСсылка.Противники - ссылка на противника.
//
// Возвращаемое значение:
// 	Число - максимальное значение силы из всех действий цикла, или 0 если табличная часть пуста.
//
Функция ПолучитьМаксимальнуюСилуИзДействийЦикла(СсылкаНаПротивника) Экспорт
	РезультатФункции = 0;
	
	Если СсылкаНаПротивника.Пустая() Тогда
		Возврат РезультатФункции;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
		|	МАКСИМУМ(ДействияЦикла.МинимальнаяСила) КАК МаксимальнаяСила
		|ИЗ
		|	Справочник.Противники.ДействияЦикла КАК ДействияЦикла
		|ГДЕ
		|	ДействияЦикла.Ссылка = &СсылкаНаПротивника";
	
	Запрос.УстановитьПараметр("СсылкаНаПротивника", СсылкаНаПротивника);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			Если НЕ Выборка.МаксимальнаяСила = Неопределено Тогда
				РезультатФункции = Выборка.МаксимальнаяСила;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатФункции;
КонецФункции		// ПолучитьМаксимальнуюСилуИзДействийЦикла()

// Возвращает таблицу значений с действиями цикла противника.
// 
// Параметры:
//  СсылкаНаПротивника - СправочникСсылка.Противники - ссылка на противника.
//
// Возвращаемое значение:
//  ТаблицаЗначений - таблица с колонками: ДействиеЦикла, МинимальнаяСила, МаксимальнаяСила.
//
Функция ПолучитьТаблицуДействийЦикла(СсылкаНаПротивника) Экспорт
	РезультатФункции = Новый ТаблицаЗначений;
	РезультатФункции.Колонки.Добавить("ДействиеЦикла");
	РезультатФункции.Колонки.Добавить("МинимальнаяСила");
	РезультатФункции.Колонки.Добавить("МаксимальнаяСила");
	Если НЕ СсылкаНаПротивника.Пустая() Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
			|	ДействияЦикла.ДействиеЦикла КАК ДействиеЦикла,
			|	ДействияЦикла.МинимальнаяСила КАК МинимальнаяСила,
			|	ДействияЦикла.МаксимальнаяСила КАК МаксимальнаяСила
			|ИЗ
			|	Справочник.Противники.ДействияЦикла КАК ДействияЦикла
			|ГДЕ
			|	ДействияЦикла.Ссылка = &СсылкаНаПротивника";
		Запрос.УстановитьПараметр("СсылкаНаПротивника", СсылкаНаПротивника);
		РезультатЗапроса = Запрос.Выполнить();
		Если НЕ РезультатЗапроса.Пустой() Тогда
			РезультатФункции = РезультатЗапроса.Выгрузить();
		Иначе
			// Результат запроса пустой, возвращаем пустую таблицу с настроенными колонками
		КонецЕсли;
	Иначе
		// Ссылка пустая, возвращаем пустую таблицу с настроенными колонками
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТаблицуДействийЦикла()
