// Открывает случайную карту, у которой признак Открыта = Ложь.
// Устанавливает Открыта = Истина и возвращает ссылку на карту.
// Если неоткрытых карт нет — возвращает пустую ссылку.
//
// Возвращаемое значение:
//   - СправочникСсылка.Карты — ссылка на открытую карту или пустая ссылка.
//
Функция ОткрытьСлучайнуюКарту() Экспорт
	ПустаяКарта = Справочники.Карты.ПустаяСсылка();
	РезультатФункции = ПустаяКарта;
	Гсч = Новый ГенераторСлучайныхЧисел;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Карты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Карты КАК Карты
		|ГДЕ
		|	НЕ Карты.Открыта
		|	И НЕ Карты.ПометкаУдаления";
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выгрузка = РезультатЗапроса.Выгрузить();
		МассивКарт = Выгрузка.ВыгрузитьКолонку("Ссылка");
		СлучайныйИндекс = Гсч.СлучайноеЧисло(0, МассивКарт.Количество() - 1);
		ВыбраннаяКарта = МассивКарт[СлучайныйИндекс];
		ОбъектКарты = ВыбраннаяКарта.ПолучитьОбъект();
		ОбъектКарты.Открыта = Истина;
		ОбъектКарты.Записать();
		РезультатФункции = ВыбраннаяКарта;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции
