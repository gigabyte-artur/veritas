
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УправлениеДоступностью();
КонецПроцедуры

&НаКлиенте
Процедура КомандаНаградаЗолото(Команда)
	СтруктураЗакрытия = Новый Структура();
	СтруктураЗакрытия.Вставить("Награда", ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото"));
	СтруктураЗакрытия.Вставить("Размер", 5);
	Закрыть(СтруктураЗакрытия);
КонецПроцедуры

&НаКлиенте
Процедура КомандаНаградаКарта(Команда)
	Размер = 2;
	Если ЕстьМодификаторИгрока(ПредопределенноеЗначение("Справочник.Модификаторы.РасширенныйАрхив")) Тогда
		Размер = 3;
	КонецЕсли;
	СтруктураЗакрытия = Новый Структура();
	СтруктураЗакрытия.Вставить("Награда", ПредопределенноеЗначение("Справочник.Карты.ПустаяСсылка"));
	СтруктураЗакрытия.Вставить("Размер", Размер);
	Закрыть(СтруктураЗакрытия);
КонецПроцедуры

