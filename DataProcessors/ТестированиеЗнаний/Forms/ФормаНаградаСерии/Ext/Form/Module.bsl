&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЭнергияИгрока = Параметры.ЭнергияИгрока;
	ЗдоровьеПротивника = Параметры.ЗдоровьеПротивника;
	МаксимальноеЗдоровьеПротивника = Параметры.МаксимальноеЗдоровьеПротивника;
	МодификаторыИгрока = Новый СписокЗначений;
	Для Каждого ЭлементСписка Из Параметры.Модификаторы Цикл
		МодификаторыИгрока.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	Элементы.ДекорацияЭнергияИгрока.Заголовок = "Энергия: " + Строка(ЭнергияИгрока);
	Элементы.ДекорацияЗдоровьеПротивника.Заголовок = "Противник: " + Строка(ЗдоровьеПротивника) + "/" + Строка(МаксимальноеЗдоровьеПротивника);
КонецПроцедуры

// Управляет видимостью и заголовками кнопок наград в зависимости от наличия модификаторов у игрока.
//
&НаКлиенте
Процедура УправлениеДоступностью()
	Если ЕстьМодификаторИгрока(ПредопределенноеЗначение("Справочник.Модификаторы.ПлащМеркурия")) Тогда
		Элементы.КомандаНаградаЗолото.Видимость = Истина;
	КонецЕсли;
	Если ЕстьМодификаторИгрока(ПредопределенноеЗначение("Справочник.Модификаторы.ШлемАфины")) Тогда
		Элементы.КомандаНаградаЩит.Видимость = Истина;
	КонецЕсли;
	Если ЕстьМодификаторИгрока(ПредопределенноеЗначение("Справочник.Модификаторы.РасширенныйАрхив")) Тогда
		Элементы.КомандаНаградаКарта.Заголовок = "Получить 3 карты";
	Иначе
		Элементы.КомандаНаградаКарта.Заголовок = "Получить 2 карты";
	КонецЕсли;
КонецПроцедуры

// Определяет, есть ли у игрока заданный модификатор.
//
// Параметры:
//  МодификаторВход - СправочникСсылка.Модификаторы - проверяемый модификатор.
//
// Возвращаемое значение:
//  Булево - Истина, если модификатор есть у игрока.
//
&НаКлиенте
Функция ЕстьМодификаторИгрока(МодификаторВход)
	Возврат МодификаторыИгрока.НайтиПоЗначению(МодификаторВход) <> Неопределено;
КонецФункции
