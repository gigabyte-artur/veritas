&НаКлиенте
Процедура ВыбратьЭтап(Команда)
	// Получаем выбранную строку из таблицы этапов
	Если ТаблицаЭтапов.ТекущаяСтрока <> Неопределено Тогда
		ВыбраннаяСтрока = ТаблицаЭтапов.ТекущаяСтрока;
		// Возвращаем результат через структуру
		Результат = Новый Структура;
		Результат.Вставить("ВидЭтапа", ВыбраннаяСтрока.ВидЭтапа);
		Результат.Вставить("Противник", ВыбраннаяСтрока.Противник);
		
		// Записываем результат и закрываем форму
		Модифицированность = Ложь;
		Закрыть(Результат);
	Иначе
		Предупреждение("Выберите этап из списка.");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Инициализация таблицы этапов
	ТаблицаЭтапов.Очистить();
	
	// Заполняем таблицу этапов данными
	// Здесь должна быть логика получения этапов восхождения
	// Для примера добавим заглушку
	НоваяСтрока = ТаблицаЭтапов.Добавить();
	НоваяСтрока.ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Начальный;
	НоваяСтрока.Противник = Справочники.Противники.ПустаяСсылка;
КонецПроцедуры
