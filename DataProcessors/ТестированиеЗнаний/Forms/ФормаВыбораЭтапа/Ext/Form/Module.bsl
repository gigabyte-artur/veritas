&НаСервере
Перем Гсч;		// Генератор случайных чисел.

&НаКлиенте
Процедура ВыбратьЭтап(Команда)
	// Получаем выбранную строку из таблицы этапов
	ТекДанные = Элементы.ТаблицаЭтапов.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		// Возвращаем результат через структуру
		Результат = Новый Структура;
		Результат.Вставить("ВидЭтапа",	 ТекДанные.ВидЭтапа);
		Результат.Вставить("Противник",	 ТекДанные.Противник);
		Результат.Вставить("НомерЭтапа", НомерЭтапа + 1);
		// Записываем результат и закрываем форму
		Модифицированность = Ложь;
		Закрыть(Результат);
	Иначе
		Предупреждение("Выберите этап из списка.");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Инициализация генератора случайных чисел
	Гсч = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
	// Считываем параметры формы.
	ВсегоЭтапов = Параметры.ВсегоЭтапов;
	НомерЭтапа = Параметры.НомерЭтапа;
	// Считываем предыдущие значения противника и вида этапа
	Если Параметры.Свойство("ПредыдущийПротивник") Тогда
		ПредыдущийПротивник = Параметры.ПредыдущийПротивник;
	КонецЕсли;
	Если Параметры.Свойство("ПредыдущийВидЭтапа") Тогда
		ПредыдущийВидЭтапа = Параметры.ПредыдущийВидЭтапа;
		Если ПредыдущийВидЭтапа <> Перечисления.ВидыЭтаповВосхождения.Противник Тогда
			ПредыдущийПротивник = Справочники.Противники.ПустаяСсылка();
		Иначе
			// Не очищаем противника.
		КонецЕсли;	
	КонецЕсли;
	// Формирование заголовка декорации.
	Элементы.ДекорацияНомерЭтапа.Заголовок = Строка(НомерЭтапа) + "/" + Строка(ВсегоЭтапов);
	// Заполнение таблицы этапов
	ЗаполнитьТаблицуЭтапов();
КонецПроцедуры

// Осуществляет заполнение таблицы этапов.
//
&НаСервере
Процедура ЗаполнитьТаблицуЭтапов()
	// Количество строк для выбора этапа
	ЧислоЭтаповДляВыбора = 3;
	// Инициализация таблицы этапов
	ТаблицаЭтапов.Очистить();
	// Заполняем таблицу этапов строками с распределением вероятностей
	Для Индекс = 1 По ЧислоЭтаповДляВыбора Цикл
		НоваяСтрока = ТаблицаЭтапов.Добавить();
		// Генерируем случайное число от 0 до 99 для определения вероятности
		СлучайноеЗначение = Гсч.СлучайноеЧисло(0, 99);
			// Распределение вероятностей:
			// 0-90 (90%) - Противник
			// 90-94 (4%) - Торговец
			// 94-98 (4%) - Отдых
			// 98-99 (2%) - Сокровище
			Если СлучайноеЗначение < 90 Тогда
				ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Противник;
			ИначеЕсли СлучайноеЗначение < 94 Тогда
				ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Торговец;
			ИначеЕсли СлучайноеЗначение < 98 Тогда
				ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Отдых;
			Иначе
				ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Сокровище;
			КонецЕсли;
		НоваяСтрока.ВидЭтапа = ВидЭтапа;
		// Если выбран вид этапа "Противник", заполняем поле Противник
		Если НоваяСтрока.ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Противник Тогда
			НоваяСтрока.Противник = Справочники.Противники.ПолучитьСлучайногоПротивника(Гсч);
		Иначе
			НоваяСтрока.Противник = Справочники.Противники.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
