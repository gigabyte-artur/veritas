
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Получение золота из параметров формы
	Золото = Параметры.Золото;
	// Получение и заполнение модификаторов игрока из параметров формы
	МодификаторыИгрока = Новый СписокЗначений;
	Для каждого ЭлементСписка Из Параметры.Модификаторы Цикл
		МодификаторыИгрока.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	// Получение карт игрока из параметров формы
	КартыИгрока.Очистить();
	Для Каждого ТекКартыИгрока Из Параметры.КартыИгрока Цикл
		НоваяСтрока = КартыИгрока.Добавить();
		НоваяСтрока.Карта				 = ТекКартыИгрока.Карта;
		НоваяСтрока.ИдентификаторКарты	 = ТекКартыИгрока.ИдентификаторКарты;
	КонецЦикла;
	// Заполнение таблицы МодификаторыНаВитрине
	ЗаполнитьМодификаторыНаВитрине();
	// Заполнение таблицы КартыНаВитрине
	ЗаполнитьКартыНаВитрине();
КонецПроцедуры

// Выполняет заполнение таблицы модификаторов к покупке.
//
&НаСервере
Процедура ЗаполнитьМодификаторыНаВитрине()
	Гсч = Новый ГенераторСлучайныхЧисел;
	МодификаторыНаВитрине.Очистить();
	КоличествоДобавленных = 0;
	МаксимумКПокупке = 3;
	Пока КоличествоДобавленных < МаксимумКПокупке Цикл
		// Получаем случайный модификатор, исключая модификаторы игрока
		НовыйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Истина, Гсч, МодификаторыИгрока.ВыгрузитьЗначения());
		Если ЗначениеЗаполнено(НовыйМодификатор) Тогда
			// Проверяем, нет ли уже такого модификатора в витрине
			СтруктураПоиска = Новый Структура("Модификатор", НовыйМодификатор);
			НайденныеСтроки = МодификаторыНаВитрине.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтроки.Количество() = 0 Тогда
				НоваяСтрока = МодификаторыНаВитрине.Добавить();
				НоваяСтрока.Модификатор = НовыйМодификатор;
				СлучайнаяЦена = Гсч.СлучайноеЧисло(15, 30) * 10;
				НоваяСтрока.Цена = СлучайнаяЦена;
				КоличествоДобавленных = КоличествоДобавленных + 1;
			КонецЕсли;
		Иначе
			// Не удалось найти подходящий модификатор
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Выполняет заполнение таблицы карт к покупке.
//
&НаСервере
Процедура ЗаполнитьКартыНаВитрине()
	Гсч = Новый ГенераторСлучайныхЧисел;
	КартыНаВитрине.Очистить();
	// Получаем все карты, не помеченные на удаление
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	НЕ Карты.ПометкаУдаления";
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	МассивВсехКарт = Новый Массив;
	Пока Выборка.Следующий() Цикл
		МассивВсехКарт.Добавить(Выборка.Ссылка);
	КонецЦикла;
	// Выбираем 3 случайные карты
	КоличествоДобавленных = 0;
	МаксимумКПокупке = 3;
	Пока КоличествоДобавленных < МаксимумКПокупке И МассивВсехКарт.Количество() > 0 Цикл
		СлучайныйИндекс = Гсч.СлучайноеЧисло(0, МассивВсехКарт.Количество() - 1);
		НоваяКарта = МассивВсехКарт[СлучайныйИндекс];
		МассивВсехКарт.Удалить(СлучайныйИндекс);
		НоваяСтрока = КартыНаВитрине.Добавить();
		НоваяСтрока.Карта = НоваяКарта;
		НоваяСтрока.Цена = Гсч.СлучайноеЧисло(50, 100);
		КоличествоДобавленных = КоличествоДобавленных + 1;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура КупитьМодификатор(Команда)
	ТекДанные = Элементы.МодификаторыНаВитрине.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		ТекМодификатор	 = ТекДанные.Модификатор;
		ТекЦена			 = ТекДанные.Цена;
		Если Золото < ТекЦена Тогда
			Сообщить("Недостаточно золота для покупки");
		Иначе
			// Уменьшаем золото на величину цены.
			Золото = Золото - ТекЦена;
			// Добавляем модификатор в список купленных
			КупленныеМодификаторы.Добавить(ТекМодификатор);
			// Удаляем модификатор из витрины
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Модификатор", ТекМодификатор);
			НайденныеСтроки = МодификаторыНаВитрине.НайтиСтроки(СтруктураПоиска);
			Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
				МодификаторыНаВитрине.Удалить(ТекНайденныеСтроки);
			КонецЦикла;	
		КонецЕсли;
	Иначе
		Сообщить("Требуется выбрать модифкатор");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьПокупки(Команда)
	СтруктураЗакрытия = Новый Структура;
	СтруктураЗакрытия.Вставить("Золото", Золото);
	СтруктураЗакрытия.Вставить("КупленныеМодификаторы", КупленныеМодификаторы);
	СтруктураЗакрытия.Вставить("КупленныеКарты", КупленныеКарты);
	СтруктураЗакрытия.Вставить("УдаленныеКарты", КартыКУдалению);
	Закрыть(СтруктураЗакрытия);
КонецПроцедуры

&НаКлиенте
Процедура КупитьКарту(Команда)
	ТекДанные = Элементы.КартыНаВитрине.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		ТекКарта = ТекДанные.Карта;
		ТекЦена = ТекДанные.Цена;
		Если Золото < ТекЦена Тогда
			Сообщить("Недостаточно золота для покупки");
		Иначе
			// Уменьшаем золото на величину цены.
			Золото = Золото - ТекЦена;
			// Добавляем карту в список купленных
			КупленныеКарты.Добавить(ТекКарта);
			// Удаляем карту из витрины
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Карта", ТекКарта);
			НайденныеСтроки = КартыНаВитрине.НайтиСтроки(СтруктураПоиска);
			Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
				КартыНаВитрине.Удалить(ТекНайденныеСтроки);
			КонецЦикла;
		КонецЕсли;
	Иначе
		Сообщить("Требуется выбрать карту");
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СтоимостьУдаленияКарты()
	Возврат 50;
КонецФункции

&НаКлиенте
Процедура УдалитьКарту(Команда)
	Если Золото < СтоимостьУдаленияКарты() Тогда
		Сообщить("Недостаточно золота для удаления карты");
		Возврат;
	КонецЕсли;
	СписокКарт = Новый СписокЗначений;
	Для Каждого ТекКарта Из КартыИгрока Цикл
		СписокКарт.Добавить(ТекКарта.ИдентификаторКарты, ТекКарта.Карта);
	КонецЦикла;
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораКартыДляУдаления", ЭтаФорма);
	ПоказатьВыборИзСписка(ОписаниеОповещения, СписокКарт);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКартыДляУдаления(Результат, ДополнительныеПараметры) Экспорт
	Если Результат <> Неопределено Тогда
		Золото = Золото - СтоимостьУдаленияКарты();
		КартыКУдалению.Добавить(Результат);
		// Удаляем карту из списка, чтобы исключить повторный выбор
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("ИдентификаторКарты", Результат);
		НайденныеСтроки = КартыИгрока.НайтиСтроки(СтруктураПоиска);
		Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
			КартыИгрока.Удалить(ТекНайденныеСтроки);
		КонецЦикла;
	Иначе
		// Пользователь отменил выбор.
	КонецЕсли;
КонецПроцедуры
