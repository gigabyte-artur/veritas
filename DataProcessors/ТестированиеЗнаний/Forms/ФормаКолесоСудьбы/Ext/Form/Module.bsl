&НаСервере
Перем ГсчКолеса;

&НаКлиенте
Перем НакопленноеЗолото;

&НаКлиенте
Перем НакопленноеЗдоровье;

&НаКлиенте
Перем НакопленныйЩит;

&НаКлиенте
Перем НакопленнаяЭнергия;

&НаКлиенте
Перем НакопленныеКарты;

&НаКлиенте
Перем ТекущееЗдоровьеЛок;

&НаКлиенте
Перем МаксимальноеЗдоровьеЛок;

&НаКлиенте
Перем ИсходноеЗолото;

&НаКлиенте
Перем ИсходныйЩит;

&НаКлиенте
Перем ИсходнаяЭнергия;

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ГсчКолеса = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
	ТекущееЗдоровьеЛок     = Параметры.ТекущееЗдоровье;
	МаксимальноеЗдоровьеЛок = Параметры.МаксимальноеЗдоровье;
	ИсходноеЗолото    = Параметры.Золото;
	ИсходныйЩит        = Параметры.Щит;
	ИсходнаяЭнергия    = Параметры.Энергия;
	НакопленноеЗолото   = 0;
	НакопленныйЩит       = 0;
	НакопленнаяЭнергия   = 0;
	НакопленноеЗдоровье  = 0;
	НакопленныеКарты     = 0;
	СчетчикЖалости       = 0;
	ЗдоровьеТекст = "❤ " + Строка(ТекущееЗдоровьеЛок + НакопленноеЗдоровье) + " / " + Строка(МаксимальноеЗдоровьеЛок);
	ЗолотоТекст   = "🪙 " + Строка(ИсходноеЗолото + НакопленноеЗолото);
	ЩитТекст      = "🛡 " + Строка(ИсходныйЩит + НакопленныйЩит);
	ЭнергияТекст  = "⚡ " + Строка(ИсходнаяЭнергия + НакопленнаяЭнергия);
	ЖалостьТекст  = "Шанс: 0 попыток";
	ПолеКолеса.Очистить();
	ТекстРезультата = "Нажмите «Крутить» для начала.";
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображениеПараметров()
	ЗдоровьеТекст = "❤ " + Строка(ТекущееЗдоровьеЛок + НакопленноеЗдоровье) + " / " + Строка(МаксимальноеЗдоровьеЛок);
	ЗолотоТекст   = "🪙 " + Строка(ИсходноеЗолото + НакопленноеЗолото);
	ЩитТекст      = "🛡 " + Строка(ИсходныйЩит + НакопленныйЩит);
	ЭнергияТекст  = "⚡ " + Строка(ИсходнаяЭнергия + НакопленнаяЭнергия);
	ЖалостьТекст  = "Шанс: " + Строка(Мин(СчетчикЖалости, 2)) + " попыток";
КонецПроцедуры

&НаКлиенте
Асинх Процедура Крутить(Команда)
	ТекстРезультата = "Вращение...";
	ПолеКолеса.Очистить();
	РезультатСпина = Ждать ВыполнитьСпинНаСервере(СчетчикЖалости);
	ОбработатьРезультатСпина(РезультатСпина);
КонецПроцедуры

&НаСервере
Функция ВыполнитьСпинНаСервере(СчетчикЖалостиСервер)
	ГсчКолеса = Новый ГенераторСлучайныхЧисел();
	РезультатФункции = Обработки.ТестированиеЗнаний.ВыполнитьСпинКолесаСудьбы(ГсчКолеса, СчетчикЖалостиСервер);
	Возврат РезультатФункции;
КонецФункции

&НаКлиенте
Процедура ОбработатьРезультатСпина(Результат)
	ПолеКолеса.Очистить();
	Для Каждого СтрокаМассив Из Результат.Поле Цикл
		НовСтр = ПолеКолеса.Добавить();
		НовСтр.Я0 = СтрокаМассив[0];
		НовСтр.Я1 = СтрокаМассив[1];
		НовСтр.Я2 = СтрокаМассив[2];
		НовСтр.Я3 = СтрокаМассив[3];
		НовСтр.Я4 = СтрокаМассив[4];
	КонецЦикла;

	Если Результат.ЭффектРиска = "Выбор" Тогда
		ПоказатьДиалогВыбораРиска(Результат);
		Возврат;
	КонецЕсли;

	ПрименитьРезультат(Результат);
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьРезультат(Результат)
	ТекстИтога = "";
	НакопленноеЗдоровье  = 0;
	НакопленнаяЭнергия   = 0;
	НакопленноеЗолото    = 0;
	НакопленныйЩит       = 0;
	НакопленныеКарты     = 0;
	Если Результат.ЭффектРиска = "Обнуление" Тогда
		ТекстИтога = "⚠ Риск 3 — награда обнулена!";
		Если Результат.СброситьЖалость Тогда
			СчетчикЖалости = 0;
		КонецЕсли;
	ИначеЕсли Результат.ЭффектРиска = "УронИИскажение" Тогда
		ТекстИтога = "💀 Риск " + Строка(Результат.КоличествоРиска) + " — урон " + Строка(Результат.НаградаЗдоровье) + " HP и Искажение (энергия " + Строка(Результат.НаградаЭнергия) + ")";
		НакопленноеЗдоровье  = НакопленноеЗдоровье  + Результат.НаградаЗдоровье;
		НакопленнаяЭнергия   = НакопленнаяЭнергия   + Результат.НаградаЭнергия;
		НакопленноеЗолото    = НакопленноеЗолото    + Результат.НаградаЗолото;
		НакопленныйЩит       = НакопленныйЩит       + Результат.НаградаЩит;
		НакопленныеКарты     = НакопленныеКарты     + Результат.НаградаКарта;
		СчетчикЖалости = СчетчикЖалости + 1;
	ИначеЕсли Результат.ТипРезультата = "Джекпот" Тогда
		ТекстИтога = "🎉 ДЖЕКПОТ! Символ: " + Результат.Символ + " (x" + Строка(Результат.Множитель) + ")";
		НакопленноеЗдоровье  = НакопленноеЗдоровье  + Результат.НаградаЗдоровье;
		НакопленнаяЭнергия   = НакопленнаяЭнергия   + Результат.НаградаЭнергия;
		НакопленноеЗолото    = НакопленноеЗолото    + Результат.НаградаЗолото;
		НакопленныйЩит       = НакопленныйЩит       + Результат.НаградаЩит;
		НакопленныеКарты     = НакопленныеКарты     + Результат.НаградаКарта;
		СчетчикЖалости = 0;
	ИначеЕсли Результат.ТипРезультата = "Бонус" Тогда
		ТекстИтога = "✨ Бонус! " + Результат.Символ + " x4 (множитель x" + Строка(Результат.Множитель) + ")";
		НакопленноеЗдоровье  = НакопленноеЗдоровье  + Результат.НаградаЗдоровье;
		НакопленнаяЭнергия   = НакопленнаяЭнергия   + Результат.НаградаЭнергия;
		НакопленноеЗолото    = НакопленноеЗолото    + Результат.НаградаЗолото;
		НакопленныйЩит       = НакопленныйЩит       + Результат.НаградаЩит;
		НакопленныеКарты     = НакопленныеКарты     + Результат.НаградаКарта;
		СчетчикЖалости = 0;
	ИначеЕсли Результат.ТипРезультата = "База" Тогда
		ТекстИтога = "✅ База! " + Результат.Символ + " x3";
		НакопленноеЗдоровье  = НакопленноеЗдоровье  + Результат.НаградаЗдоровье;
		НакопленнаяЭнергия   = НакопленнаяЭнергия   + Результат.НаградаЭнергия;
		НакопленноеЗолото    = НакопленноеЗолото    + Результат.НаградаЗолото;
		НакопленныйЩит       = НакопленныйЩит       + Результат.НаградаЩит;
		НакопленныеКарты     = НакопленныеКарты     + Результат.НаградаКарта;
		СчетчикЖалости = 0;
	ИначеЕсли Результат.ТипРезультата = "NearMiss" Тогда
		ТекстИтога = "🍒 Near-Miss! +" + Строка(Результат.НаградаЗолото) + " золота";
		НакопленноеЗолото    = НакопленноеЗолото    + Результат.НаградаЗолото;
		СчетчикЖалости = 0;
	Иначе
		ТекстИтога = "❌ Проигрыш. Счётчик жалости +1";
		СчетчикЖалости = СчетчикЖалости + 1;
	КонецЕсли;

	Если Результат.КоличествоРиска > 0 И Результат.ЭффектРиска <> "Обнуление" 
		И Результат.ЭффектРиска <> "УронИИскажение" И Результат.ЭффектРиска <> "Выбор" Тогда
		ТекстИтога = ТекстИтога + " | ⚠ Риск: " + Строка(Результат.КоличествоРиска);
	КонецЕсли;

	ТекстРезультата = ТекстИтога;
	ОбновитьОтображениеПараметров();
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДиалогВыбораРиска(Результат)
	ТекстВопроса = "⚠ Выпало 4 символа Риска!
|Награда спина сохранена, но требуется выбор:
|
|Да — потерять 30% валюты
|Нет — получить дебафф «Сомнение» (энергия -1)";
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ВыборРискаЗавершение", ЭтотОбъект, Результат), ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Нет, "Риск 4");
КонецПроцедуры

&НаКлиенте
Процедура ВыборРискаЗавершение(РезультатВыбора, Дополнительно) Экспорт
	Результат = Дополнительно;
	Если РезультатВыбора = КодВозвратаДиалога.Да Тогда
		ВсегоЗолота = ИсходноеЗолото + НакопленноеЗолото;
		ПотеряЗолота = Цел(ВсегоЗолота * 0.30);
		Если ПотеряЗолота < 1 Тогда
			ПотеряЗолота = 1;
		КонецЕсли;
		НакопленноеЗолото = НакопленноеЗолото - ПотеряЗолота;
		ТекстРезультата = "Потеряно " + Строка(ПотеряЗолота) + " золота (30%).";
	Иначе
		НакопленнаяЭнергия = Макс(НакопленнаяЭнергия - 1, 0);
		ТекстРезультата = "Наложено «Сомнение» (энергия -1).";
	КонецЕсли;

	Если Результат.СброситьЖалость Тогда
		СчетчикЖалости = 0;
	КонецЕсли;

	Если Результат.Выигрыш Тогда
		НакопленноеЗдоровье = НакопленноеЗдоровье + Результат.НаградаЗдоровье;
		НакопленнаяЭнергия  = НакопленнаяЭнергия  + Результат.НаградаЭнергия;
		НакопленноеЗолото   = НакопленноеЗолото   + Результат.НаградаЗолото;
		НакопленныйЩит      = НакопленныйЩит      + Результат.НаградаЩит;
		НакопленныеКарты    = НакопленныеКарты    + Результат.НаградаКарта;
	КонецЕсли;

	ОбновитьОтображениеПараметров();
КонецПроцедуры

&НаКлиенте
Процедура Закончить(Команда)
	СтруктураЗакрытия = Новый Структура;
	СтруктураЗакрытия.Вставить("Золото",   НакопленноеЗолото);
	СтруктураЗакрытия.Вставить("Здоровье", НакопленноеЗдоровье);
	СтруктураЗакрытия.Вставить("Щит",      НакопленныйЩит);
	СтруктураЗакрытия.Вставить("Энергия",  НакопленнаяЭнергия);
	СтруктураЗакрытия.Вставить("Карты",    НакопленныеКарты);
	Закрыть(СтруктураЗакрытия);
КонецПроцедуры
