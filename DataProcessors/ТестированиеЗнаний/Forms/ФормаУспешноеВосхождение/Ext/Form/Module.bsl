&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	Закрыть();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	МассивОткрытыхКарт = Новый Массив;
	Для Счетчик = 1 По 3 Цикл
		ОткрытаяКарта = Справочники.Карты.ОткрытьСлучайнуюКарту();
		Если ЗначениеЗаполнено(ОткрытаяКарта) Тогда
			МассивОткрытыхКарт.Добавить(ОткрытаяКарта);
		КонецЕсли;
	КонецЦикла;
	ОткрытыйМодификатор = Справочники.Модификаторы.ОткрытьСлучайныйМодификатор();
	ТекстОткрытия = "";
	Если МассивОткрытыхКарт.Количество() > 0 Тогда
		ИменаКарт = Новый Массив;
		Для Каждого Карта Из МассивОткрытыхКарт Цикл
			ИменаКарт.Добавить("[" + Карта.Наименование + "]");
		КонецЦикла;
		ТекстОткрытия = ТекстОткрытия + "Открыты карты: " + СтрСоединить(ИменаКарт, ", ") + ".";
	КонецЕсли;
	Если ЗначениеЗаполнено(ОткрытыйМодификатор) Тогда
		Если ТекстОткрытия <> "" Тогда
			ТекстОткрытия = ТекстОткрытия + " ";
		КонецЕсли;
		ТекстОткрытия = ТекстОткрытия + "Открыт модификатор: [" + ОткрытыйМодификатор.Наименование + "].";
	КонецЕсли;
	Если ТекстОткрытия = "" Тогда
		ТекстОткрытия = "Все возможные награды разблокированы ранее.";
	КонецЕсли;
	Элементы.ДекорацияОткрытия.Заголовок = ТекстОткрытия;
КонецПроцедуры
