// Определяет, является ли этап этапом элитной сложности.
//
// Параметры:
//	 - .
//
// Возвращаемое значение:
//	 - .
//
&НаСервереБезКонтекста
Функция ЭтоЭтапЭлитнойСложности(НомерЭтапаВход)
	РезультатФункции = Ложь;
	ЭтапыЭличнойСложности = Обработки.ТестированиеЗнаний.МассивЭтаповЭлитныхПротивников();
	ЭтоЭлитнаяСложность = (ЭтапыЭличнойСложности.Найти(НомерЭтапаВход) <> Неопределено);
	Возврат РезультатФункции;	
КонецФункции		 // ЭтоЭтапЭлитнойСложности()

// Устанавливает на форме реквизит СложностьПротивника.
//
&НаСервере
Процедура СчитатьСложностьПротивника()
	ЭтоЭлитнаяСложность = Обработки.ТестированиеЗнаний.ЭтоЭтапЭлитнойСложности(НомерЭтапа);
	СложностьПротивника = Перечисления.СложностиПротивников.Обычная;
	Если НомерЭтапа <= 5 Тогда
		СложностьПротивника = Перечисления.СложностиПротивников.Начальная;
	Иначе
		Если ЭтоЭлитнаяСложность Тогда
			СложностьПротивника = Перечисления.СложностиПротивников.Элитная;
		Иначе	
			СложностьПротивника = Перечисления.СложностиПротивников.Обычная;
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры		// СчитатьСложностьПротивника()

// Размещает случайного противника на форму.
//
&НаСервере
Процедура ЗагрузитьПротивника()
	СчитатьСложностьПротивника();
	Противник = Справочники.Противники.ПолучитьСлучайногоПротивника(ГСЧ, СложностьПротивника);
КонецПроцедуры		// ЗагрузитьПротивника()

// Загружает таблицу цикла действий противника в реквизит формы ЦиклДействийПротивника.
//
&НаСервере
Процедура ЗагрузитьЦиклДействийПротивника(Противник)
	ЦиклДействийПротивника.Очистить();
	ТаблицаДействий = Справочники.Противники.ПолучитьТаблицуДействийЦикла(Противник);
	Для Каждого СтрокаДействия Из ТаблицаДействий Цикл
		НоваяСтрока = ЦиклДействийПротивника.Добавить();
		НоваяСтрока.ДействиеЦикла = СтрокаДействия.ДействиеЦикла;
		НоваяСтрока.МинимальнаяСила = СтрокаДействия.МинимальнаяСила;
		НоваяСтрока.МаксимальнаяСила = СтрокаДействия.МаксимальнаяСила;
		НоваяСтрока.ИдентификаторСтроки = Строка(Новый УникальныйИдентификатор);
	КонецЦикла;
КонецПроцедуры		// ЗагрузитьЦиклДействийПротивника()

// Возвращает начальное значение здоровья игрока по умолчанию.
//
&НаСервере
Функция НачальноеЗдоровьеИгрокаПоУмолчанию()
	Возврат 100;
