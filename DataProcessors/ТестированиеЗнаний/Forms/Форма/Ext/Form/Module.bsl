//
&НаСервере
Процедура ДействиеКарты_БыстраяДетонация(НайденнаяКарта, ИдентификаторКартыВход)
	ВидПараметраЯд = Перечисления.ВидыПараметровИгроков.Яд;
	ЗначениеЯда = ПолучитьЗначениеПараметраПротивника(ВидПараметраЯд);
	Если ЗначениеЯда > 0 Тогда
		НанестиУронПротивнику(ЗначениеЯда * 3);
		УдалитьПараметрПротивника(ВидПараметраЯд);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_БыстраяДетонация()

// Выполняет действие карты СтеклянныйЩит.
// Добавляет игроку 1 единицу параметра СтеклянныйЩит.
//
// Параметры:
//  НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//  ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_СтеклянныйЩит(НайденнаяКарта, ИдентификаторКартыВход)
	ВидПараметраСтеклянныйЩит = Перечисления.ВидыПараметровИгроков.СтеклянныйЩит;
	УвеличитьПараметрИгрока(ВидПараметраСтеклянныйЩит, 1);
КонецПроцедуры		// ДействиеКарты_СтеклянныйЩит()

// Выполняет действие карты СвежийВзгляд.
// Игрок берет 3 карты из стопки добора в руку и сбрасывает 1 случайную карту из руки в стопку сброса.
//
// Параметры:
//  НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//  ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_СвежийВзгляд(НайденнаяКарта, ИдентификаторКартыВход)
	// Игрок берет 3 карты из стопки добора в руку
	ДобратьВРукуКарты(3);

	// Сбрасывает 1 случайную карту из руки в стопку сброса
	Если РукаИгрока.Количество() > 0 Тогда
		Индекс = ГсчКлиент.СлучайноеЧисло(0, РукаИгрока.Количество() - 1);
		ВыбраннаяКартаСтрока = РукаИгрока[Индекс];
		ИдентификаторКарты = ВыбраннаяКартаСтрока.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_СвежийВзгляд()

// Выполняет действие карты Замена.
// Игрок берет 2 карты из стопки добора в руку и сбрасывает 1 случайную карту из руки в стопку сброса.
//
// Параметры:
//  НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//  ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Замена(НайденнаяКарта, ИдентификаторКартыВход)
	// Игрок берет 2 карты из стопки добора в руку
	ДобратьВРукуКарты(2);

	// Сбрасывает 1 случайную карту из руки в стопку сброса
	Если РукаИгрока.Количество() > 0 Тогда
		Индекс = ГсчКлиент.СлучайноеЧисло(0, РукаИгрока.Количество() - 1);
		ВыбраннаяКартаСтрока = РукаИгрока[Индекс];
		ИдентификаторКарты = ВыбраннаяКартаСтрока.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Замена()

// Выполняет действие карты Приют.
// Игрок получает 5 щита. Если у игрока больше 11 щита, игрок берет 1 карту 
// (дополнительно) из стопки добора в руку.
//
// Параметры:
//  НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//  ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Приют(НайденнаяКарта, ИдентификаторКартыВход)
	ТекущийЩит = ПолучитьЗначениеПараметраИгрока(ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Щит"));
	// Игрок получает 5 щита
	УвеличитьЩитИгрока(5);
	// Если у игрока больше 11 щита, игрок берет 1 карту из стопки добора в руку
	Если ТекущийЩит > 11 Тогда
		ДобратьКартуВРуку();
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Приют()

// Выполняет действие карты Тройка.
// Последовательно выполняет действия:
// 1. Игрок излечивает 3 здоровья;
// 2. Игрок получает 3 щита;
// 3. Игрок наносит 3 урона противнику;
// 4. Игрок добирает 3 карты из таблицы СтопкаДобора в таблицу РукаИгрока.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Тройка(КартаВход, ИдентифкаторКартыВход)
	// 1. Игрок излечивает 3 здоровья
	ВосстановитьЗдоровьеИгрока(3);
	// 2. Игрок получает 3 щита
	УвеличитьЩитИгрока(3);
	// 3. Игрок наносит 3 урона противнику
	НанестиУронПротивнику(3);
	// 4. Игрок добирает 3 карты из СтопкаДобора в РукаИгрока
	ДобратьВРукуКарты(3);
КонецПроцедуры		// ДействиеКарты_Тройка()

// Выполняет действие карты Пятерка.
// Последовательно выполняет действия:
// 1. Игрок излечивает 5 здоровья;
// 2. Игрок получает 5 щита;
// 3. Игрок наносит 5 урона противнику;
// 4. Игрок добирает 5 карт из таблицы СтопкаДобора в таблицу РукаИгрока.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Пятерка(КартаВход, ИдентифкаторКартыВход)
	// 1. Игрок излечивает 5 здоровья
	ВосстановитьЗдоровьеИгрока(5);
	// 2. Игрок получает 5 щита
	УвеличитьЩитИгрока(5);
	// 3. Игрок наносит 5 урона противнику
	НанестиУронПротивнику(5);
	// 4. Игрок добирает 5 карт из СтопкаДобора в РукаИгрока
	ДобратьВРукуКарты(5);
КонецПроцедуры		// ДействиеКарты_Пятерка()

// Очищает таблицу параметров, оставляя только основные параметры.
//
// Параметры:
//  ТаблицаПараметров - ТаблицаЗначений - таблица параметров для очистки.
//
&НаСервере
Процедура ОчиститьПараметрыКромеОсновных(ТаблицаПараметров)
	ОсновныеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьОсновныеПараметры();
	// Копируем строки для удаления, чтобы избежать изменения коллекции во время итерации
	МассивДляУдаления = Новый Массив;
	Для Каждого ТекПараметр Из ТаблицаПараметров Цикл
		Если ОсновныеПараметры.Найти(ТекПараметр.ВидПараметра) = Неопределено Тогда
			МассивДляУдаления.Добавить(ТекПараметр);
		КонецЕсли;
	КонецЦикла;
	// Удаляем неосновные параметры
	Для Каждого ТекПараметрИзМассива Из МассивДляУдаления Цикл
		ТаблицаПараметров.Удалить(ТекПараметрИзМассива);
	КонецЦикла;
КонецПроцедуры		// ОчиститьПараметрыКромеОсновных()

// Наносит урон противнику, учитывая его щит.
// Щит поглощает урон первым, остаток урона наносится по здоровью.
//
// Параметры:
//  КоличествоУрона - Число - количество урона, которое наносится противнику.
//
// Возвращаемое значение:
//  Структура - структура с полями:
//    - УронПоЩиту - Число - количество урона, поглощённое щитом.
//    - УронПоЗдоровью - Число - количество урона, нанесённое по здоровью.
//
&НаСервере
Функция НанестиУронПротивнику(КоличествоУрона)
	// Инициализация
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	// Получение размера щита противника.
	ЗначениеЩита = ПолучитьЗначениеПараметраПротивника(ВидПараметраЩит);
	УронПоЩиту = 0;
	ОстаточныйУрон = КоличествоУрона;
	// Проверка урона по щиту.
	Если ЗначениеЩита > 0 Тогда
		Если ЗначениеЩита >= КоличествоУрона Тогда
			НовоеЗначениеЩита = ЗначениеЩита - КоличествоУрона;
			УстановитьПараметрПротивника(ВидПараметраЩит, НовоеЗначениеЩита);
			УронПоЩиту = КоличествоУрона;
			ОстаточныйУрон = 0;
		Иначе
			ОстатокУрона = КоличествоУрона - ЗначениеЩита;
			УронПоЩиту = ЗначениеЩита;
			УстановитьПараметрПротивника(ВидПараметраЩит, 0);
			ОстаточныйУрон = ОстатокУрона;
		КонецЕсли;
	Иначе
		// Щита нет, весь урон наносится по здоровью.
	КонецЕсли;
	// Наносим остаточный урон по здоровью.
	ВидПараметраЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраЗдоровье);
	НовоеЗдоровье = ТекущееЗдоровье - ОстаточныйУрон;
	Если НовоеЗдоровье < 0 Тогда
		НовоеЗдоровье = 0;
	КонецЕсли;
	УстановитьПараметрПротивника(ВидПараметраЗдоровье, НовоеЗдоровье);
	// Формируем и возвращаем результат.
	Результат = Новый Структура;
	Результат.Вставить("УронПоЩиту", УронПоЩиту);
	Результат.Вставить("УронПоЗдоровью", ОстаточныйУрон);
	Возврат Результат;
КонецФункции		// НанестиУронПротивнику()

// Меняет цвет заголовка противника в зависимости от сложности.
//
&НаКлиенте
Процедура ИзменитьЦветПротивника()
	Если СложностьПротивника = ПредопределенноеЗначение("Перечисление.СложностиПротивников.Начальная") Тогда
		Элементы.Противник.ЦветТекстаЗаголовка = WebЦвета.ЗеленыйЛес;
	ИначеЕсли СложностьПротивника = ПредопределенноеЗначение("Перечисление.СложностиПротивников.Обычная") Тогда
		Элементы.Противник.ЦветТекстаЗаголовка = WebЦвета.Синий;
	ИначеЕсли СложностьПротивника = ПредопределенноеЗначение("Перечисление.СложностиПротивников.Элитная") Тогда
		Элементы.Противник.ЦветТекстаЗаголовка = WebЦвета.Красный;
	ИначеЕсли СложностьПротивника = ПредопределенноеЗначение("Перечисление.СложностиПротивников.Босс") Тогда
		Элементы.Противник.ЦветТекстаЗаголовка = WebЦвета.Фиолетовый;
	Иначе
		Элементы.Противник.ЦветТекстаЗаголовка = WebЦвета.Синий;
	КонецЕсли;
КонецПроцедуры		// ИзменитьЦветПротивника()

// Обсуществляет розыгрыш карты КартаВход.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую нужно разыграть.
//
&НаКлиенте
Процедура РазыгратьКарту(ИдентификаторКартыВход)
	НайденнаяКарта = ПредопределенноеЗначение("Справочник.Карты.ПустаяСсылка");
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторКарты", ИдентификаторКартыВход);
	НайденныеСтроки = РукаИгрока.НайтиСтроки(СтруктураПоиска);
	Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
		НайденнаяКарта = ТекНайденныеСтроки.Карта;
	КонецЦикла;
	Если ЗначениеЗаполнено(НайденнаяКарта) Тогда
		ДействиеВыбраннойКарты(НайденнаяКарта, ИдентификаторКартыВход);
		ПереместиКартуИзСтопки(ИдентификаторКартыВход, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
		ОтобразитьСостояниеИгрока();
		ОтобразитьСостояниеПротивника();
	Иначе
		Сообщить("Карта " + Строка(ИдентификаторКартыВход) + " не найден.");
	КонецЕсли;
КонецПроцедуры		// РазыгратьКарту()

// Выполняет действие карты Фокус.
// Меняет местами стопки сброса и добора, после чего игрок берёт одну карту из стопки добора.
//
// Параметры:
//  НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//  ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Фокус(НайденнаяКарта, ИдентификаторКартыВход)
	// Сохраняем карты из обеих стопок в массивы структур
	МассивСтопкаСброса = Новый Массив;
	Для Каждого ТекСтрока Из СтопкаСброса Цикл
		СтруктураКарты = Новый Структура;
		СтруктураКарты.Вставить("Карта", ТекСтрока.Карта);
		СтруктураКарты.Вставить("ИдентификаторКарты", ТекСтрока.ИдентификаторКарты);
		МассивСтопкаСброса.Добавить(СтруктураКарты);
	КонецЦикла;
	МассивСтопкаДобора = Новый Массив;
	Для Каждого ТекСтрока Из СтопкаДобора Цикл
		СтруктураКарты = Новый Структура;
		СтруктураКарты.Вставить("Карта", ТекСтрока.Карта);
		СтруктураКарты.Вставить("ИдентификаторКарты", ТекСтрока.ИдентификаторКарты);
		МассивСтопкаДобора.Добавить(СтруктураКарты);
	КонецЦикла;
	// Очищаем обе стопки
	СтопкаСброса.Очистить();
	СтопкаДобора.Очистить();
	// Заполняем стопку добора картами из бывшей стопки сброса
	Для Каждого ТекКарта Из МассивСтопкаСброса Цикл
		НоваяСтрока = СтопкаДобора.Добавить();
		НоваяСтрока.Карта = ТекКарта.Карта;
		НоваяСтрока.ИдентификаторКарты = ТекКарта.ИдентификаторКарты;
	КонецЦикла;
	// Заполняем стопку сброса картами из бывшей стопки добора
	Для Каждого ТекКарта Из МассивСтопкаДобора Цикл
		НоваяСтрока = СтопкаСброса.Добавить();
		НоваяСтрока.Карта = ТекКарта.Карта;
		НоваяСтрока.ИдентификаторКарты = ТекКарта.ИдентификаторКарты;
	КонецЦикла;
	// Игрок берёт одну карту из стопки добора
	ДобратьКартуВРуку();
КонецПроцедуры		// ДействиеКарты_Фокус()

#КонецОбласти

&НаКлиенте
Процедура НачатьЗадание()
	Если ДостигнутКонецРаунда() Тогда
		Сообщить("Задано " + Строка(КоличествоЗаданных) + " вопросов. Верно отвечено: " + Строка(КоличествоВерных));
		ОтобразитьСледующееЗадание(Сборник);
	Иначе
		ОтобразитьСледующееЗадание(Сборник);
	КонецЕсли;
	УменьшитьПараметрыИгроков();
	УменьшитьПараметрыПротивников();
КонецПроцедуры

// Перемещает карту из стопки добора в руку. Если карт нет - перемешивает сброс в добор.
//
&НаСервере
Процедура ДобратьКартуВРуку()
	Если СтопкаДобора.Количество() > 0 Тогда
		КартаДляПеремещения = СтопкаДобора[0];
		ИдентификаторПеремещаемойКарты = КартаДляПеремещения.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторПеремещаемойКарты, "СтопкаДобора", "РукаИгрока", ЭтаФорма);
	Иначе
		ПеремешатьСбросВДобор();
		КартаДляПеремещения = СтопкаДобора[0];
		ИдентификаторПеремещаемойКарты = КартаДляПеремещения.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторПеремещаемойКарты, "СтопкаДобора", "РукаИгрока", ЭтаФорма);
	КонецЕсли;
КонецПроцедуры		// ДобратьКартуВРуку()

// Несколько раз добирает карты из стопки добора в руку.
&НаСервере
Процедура ДобратьВРукуКарты(КоличествоВход)
	Для Счетчик = 1 По КоличествоВход Цикл
		ДобратьКартуВРуку();
	КонецЦикла;
КонецПроцедуры		// ДобратьВРукуКарты()

&НаКлиенте
Процедура НаградаСерии_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		Награда = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Награда", Неопределено);
		Размер  = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Размер", Неопределено);
		Если Награда = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото") Тогда
			// Золото.
			УвеличитьПараметрИгрока(ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото"), Размер);
		ИначеЕсли Награда = ПредопределенноеЗначение("Справочник.Карты.ПустаяСсылка") Тогда
			// Добор карт.
			ДобратьВРукуКарты(Размер);
		ИначеЕсли Награда = ПредопределенноеЗначение("Перечисление.ВариантыДействийПротивников.Атака") Тогда
			// Атака.
			УронПротивникуПоКоличеству(Размер);
		ИначеЕсли Награда = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия") Тогда
			// Энергия.
			УвеличитьПараметрИгрока(ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия"), Размер);
		Иначе
			Сообщить("Неизвестный тип награды: " + Награда);
		КонецЕсли;
		ОтобразитьСледующееЗадание(Сборник);
		ОтобразитьСостояниеИгрока();
		ОтобразитьСостояниеПротивника();
	Иначе
        // Пользователь отказался. Ничего не делаем.
	КонецЕсли;
КонецПроцедуры		// НаградаСерии_Заверешние()

// Увеличивает Заряд серии на 1, при необходимости выполняет связанные действия.
//
&НаКлиенте
Процедура УвеличитьЗарядСерии()
	ВидПараметраЭнергия = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия");
	Если ЗарядСерии < 2 Тогда
		ЗарядСерии = ЗарядСерии + 1;
		ОтобразитьСледующееЗадание(Сборник);
		ОтобразитьСостояниеИгрока();
		ОтобразитьСостояниеПротивника();
	Иначе
		ЗарядСерии = 0;
		ПараметрыФормы = Новый Структура;
		ОписаниеОповещенияЗакрытие = Новый ОписаниеОповещения("НаградаСерии_Завершение", ЭтотОбъект);
		ОткрытьФорму("Обработка.ТестированиеЗнаний.Форма.ФормаНаградаСерии", ПараметрыФормы, ЭтаФорма, , , , ОписаниеОповещенияЗакрытие, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
КонецПроцедуры		// УвеличитьЗарядСерии()

// Осуществляет обработку верного ответа для режима викторины Восхождение.
//
&НаКлиенте
Процедура ОбработатьВерныйОтветВосхождение()
	ДействияИгрока();
	УвеличитьЗарядСерии();
КонецПроцедуры		// ОбработатьВерныйОтветВосхождение()

// Фиксирует ответ пользователя номер НомерОтветаВход.
&НаКлиенте
Процедура ВыбратьВариантОтвета(НомерОтветаВход)
	// Инициализация.
	ВероятностьПодсказки = 11;
	НовыйНомерПравильногоОтвета = ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтвета, Сложность);
	ЭтоВосхождение = (РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение"));
	ЭтоВерныйОтвет = (НомерОтветаВход = НовыйНомерПравильногоОтвета);
	НовыйОпыт = 0;
	МодификаторВолчийКлык = ПредопределенноеЗначение("Справочник.Модификаторы.ВолчийКлык");
	// Обработка ответа.
	Если ЭтоВерныйОтвет Тогда
		Если ЭтоВосхождение Тогда
			ОбработатьВерныйОтветВосхождение();
		Иначе
			ОтобразитьСледующееЗадание(Сборник);
		КонецЕсли;	
		Если НЕ ОтветДан Тогда
			КоличествоВерных = КоличествоВерных + 1;
			СерияПравильных = СерияПравильных + 1;
			НовыйОпыт = 3;
			// Применяем модификатор "ВолчийКлык" при правильном ответе.
			Если ЭтоВосхождение Тогда
				Если МодификаторАктивен(МодификаторВолчийКлык) Тогда
					ПрименитьМодификатор_ВолчийКлык(Истина);
				Иначе
					// Нет модификатора, не увеличиваем Ярость.
				КонецЕсли;
			Иначе
				// Не требуется применения модифкаторов для прочих режимов.
			КонецЕсли;	
		Иначе
			// Не увеличиваем количество верных ответов.
		КонецЕсли;
	Иначе      
		СтруктураПараметров = Новый Структура;
		ВыбранноеЧисло = ГсчКлиент.СлучайноеЧисло(1, 100);
		Если (ВыбранноеЧисло < ВероятностьПодсказки) Тогда
			ТекстВопроса = НСтр("ru = 'Ответ неверный. Хотите использовать подсказку?'");
			Режим = РежимДиалогаВопрос.ДаНет;
			Оповещение = Новый ОписаниеОповещения("ПодтверждениеИспользованиеПодсказкиЗавершение", ЭтаФорма, СтруктураПараметров);
			ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
		Иначе                       
			ОбработкаНеправильногоОтвета();
		КонецЕсли;
	КонецЕсли;
	ОбработатьДостиженияВыборОтвета();
	НачислитьОпыт(НовыйОпыт, ТекПользователь);
	ЗаписатьОтветВРезультаты(Сборник, ТекПользователь, ЭтоВерныйОтвет);
КонецПроцедуры		// ВыбратьВариантОтвета()

// Преобразует номер правильного ответа ИсходныйНомерПравильногоОтветаВход
// в номер ответа на командах формы, ориентируясь на сложность сборника 
// СборникВход.
&НаКлиенте
Функция ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СложностьВход)
	РезультатФункции = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СложностьВход);
	Возврат РезультатФункции;
КонецФункции		// ПреобразоватьНомерПравильногоОтвета()

// Управляет видимостью элементов на форме.
&НаСервере
Процедура УправлениеВидимостью()
	// Количество ответов.
	СложностьСборника = Сборник.Сложность;
	Если (НЕ ЗначениеЗаполнено(СложностьСборника)) ИЛИ (СложностьСборника = Перечисления.СложностиСборников.ШестьОтветов) Тогда
		Элементы.ВыбратьВариант3.Видимость = Истина;
		Элементы.ВыбратьВариант6.Видимость = Истина;
	ИначеЕсли (СложностьСборника = Перечисления.СложностиСборников.ЧетыреОтвета) Тогда
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;	
	Иначе
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;
	КонецЕсли;	
	// Не показывать пустой вопрос.
	ПустоеЗадание = (СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "" ИЛИ СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "-");
	Элементы.ЗаданиеТекстВопросаЗадания.Видимость = НЕ ПустоеЗадание;
	Элементы.УбратьНевернуюПоловину.Доступность = НЕ НеверныеВариантыУбраны;
	// Скрывать подсказки для режима Восхождение.
	ЭтоРежимВосхождение = (РежимВикторины = Перечисления.РежимыВикторины.Восхождение);
	Элементы.ГруппаПодменюПодсказки.Видимость = НЕ (ЭтоРежимВосхождение);
	// Отображение информации об игре в режиме Восхождение.
	Элементы.ГруппаСтраницаОбИгре.Видимость = ЭтоРежимВосхождение;
	Если ЭтоРежимВосхождение Тогда
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	Иначе
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	КонецЕсли;
// Отображение элемента СледующееДействиеПротивника только в режиме Восхождение.
	Элементы.СледующееДействиеПротивника.Видимость = ЭтоРежимВосхождение;
	// Отображение группы ГруппаРезультаты только когда не выбран режим Восхождение.
	Элементы.ГруппаРезультаты.Видимость = НЕ ЭтоРежимВосхождение;
КонецПроцедуры		// УправлениеВидимостью()

// Возвращает текст вопроса задания ЗаданиеВход.
&НаСервереБезКонтекста
Функция ПолучитьТекстВопроса(ЗаданиеВход)
	РезультатФункции = ЗаданиеВход.ТекстВопросаЗадания;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТекстВопроса()

// Возвращает массив номеров неправильных ответов, которые необходимо
// удалить для подсказки 50/50.
&НаСервере
Функция ПолучитьМассивНеправильныхОтветовКУдалению(НомерПравильногоОтветаВход, СборникВход)
	РезультатФункции = Новый Массив;
	НовыйНомерПравильногоОтвета = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтветаВход, Сложность);
	Если Сложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
		РезультатФункции = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 6);
	ИначеЕсли Сложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
		ВремРезультат = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 4);
		Для Каждого ТекВремРезультат Из ВремРезультат Цикл
			НовыйНомер = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(ТекВремРезультат, Сложность);
			РезультатФункции.Добавить(НовыйНомер);
		КонецЦикла;	
	Иначе
		РезультатФункции = Новый Массив;
		ТекстСообщения = НСтр("ru = 'Неизвестный вариант сложности: %Сложность%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Сложность%", Строка(Сложность));
		Сообщить(ТекстСообщения);
	КонецЕсли;	
	Возврат РезультатФункции;
КонецФункции		// ПолучитьМассивНеправильныхОтветовКУдалению()

// Получает и выводит следующее задание на форму.
&НаКлиенте
Процедура ОтобразитьСледующееЗадание(СборникВход)
	НеверныеВариантыУбраны = Ложь;
	Элементы.ВыбратьВариант1.Доступность = Истина;
	Элементы.ВыбратьВариант2.Доступность = Истина;
	Элементы.ВыбратьВариант3.Доступность = Истина;
	Элементы.ВыбратьВариант4.Доступность = Истина;
	Элементы.ВыбратьВариант5.Доступность = Истина;
	Элементы.ВыбратьВариант6.Доступность = Истина;
	Элементы.ВыбратьВариант1.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант2.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант3.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант4.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант5.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант6.ЦветФона = Новый Цвет();
	РезультатСмены = СледующееЗадание_Сервер(СборникВход, РежимВикторины);	
	Сборник = РезультатСмены.Сборник;
	АдресКартинки = РезультатСмены.АдресКартинки;
	КоличествоЗаданных = КоличествоЗаданных + 1;
	ОтветДан = Ложь;
	ЭтаФорма.Заголовок = Строка(Сборник);
	ДобавитьТекущуюДатуВСтек();
КонецПроцедуры

// Блокирует команды с неверными ответами по номерам массива МассивНеверных.
&НаКлиентеНаСервереБезКонтекста
Процедура УбратьНеверныеОтветы(МассивНеверных, Форма)
	Если МассивНеверных.Найти(1) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант1.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(2) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант2.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(3) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант3.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(4) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант4.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(5) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант5.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(6) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант6.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры		// УбратьНеверныеОтветы()

// Добавляет в стек ДатыОтветов текущую дату
&НаКлиенте
Процедура ДобавитьТекущуюДатуВСтек()
	РазмерСтекаДат = 20;
	ТекДата = ТекущаяДата();
	НовыйСписокДаты = Новый СписокЗначений;
	НовыйСписокДаты.Добавить(ТекДата);
	Если ДатыОтветов.Количество() < РазмерСтекаДат Тогда
		Для Каждого ТекДатыОтветов Из ДатыОтветов Цикл
			НовыйСписокДаты.Добавить(ТекДатыОтветов.Значение);
		КонецЦикла;	
	Иначе
		Для Счетчик = 0 По РазмерСтекаДат - 2 Цикл
			ТекДатыОтветов = ДатыОтветов.Получить(Счетчик);
			НовыйСписокДаты.Добавить(ТекДатыОтветов.Значение);
		КонецЦикла;
	КонецЕсли;
	МассивДат = НовыйСписокДаты.ВыгрузитьЗначения();
	ДатыОтветов.ЗагрузитьЗначения(МассивДат);
КонецПроцедуры		// ДобавитьТекущуюДатуВСтек()

// Выполняет удаление половины неправильных ответов на вопрос.
&НаКлиенте
Процедура ОбработкаУбратьНевернуюПоловину()
	МассивНеверных = ПолучитьМассивНеправильныхОтветовКУдалению(НомерПравильногоОтвета, Сборник);
	УбратьНеверныеОтветы(МассивНеверных, ЭтаФорма);
	НеверныеВариантыУбраны = Истина;
	УправлениеВидимостью();
КонецПроцедуры		// ОбработкаУбратьНевернуюПоловину()

&НаКлиенте
Процедура НастройкиВикторины_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		ТекПользователь		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Пользователь", ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка"));
		НовыйСборник		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Сборник", ПредопределенноеЗначение("Справочник.Сборники.ПустаяСсылка"));
		РежимВикторины		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "РежимВикторины", ПредопределенноеЗначение("Перечисление.РежимыВикторины.ОдинСборникБезОстановки"));
		ВыбранныеСборники	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "ВыбранныеСборники", Новый СписокЗначений);
		Если НовыйСборник <> Сборник Тогда
			Сборник = НовыйСборник;
			УправлениеВидимостью();
			КоличествоВерных = 0;
			КоличествоЗаданных = 0;
			ОтобразитьСледующееЗадание(Сборник);
		Иначе
			// Сборник не изменился. Не отображаем новый вопрос.
		КонецЕсли;
	Иначе
		// Не изменяем значения настроек.
	КонецЕсли;
КонецПроцедуры		// НастройкиВикторины_Завершение()

// Добавляет модификаторы по умолчанию в таблицу Модификаторы.
//
&НаСервере
Процедура ЗагрузитьМодификаторыПоУмолчанию()
	Модификаторы.Очистить();
	// Загрузим один положительный и один отрицательный модификатор.
	ПоложительныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Истина, Гсч);
	Если ЗначениеЗаполнено(ПоложительныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ПоложительныйМодификатор;
	Иначе
		// Положительный модификатор не найден.
	КонецЕсли;
	ОтрицательныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Ложь, Гсч);
	Если ЗначениеЗаполнено(ОтрицательныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ОтрицательныйМодификатор;
	Иначе
		// Отрицательный модификатор не найден.
	КонецЕсли;
КонецПроцедуры		// ЗагрузитьМодификаторыПоУмолчанию()

#Область СохранениеЗагрузка

&НаСервере
Процедура СохранитьВосхождение_Сервер()
	// Формируем структуру для сохранения данных восхождения
	ДанныеВосхождения = Новый Структура;
	ДанныеВосхождения.Вставить("ПараметрыИгрока", ПараметрыИгрока.Выгрузить());
	ДанныеВосхождения.Вставить("КолодаИгрока", КолодаИгрока.Выгрузить());
	ДанныеВосхождения.Вставить("Модификаторы", Модификаторы.Выгрузить());
	ДанныеВосхождения.Вставить("НомерЭтапа", НомерЭтапа);
	ДанныеВосхождения.Вставить("Противник", Противник);
	РегистрыСведений.СохраненияВосхождения.СохранитьВосхождениеПользователя(ДанныеВосхождения, ТекПользователь);
КонецПроцедуры		 // СохранитьВосхождение_Сервер()

// Сохраняет результаты восхождения.
&НаКлиенте
Процедура СохранитьВосхождение()
	СохранитьВосхождение_Сервер();
КонецПроцедуры		// СохранитьВосхождение()

// Вовзращает структуру сохранения пользователя ПользовательВход. 
//
// Параметры:
//	ПользовательВход - СправочникСсылка.Пользователи - Пользователь, для которого требуется получить сохранение.
//
// Возвращаемое значение:
//	Структура - Структура с резукльтатом сохранения.
//
&НаСервереБезКонтекста
Функция ПолучитьСтруктуруСохранения(ПользовательВход)
	РезультатФункции = РегистрыСведений.СохраненияВосхождения.ПолучитьСохранениеВосхождения(ПользовательВход);
	Возврат РезультатФункции;                
КонецФункции		 // ПолучитьСтруктуруСохранения()

// Соуществляет загрузку сохранения из хранилища значений ХранилищеВход
//
// Параметры:
//	ХранилищеВход - ХранилищеЗначений - Хранилище, содержащее данные сохранения.
//
&НаСервере
Процедура ЗагрузитьХранилищеСохранения(ХранилищеВход)
	Если ХранилищеВход <> Неопределено Тогда
		СтруктураДанныхСохранения = ХранилищеВход.Получить();
		Если ТипЗнч(СтруктураДанныхСохранения) = Тип("Структура") Тогда
			// Считывание данных.
			НоваяКолодаИгрока		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСохранения, "КолодаИгрока", Новый ТаблицаЗначений);
			НовыеПараметрыИгрока	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСохранения, "ПараметрыИгрока", Новый ТаблицаЗначений);
			НовыеМодификаторы		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСохранения, "Модификаторы", Новый ТаблицаЗначений);
			НовыйНомерЭтапа			 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСохранения, "НомерЭтапа", 1);
			НовыйПротивник			 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСохранения, "Противник", Справочники.Противники.ПустаяСсылка());
			// Очистка таблиц.
			КолодаИгрока.Очистить();
			ПараметрыИгрока.Очистить();
			Модификаторы.Очистить();
			// Загрузка в данные формы.
			НомерЭтапа = НовыйНомерЭтапа;
			Противник = НовыйПротивник;
			КолодаИгрока.Загрузить(НоваяКолодаИгрока);
			ПараметрыИгрока.Загрузить(НовыеПараметрыИгрока);
			Модификаторы.Загрузить(НовыеМодификаторы);
		Иначе
			Сообщить("Не удалось считать сохранение");
		КонецЕсли;
	Иначе
		Сообщить("Не удалось загрузить сохранение");
	КонецЕсли;
КонецПроцедуры		// ЗагрузитьХранилищеСохранения()

&НаКлиенте
Процедура ПодтверждениеЗагрузкаСохранения_Завершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Попытка
			ХранилищеСохранения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ХранилищеСохранения", Неопределено);
			ЗагрузитьХранилищеСохранения(ХранилищеСохранения);
			// Повторное сохранение после загрузки.
			СохранитьВосхождение();
		Исключение
			ТекстСообщения = НСтр("ru = 'При попытке загрузить сохранение возника ошибка: %ОписаниеОшибки%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки());
			Сообщить(ТекстСообщения);
		КонецПопытки;
	Иначе
		// Пользователь отказался. Ничего не делаем.
	КонецЕсли;
КонецПроцедуры		// ПодтверждениеЗагрузкаСохранения_Завершение()

&НаКлиенте
Процедура ПроверитьСохранениеВосхождения()
	СтруктураСохранения = ПолучитьСтруктуруСохранения(ТекПользователь);
	СохранениеНайдено = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураСохранения, "СохранениеНайдено", Ложь);
	ХранилищеСохранения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураСохранения, "ХранилищеСохранения", Неопределено);
	Если СохранениеНайдено Тогда
		СтруктураДополнительныхПараметов = Новый Структура;
		СтруктураДополнительныхПараметов.Вставить("ХранилищеСохранения", ХранилищеСохранения);
		Оповещение = Новый ОписаниеОповещения("ПодтверждениеЗагрузкаСохранения_Завершение", ЭтаФорма, СтруктураДополнительныхПараметов);
		ТекстВопроса = НСтр("ru = 'Загрузить последнее сохранение?'");
		Режим = РежимДиалогаВопрос.ДаНет;
		ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
	Иначе
		// Выполняем стандартную загрузку.
	КонецЕсли;
КонецПроцедуры

