		КоличествоЗаданийВРаунде = 100;
	Иначе
		// Значение установлено.
	КонецЕсли;
	ВероятностьПовтораНеправильного = Константы.ВероятностьПовтораНеправильного.Получить();
	// Инициализация игры для режима "Восхождение"
	Если РежимВикторины = Перечисления.РежимыВикторины.Восхождение Тогда
		ИнициализироватьРежимВосхождение();
	Иначе
		// Для прочих вариантов не инициализируем.
	КонецЕсли;
	// Управление видимостью.
	УправлениеВидимостью();
