// Проверяет, достаточно ли у игрока золота, и при наличии списывает указанную сумму.
//
// Параметры:
//	Сумма - Число - количество золота для списания.
//
// Возвращаемое значение:
//	Булево - Истина, если золото успешно списано; Ложь, если недостаточно.
//
&НаКлиенте
Функция ЗаплатитьЗолото(Сумма)
	СуммаКОплате = Сумма;
	МодификаторШляпаСкупердяя = ПредопределенноеЗначение("Справочник.Модификаторы.ШляпаСкупердяя");
	Если МодификаторАктивен(МодификаторШляпаСкупердяя) И СуммаКОплате > 1 Тогда
		СуммаКОплате = СуммаКОплате - 1;
	КонецЕсли;
	ВидПараметраЗолото = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото");
	ЗолотоИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраЗолото);
	Если ЗолотоИгрока >= СуммаКОплате Тогда
		УвеличитьПараметрИгрока(ВидПараметраЗолото, -СуммаКОплате);
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции		// ЗаплатитьЗолото()

// Увеличивает количество золота у игрока на указанную сумму.
//
// Параметры:
//	Сумма - Число - количество золота для начисления.
//
&НаКлиенте
Процедура ПолучитьЗолото(Сумма)
	ВидПараметраЗолото = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото");
	УвеличитьПараметрИгрока(ВидПараметраЗолото, Сумма);
КонецПроцедуры		// ПолучитьЗолото()

// Выполняет действие карты Эхо.
// Выбирает случайную карту из стопки сброса игрока и разыгрывает её действие
// без перемещения выбранной карты из стопки сброса и без затраты энергии.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Эхо(КартаВход, ИдентифкаторКартыВход)
	Если СтопкаСброса.Количество() > 0 Тогда
		Индекс = ГсчКлиент.СлучайноеЧисло(0, СтопкаСброса.Количество() - 1);
		ВыбраннаяКартаСтрока = СтопкаСброса[Индекс];
		ВыбраннаяКарта = ВыбраннаяКартаСтрока.Карта;
		ИдентификаторВыбраннойКарты = ВыбраннаяКартаСтрока.ИдентификаторКарты;
		Если ЗначениеЗаполнено(ВыбраннаяКарта) Тогда
			Если ВыбраннаяКарта <> ПредопределенноеЗначение("Справочник.Карты.Эхо") Тогда
				ДействиеВыбраннойКарты(ВыбраннаяКарта, ИдентифкаторКартыВход);
			Иначе
				// Не разыгрываем повторно.
			КонецЕсли;
			ОтобразитьСостояниеИгрока();
			ОтобразитьСостояниеПротивника();
		КонецЕсли;
	Иначе
		// Стпока сброса пуста.
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Эхо()

// Выполняет действие карты Вдохновение.
// Игрок берёт 1 карту из стопки добора в руку.
// Если взятая карта стоит 0 - игрок берёт ещё одну карту.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Вдохновение(КартаВход, ИдентифкаторКартыВход)
	// Берём первую карту из стопки добора
	Если СтопкаДобора.Количество() > 0 Тогда
		ПерваяКарта = СтопкаДобора[0];
		ИдентификаторКарты = ПерваяКарта.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "СтопкаДобора", "РукаИгрока", ЭтаФорма);
		// Проверяем стоимость взятой карты
		Если ПерваяКарта.Карта.Стоимость = 0 Тогда
			// Если карта стоит 0 - берём ещё одну
			ДобратьКартуВРуку();
		КонецЕсли;
	Иначе
		// Стопка добора пуста.
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Вдохновение()

// Выполняет действие карты Исчезновение.
// Игрок сбрасывает все карты из руки в стопку сброса,
// затем берёт из стопки добора такое же количество карт.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Исчезновение(КартаВход, ИдентифкаторКартыВход)
	// Подсчитываем количество карт в руке
	КоличествоКартВРуке = РукаИгрока.Количество();
	Если КоличествоКартВРуке > 0 Тогда
		// Сбрасываем все карты из руки в стопку сброса
		Пока РукаИгрока.Количество() > 0 Цикл
			КартаСтрока = РукаИгрока[0];
			ИдентификаторКарты = КартаСтрока.ИдентификаторКарты;
			ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
		КонецЦикла;
		// Берём из стопки добора такое же количество карт
		ДобратьВРукуКарты(КоличествоКартВРуке);
	Иначе
		// В руке нет карт - ничего не делаем
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Исчезновение()

// Выполняет действие карты Перегонка.
// Игрок сбрасывает 1 карту (если она есть в руке) и получает 1 единицу энергии.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Перегонка(КартаВход, ИдентифкаторКартыВход)
	Если РукаИгрока.Количество() > 0 Тогда
		// Выбираем случайную карту из руки для сброса
		ИндексСлучайнойКарты = ?(РукаИгрока.Количество() = 1, 0, ГсчКлиент.СлучайноеЧисло(0, РукаИгрока.Количество() - 1));
		КартаСтрока = РукаИгрока[ИндексСлучайнойКарты];
		ИдентификаторКарты = КартаСтрока.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
		// Увеличиваем энергию игрока на 1
		ВидПараметраЭнергия = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия");
		УвеличитьПараметрИгрока(ВидПараметраЭнергия, 1);
	Иначе
		// В руке нет карт - ничего не делаем
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Перегонка()

// Выполняет действие карты Передышка.
// Даёт игроку 3 единицы щита. Если у игрока 10 единиц щита или больше, игрок берёт 1 карту.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Передышка(КартаВход, ИдентифкаторКартыВход)
	// Получаем текущее значение щита ДО увеличения
	ВидПараметраЩит = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Щит");
	ТекущийЩит = ПолучитьЗначениеПараметраИгрока(ВидПараметраЩит);
	// Даём игроку 3 единицы щита
	УвеличитьЩитИгрока(3);
	// Проверяем, было ли у игрока 10 или больше щита до увеличения
	Если ТекущийЩит >= 10 Тогда
		// Игрок берёт 1 карту из стопки добора
		ДобратьКартуВРуку();
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Передышка()

