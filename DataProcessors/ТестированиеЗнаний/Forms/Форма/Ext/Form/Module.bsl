Процедура ОткрытьСписокКарт(Команда)
	// Инициализация.
	ВидПраметраЭнергия = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия");
	// Формируем структуру параметров формы
	ПараметрыФормы = Новый Структура;
	МассивКарт = Новый Массив;
	Для Каждого ТекРукаИгрока Из РукаИгрока Цикл
		СтруктураПараметр = Новый Структура;
		СтруктураПараметр.Вставить("Карта",					 ТекРукаИгрока.Карта);
		СтруктураПараметр.Вставить("ИдентификаторКарты",	 ТекРукаИгрока.ИдентификаторКарты);
		МассивКарт.Добавить(СтруктураПараметр);
	КонецЦикла;
	ПараметрыФормы.Вставить("РукаИгрока", МассивКарт);
	Энергия = ПолучитьЗначениеПараметраИгрока(ВидПраметраЭнергия);
	ПараметрыФормы.Вставить("Энергия", Энергия);
	// Открытие формы.
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеОткрытияСпискаКарт", ЭтотОбъект);
	ОткрытьФорму("Справочник.Карты.Форма.ФормаРозыгрышаКарт", ПараметрыФормы, ЭтаФорма, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ПослеОткрытияСпискаКарт(Результат, ДополнительныеПараметры) Экспорт
	ВидПараметраЭнергия = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Энергия");
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ИдентификаторКарты	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, "ИдентификаторКарты", "");
		Энергия				 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, "Энергия", 0);
		УстановитьПараметрИгрока(ВидПараметраЭнергия, Энергия);
		РазыгратьКарту(ИдентификаторКарты);
	Иначе
		// Пользователь отказался.
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	Если Ответ = КодВозвратаДиалога.Да Тогда
		СохранитьВосхождение();
        ПодтвержденоЗакрытиеФормы = Истина;
        Закрыть();
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если Не ЗавершениеРаботы И Не ПодтвержденоЗакрытиеФормы Тогда
		Отказ = Истина;
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект),
			СтрШаблон(НСтр("ru = 'Закрыть форму и прекратить викторину?'")), 
			РежимДиалогаВопрос.ДаНет,,,"Викторина");
	Иначе
		// Разрешаем закрытие.
		// Проверка режима восхождения
		Если РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение") Тогда
			Если НЕ ЗавершениеРаботы Тогда
				СохранитьВосхождение();
			Иначе
				// Нет возможности сохранить.
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

