Процедура Подсказка(Команда)
	ТекстВопроса = СокрЛП(ПолучитьТекстВопроса(ВыбранноеЗадание));
	ТекстПодсказки = ОбщегоНазначенияКлиентСервер.ПолучитьТекстПодсказки(ТекстВопроса, СокрЛП(ПравильныйОтвет));
	ОбщегоНазначенияКлиент.ПоказатьОкноСообщения(ТекстПодсказки, "Подсказка", ЭтаФорма);
