// Возвращает размер урона, наносимого игроком.
&НаСервере
Функция ПолучитьРазмерУронаИгрока()
	Возврат 10;
КонецФункции		// ПолучитьРазмерУронаИгрока()

// Возвращает размер урона, наносимого противником.
&НаСервере
Функция ПолучитьРазмерУронаПротивника()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	РезультатФункции = 10; // Значение по умолчанию
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение урона в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РезультатФункции = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		РезультатФункции = 10;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьРазмерУронаПротивника()

// Выполняет атаку игрока по противнику.
// Уменьшает текущее здоровье противника на величину урона игрока.
// Если у противника есть щит, урон сначала поглощается щитом.
&НаСервере
Процедура АтакаИгрока()
	Урон = ПолучитьРазмерУронаИгрока();
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	ЗначениеЩита = ПолучитьЗначениеПараметраПротивника(ВидПараметраЩит);
	Если ЗначениеЩита > 0 Тогда
		Если ЗначениеЩита >= Урон Тогда
			НовоеЗначениеЩита = ЗначениеЩита - Урон;
			УстановитьПараметрПротивника(ВидПараметраЩит, НовоеЗначениеЩита);
			Урон = 0; // Щит полностью поглотил урон, дальнейшие действия не требуются.
		Иначе
			ОстатокУрона = Урон - ЗначениеЩита;
			УстановитьПараметрПротивника(ВидПараметраЩит, 0);
			Урон = ОстатокУрона;
		КонецЕсли;
	Иначе
		// Щита нет, урон наносится по здоровью (дальнейшие действия не требуются).
	КонецЕсли;
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗначение = ПолучитьЗначениеПараметраПротивника(ВидПараметра);
	НовоеЗначение = ТекущееЗначение - Урон;
	Если НовоеЗначение < 0 Тогда
		НовоеЗначение = 0;
	Иначе
		// Здоровье больше нуля, дополнительных действий не требуется.
	КонецЕсли;
	УстановитьПараметрПротивника(ВидПараметра, НовоеЗначение);
	ТекущееЗдоровьеПротивника = НовоеЗначение;
КонецПроцедуры		// АтакаИгрока()

// Проверяет, побежден ли противник (здоровье <= 0).
// Если побежден - выводит сообщение и загружает нового противника.
&НаСервере
Процедура ПроверитьПобедуНадПротивником()
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметра);
	Если ТекущееЗдоровье <= 0 Тогда
		Сообщить("Текущий противник побежден!");
		ИнициализироватьПротивника();
	Иначе
		// Противник не побежден.
	КонецЕсли;
КонецПроцедуры		// ПроверитьПобедуНадПротивником()

// Проверяет, побежден ли игрок (здоровье <= 0).
// Если побежден - выводит сообщение. Игра заканчивается.
&НаСервере
Процедура ПроверитьПоражениеИгрока()
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
	Если ТекущееЗдоровье <= 0 Тогда
		Сообщить("Игрок побежден! Игра окончена.");
		ЭтаФорма.Доступность = Ложь;
	Иначе
		// Игрок не побежден.
	КонецЕсли;
КонецПроцедуры		// ПроверитьПоражениеИгрока()

// Выполняет действия игрока после успешного ответа.
&НаСервере
Процедура ДействияИгрока()
	АтакаИгрока();
	ПроверитьПобедуНадПротивником();
	ПроверитьПоражениеИгрока();
	ОтобразитьСостояниеИгрока();
	ОтобразитьСостояниеПротивника();
КонецПроцедуры		// ДействияИгрока()

// Отображает текущее состояние противника в реквизитах формы.
&НаСервере
Процедура ОтобразитьСостояниеПротивника()
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
КонецПроцедуры		// ОтобразитьСостояниеПротивника()

// Отображает текущее состояние игрока в реквизитах формы.
&НаСервере
Процедура ОтобразитьСостояниеИгрока()
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
КонецПроцедуры		// ОтобразитьСостояниеИгрока()

// Выполняет атаку противника по игроку.
// Уменьшает текущее здоровье игрока на величину урона противника.
// Если активен модификатор "Кожаные пластины", урон уменьшается на 1.
&НаСервере
Процедура АтакаПротивника()
	НанестиУронПротивником();
КонецПроцедуры		// АтакаПротивника()

// Наносит урон игроку от противника.
// Учитывает модификатор "Кожаные пластины", который уменьшает урон на 1.
//
&НаСервере
Процедура НанестиУронПротивником()
	Урон = ПолучитьРазмерУронаПротивника();
	НанестиУронИгроку(Урон);
КонецПроцедуры		// НанестиУронПротивником()

// Наносит урон игроку.
&НаСервере
Процедура НанестиУронИгроку(УронВход)
	НовыйУрон = УронВход;
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗначение = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
	// Применяем модификатор "Кожаные пластины": уменьшаем урон на 1
	Если МодификаторАктивен(Справочники.Модификаторы.КожаныеПластины) Тогда
		НовыйУрон = Макс(0, НовыйУрон - 1);
	Иначе
		// Не требуется изменение урона.
	КонецЕсли;
	НовоеЗначение = ТекущееЗначение - НовыйУрон;
	Если НовоеЗначение < 0 Тогда
		НовоеЗначение = 0;
	Иначе
		// Значение здоровья корректно, оставляем как есть
	КонецЕсли;
	УстановитьПараметрИгрока(ВидПараметра, НовоеЗначение);
КонецПроцедуры		// НанестиУронИгроку()

// Возвращает текущее действие противника из таблицы ЦиклДействийПротивника
// по идентификатору ИдентификаторТекущегоДействияПротивника.
//
// Возвращаемое значение:
//  ПеречислениеСсылка.ВариантыДействийПротивников - ссылка на вариант действия, или пустая ссылка если не найдено.
//
&НаСервере
Функция ПолучитьТекущееДействиеПротивника()
	РезультатФункции = Перечисления.ВариантыДействийПротивников.ПустаяСсылка();
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		РезультатФункции = НайденныеСтроки[0].ДействиеЦикла;
	Иначе
		Сообщить("Действие противника с идентификатором " + ИдентификаторТекущегоДействияПротивника + " не найдено");
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТекущееДействиеПротивника()

// Перемещает действие противника вперед по циклу.
// Устанавливает идентификатор текущего действия на значение из следующей строки таблицы.
// Если достигнут конец таблицы - устанавливает значение из первой строки.
&НаСервере
Процедура ПереместитьДействиеПротивникаВпередПоЦиклу()
	Если ЦиклДействийПротивника.Количество() > 0 Тогда
		ТекущийИндекс = -1;
		Для Индекс = 0 По ЦиклДействийПротивника.Количество() - 1 Цикл
			Если ЦиклДействийПротивника[Индекс].ИдентификаторСтроки = ИдентификаторТекущегоДействияПротивника Тогда
				ТекущийИндекс = Индекс;
				Прервать;
			Иначе
				// Продолжаем поиск
			КонецЕсли;
		КонецЦикла;
		Если ТекущийИндекс >= 0 Тогда
			СледующийИндекс = ТекущийИндекс + 1;
			Если СледующийИндекс >= ЦиклДействийПротивника.Количество() Тогда
				СледующийИндекс = 0;
			Иначе
				// Индекс в пределах таблицы
			КонецЕсли;
			ИдентификаторТекущегоДействияПротивника = ЦиклДействийПротивника[СледующийИндекс].ИдентификаторСтроки;
		Иначе
			// Текущее действие не найдено, сбрасываем на первое
			ИдентификаторТекущегоДействияПротивника = ЦиклДействийПротивника[0].ИдентификаторСтроки;
		КонецЕсли;
	Иначе
		// Таблица пуста, оставляем как есть
	КонецЕсли;
КонецПроцедуры		// ПереместитьДействиеПротивникаВпередПоЦиклу()

// Выполняет действия противника после неуспешного ответа.
&НаСервере
Процедура ДействияПротивника()
	// Получение текущего действия противника
	ТекущееДействие = ПолучитьТекущееДействиеПротивника();
	// Обработка выбранного действия
	ОбработатьВыбранноеДействиеПротивника(ТекущееДействие);
	// Перемещение к следующему действию по циклу
	ПереместитьДействиеПротивникаВпередПоЦиклу();
	ПроверитьПобедуНадПротивником();
	ПроверитьПоражениеИгрока();
	ОтобразитьСостояниеИгрока();
	ОтобразитьСостояниеПротивника();
КонецПроцедуры		// ДействияПротивника()

// Обрабатывает выбранное действие противника.
//
// Параметры:
//  ВидДействияВход - ПеречислениеСсылка.ВариантыДействийПротивников - текущее действие противника.
//
&НаСервере
Процедура ОбработатьВыбранноеДействиеПротивника(ВидДействияВход)
	// Инцииализация.
	ВариантДействияАтака		 = Перечисления.ВариантыДействийПротивников.Атака;
	ВариантДействияНаложитьЩит	 = Перечисления.ВариантыДействийПротивников.НаложитьЩит;
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	// Проверка вида действия: если атака - выполнять атаку
	Если ЗначениеЗаполнено(ВидДействияВход) Тогда
		Если ВидДействияВход = ВариантДействияАтака Тогда
			АтакаПротивника();
		ИначеЕсли ВидДействияВход = ВариантДействияНаложитьЩит Тогда
			// Противник накладывает на себя щит
			ЗначениеЩита = ПолучитьЗначениеПараметраПротивника(ВидПараметраЩит);
			НовоеЗначениеЩита = ЗначениеЩита + ПолучитьЗначениеЩитаПротивника();
			УстановитьПараметрПротивника(ВидПараметраЩит, НовоеЗначениеЩита);
		Иначе
			// Другие виды действий могут быть обработаны здесь
			Сообщить("Неизвестный вид действия противника: " + Строка(ВидДействияВход));
		КонецЕсли;
	Иначе
		// Действие не найдено, выполняем атаку по умолчанию
		АтакаПротивника();
	КонецЕсли;
КонецПроцедуры		// ОбработатьВыбранноеДействиеПротивника()

// Фиксирует ответ пользователя номер НомерОтветаВход.
&НаКлиенте
Процедура ВыбратьВариантОтвета(НомерОтветаВход)
	ВероятностьПодсказки = 11;
	НовыйНомерПравильногоОтвета = ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтвета, Сборник);
	ЭтоВосхождение = (РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение"));
	ЭтоВерныйОтвет = (НомерОтветаВход = НовыйНомерПравильногоОтвета);
	НовыйОпыт = 0;
	Если ЭтоВерныйОтвет Тогда
		Если ЭтоВосхождение Тогда
			ДействияИгрока();
		Иначе
			// Не требуется действий для прочих режимов.
		КонецЕсли;	
		Если НЕ ОтветДан Тогда
			КоличествоВерных = КоличествоВерных + 1;
			СерияПравильных = СерияПравильных + 1;
			НовыйОпыт = 3;
		Иначе
			// Не увеличиваем количество верных ответов.
		КонецЕсли;
		Если ДостигнутКонецРаунда() Тогда
			Сообщить("Задано " + Строка(КоличествоЗаданных) + " вопросов. Верно отвечено: " + Строка(КоличествоВерных));
			ОтобразитьСледующееЗадание(Сборник);
		Иначе
			ОтобразитьСледующееЗадание(Сборник);
		КонецЕсли;
	Иначе      
		СтруктураПараметров = Новый Структура;
		ВыбранноеЧисло = ГсчКлиент.СлучайноеЧисло(1, 100);
		Если (ВыбранноеЧисло < ВероятностьПодсказки) Тогда
			ТекстВопроса = НСтр("ru = 'Ответ неверный. Хотите использовать подсказку?'");
			Режим = РежимДиалогаВопрос.ДаНет;
			Оповещение = Новый ОписаниеОповещения("ПодтверждениеИспользованиеПодсказкиЗавершение", ЭтаФорма, СтруктураПараметров);
			ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
		Иначе                       
			ОбработкаНеправильногоОтвета();
		КонецЕсли;
	КонецЕсли;
	ОбработатьДостиженияВыборОтвета();
	НачислитьОпыт(НовыйОпыт, ТекПользователь);
	ЗаписатьОтветВРезультаты(Сборник, ТекПользователь, ЭтоВерныйОтвет);
КонецПроцедуры		// ВыбратьВариантОтвета()

// Преобразует номер правильного ответа ИсходныйНомерПравильногоОтветаВход
// в номер ответа на командах формы, ориентируясь на сложность сборника 
// СборникВход.
&НаСервереБезКонтекста
Функция ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СборникВход)
	РезультатФункции = Обработки.ТестированиеЗнаний.ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СборникВход);
	Возврат РезультатФункции;
КонецФункции		// ПреобразоватьНомерПравильногоОтвета()

// Управляет видимостью элементов на форме.
&НаСервере
Процедура УправлениеВидимостью()
	// Количество ответов.
	СложностьСборника = Сборник.Сложность;
	Если (НЕ ЗначениеЗаполнено(СложностьСборника)) ИЛИ (СложностьСборника = Перечисления.СложностиСборников.ШестьОтветов) Тогда
		Элементы.ВыбратьВариант3.Видимость = Истина;
		Элементы.ВыбратьВариант6.Видимость = Истина;
	ИначеЕсли (СложностьСборника = Перечисления.СложностиСборников.ЧетыреОтвета) Тогда
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;	
	Иначе
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;
	КонецЕсли;	
	// Не показывать пустой вопрос.
	ПустоеЗадание = (СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "" ИЛИ СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "-");
	Элементы.ЗаданиеТекстВопросаЗадания.Видимость = НЕ ПустоеЗадание;
	Элементы.УбратьНевернуюПоловину.Доступность = НЕ НеверныеВариантыУбраны;
	// Скрывать подсказки для режима Восхождение.
	ЭтоРежимВосхождение = (РежимВикторины = Перечисления.РежимыВикторины.Восхождение);
	Элементы.ГруппаПодменюПодсказки.Видимость = НЕ (ЭтоРежимВосхождение);
	// Отображение информации об игре в режиме Восхождение.
	Элементы.ГруппаСтраницаОбИгре.Видимость = ЭтоРежимВосхождение;
	Если ЭтоРежимВосхождение Тогда
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	Иначе
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	КонецЕсли;
КонецПроцедуры		// УправлениеВидимостью()

// Возвращает текст вопроса задания ЗаданиеВход.
&НаСервереБезКонтекста
Функция ПолучитьТекстВопроса(ЗаданиеВход)
	РезультатФункции = ЗаданиеВход.ТекстВопросаЗадания;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТекстВопроса()

// Возвращает массив номеров неправильных ответов, которые необходимо
// удалить для подсказки 50/50.
&НаСервере
Функция ПолучитьМассивНеправильныхОтветовКУдалению(НомерПравильногоОтветаВход, СборникВход)
	РезультатФункции = Новый Массив;
	НовыйНомерПравильногоОтвета = ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтветаВход, СборникВход);
	ТекСложность = СборникВход.Сложность;
	Если ТекСложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
		РезультатФункции = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 6);
	ИначеЕсли ТекСложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
		ВремРезультат = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 4);
		Для Каждого ТекВремРезультат Из ВремРезультат Цикл
			НовыйНомер = ПреобразоватьНомерПравильногоОтвета(ТекВремРезультат, СборникВход);
			РезультатФункции.Добавить(НовыйНомер);
		КонецЦикла;	
	Иначе
		РезультатФункции = Новый Массив;
		ТекстСообщения = НСтр("ru = 'Неизвестный вариант сложности: %Сложность%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Сложность%", Строка(ТекСложность));
		Сообщить(ТекстСообщения);
	КонецЕсли;	
	Возврат РезультатФункции;
КонецФункции		// ПолучитьМассивНеправильныхОтветовКУдалению()

// Получает и выводит следующее задание на форму.
&НаКлиенте
Процедура ОтобразитьСледующееЗадание(СборникВход)
	НеверныеВариантыУбраны = Ложь;
	
	Элементы.ВыбратьВариант1.Доступность = Истина;
	Элементы.ВыбратьВариант2.Доступность = Истина;
	Элементы.ВыбратьВариант3.Доступность = Истина;
	Элементы.ВыбратьВариант4.Доступность = Истина;
	Элементы.ВыбратьВариант5.Доступность = Истина;
	Элементы.ВыбратьВариант6.Доступность = Истина;

	Элементы.ВыбратьВариант1.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант2.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант3.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант4.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант5.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант6.ЦветФона = Новый Цвет();

	РезультатСмены = СледующееЗадание_Сервер(СборникВход, РежимВикторины);	
	Сборник = РезультатСмены.Сборник;
	АдресКартинки = РезультатСмены.АдресКартинки;
	КоличествоЗаданных = КоличествоЗаданных + 1;
	ОтветДан = Ложь;
	ЭтаФорма.Заголовок = Строка(Сборник);
	
	ДобавитьТекущуюДатуВСтек();
КонецПроцедуры

// Блокирует команды с неверными ответами по номерам массива МассивНеверных.
&НаКлиентеНаСервереБезКонтекста
Процедура УбратьНеверныеОтветы(МассивНеверных, Форма)
	Если МассивНеверных.Найти(1) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант1.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(2) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант2.Доступность = Ложь;
	КонецЕсли;
