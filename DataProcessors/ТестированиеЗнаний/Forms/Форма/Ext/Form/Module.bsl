// Возвращает значение щита, которое противник накладывает на себя.
// Использует значения МинимальнаяСила и МаксимальнаяСила из таблицы ЦиклДействийПротивника
// для текущего действия противника.
//
// Возвращаемое значение:
//  Число - случайное значение щита в диапазоне от МинимальнаяСила до МаксимальнаяСила.
//
&НаСервере
Функция ПолучитьЗначениеЩитаПротивника()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	РезультатФункции = 15; // Значение по умолчанию
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение щита в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РезультатФункции = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		РезультатФункции = 15;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьЗначениеЩитаПротивника()

// Устанавливает значение параметра противника в таблице ПараметрыПротивника по виду параметра.
