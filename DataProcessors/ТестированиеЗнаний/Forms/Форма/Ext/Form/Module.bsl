// Возвращает начальное значение здоровья игрока по умолчанию.
//
&НаСервере
Функция НачальноеЗдоровьеИгрокаПоУмолчанию()
	Возврат 30;
КонецФункции

// Получает значение параметра игрока из таблицы ПараметрыИгрока по виду параметра.
//
// Параметры:
//  ВидПараметраВход - ПеречислениеСсылка.ВидыПараметровИгроков - вид параметра для поиска.
//
// Возвращаемое значение:
//  Число - значение параметра игрока, или 0 если параметр не найден.
//
&НаСервере
Функция ПолучитьЗначениеПараметраИгрока(ВидПараметраВход)
	РезультатФункции = 0;
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ВидПараметра", ВидПараметраВход);
	НайденныеСтроки = ПараметрыИгрока.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		РезультатФункции = НайденныеСтроки[0].ЗначениеПараметра;
	Иначе
		РезультатФункции = 0;
		Сообщить("Параметр игрока " + Строка(ВидПараметраВход) + " не найден");
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьЗначениеПараметраИгрока()

// Устанавливает значение параметра игрока в таблице ПараметрыИгрока по виду параметра.
//
// Параметры:
//  ВидПараметраВход - ПеречислениеСсылка.ВидыПараметровИгроков - вид параметра для поиска.
//  ЗначениеПараметраВход - Число - значение параметра для установки.
//
&НаСервере
Процедура УстановитьПараметрИгрока(ВидПараметраВход, ЗначениеПараметраВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ВидПараметра", ВидПараметраВход);
	НайденныеСтроки = ПараметрыИгрока.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		НайденныеСтроки[0].ЗначениеПараметра = ЗначениеПараметраВход;
	Иначе
		НоваяСтрока = ПараметрыИгрока.Добавить();
		НоваяСтрока.ВидПараметра = ВидПараметраВход;
		НоваяСтрока.ЗначениеПараметра = ЗначениеПараметраВход;
	КонецЕсли;
КонецПроцедуры		// УстановитьПараметрИгрока()

// Устанавливает значение параметра противника в таблице ПараметрыПротивника по виду параметра.
//
// Параметры:
//  ВидПараметраВход - ПеречислениеСсылка.ВидыПараметровИгроков - вид параметра для поиска.
//  ЗначениеПараметраВход - Число - значение параметра для установки.
//
&НаСервере
Процедура УстановитьПараметрПротивника(ВидПараметраВход, ЗначениеПараметраВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ВидПараметра", ВидПараметраВход);
	НайденныеСтроки = ПараметрыПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		НайденныеСтроки[0].ЗначениеПараметра = ЗначениеПараметраВход;
	Иначе
		НоваяСтрока = ПараметрыПротивника.Добавить();
		НоваяСтрока.ВидПараметра = ВидПараметраВход;
		НоваяСтрока.ЗначениеПараметра = ЗначениеПараметраВход;
	КонецЕсли;
КонецПроцедуры		// УстановитьПараметрПротивника()

// Осуществляет инициализацию игрока.
&НаСервере
Процедура ИнициализироватьИгрока()
	// Инициализация параметров игрока
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ЗначениеЗдоровья = НачальноеЗдоровьеИгрокаПоУмолчанию();
	УстановитьПараметрИгрока(ВидПараметраТекущееЗдоровье, ЗначениеЗдоровья);
	УстановитьПараметрИгрока(ВидПараметраМаксимальноеЗдоровье, ЗначениеЗдоровья);
	// Считывание текущего здоровья из таблицы параметров и размещение в реквизит формы
	ТекущееЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
КонецПроцедуры		// ИнициализироватьИгрока()

// Осуществляет инициализацию противника.
&НаСервере
Процедура ИнициализироватьПротивника()
	ЗагрузитьПротивника();
	// Инициализация параметров противника
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ЗначениеЗдоровья = НачальноеЗдоровьеИгрокаПоУмолчанию();
	УстановитьПараметрПротивника(ВидПараметраТекущееЗдоровье, ЗначениеЗдоровья);
	УстановитьПараметрПротивника(ВидПараметраМаксимальноеЗдоровье, ЗначениеЗдоровья);
КонецПроцедуры		// ИнициализироватьПротивника()

// Осуществляет инициализацию нового восхождения.
&НаСервере
Процедура ИнициализироватьРежимВосхождение()
	НовоеМаксимальноеЗдорорвьеИгрока = 100;
	ЗагрузитьМодификаторыПоУмолчанию();
	// Инициализация игрока
	ИнициализироватьИгрока();
	// Инициализация противника
	ИнициализироватьПротивника();
КонецПроцедуры		// ИнициализироватьРежимВосхождение()

// Отображает на форме задание и запоминает правильный ответ.
&НаСервере
Процедура ЗагрузитьЗадание(ЗаданиеВход)
	// Отображение текста вопроса.
	ВыбранноеЗадание = ЗаданиеВход;
	ЕстьПовторяющиеся = Истина;
	Счетчик = 0;
	Пока (ЕстьПовторяющиеся) И (Счетчик < 100) Цикл
		СтруктураВариантовОтветов = ПолучитьВариантыОтветов(ЗаданиеВход);	
		МассивОтветов = СтруктураВариантовОтветов.МассивОтветов;
		ЕстьПовторяющиеся = Обработки.ТестированиеЗнаний.ОпределитьПовторяющиесяОтветы(МассивОтветов);
		Счетчик = Счетчик + 1;
	КонецЦикла;
	Если МассивОтветов.Количество() > 0 Тогда
		НомерПравильногоОтвета = СтруктураВариантовОтветов.НомерПравильного;
		ТекСложность = Сборник.Сложность;
		Если НЕ ЗначениеЗаполнено(ТекСложность) Тогда
			ТекСложность = Перечисления.СложностиСборников.ШестьОтветов;
		Иначе
			// Сложность указана. Не изменяем.
		КонецЕсли;	
		Если ТекСложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
			ЗагрузитьОтветВЭлемент(МассивОтветов, 5, Элементы.ВыбратьВариант6);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 2, Элементы.ВыбратьВариант3);	
			ЗагрузитьОтветВЭлемент(МассивОтветов, 4, Элементы.ВыбратьВариант5);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 3, Элементы.ВыбратьВариант4);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 1, Элементы.ВыбратьВариант2);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 0, Элементы.ВыбратьВариант1);
		ИначеЕсли Сборник.Сложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
			ЗагрузитьОтветВЭлемент(МассивОтветов, 3, Элементы.ВыбратьВариант5);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 2, Элементы.ВыбратьВариант4);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 1, Элементы.ВыбратьВариант2);
			ЗагрузитьОтветВЭлемент(МассивОтветов, 0, Элементы.ВыбратьВариант1);
		Иначе
			// Неизвестный вариант. Пропускаем.
		КонецЕсли;
		ПравильныйОтвет = МассивОтветов[НомерПравильногоОтвета-1];
		ПрименитьМодификаторыПриСобытии(ПредставлениеСобытияФормы_ПриЗагрузкеЗадания());
	Иначе
		Сообщить("Не удалось загрузить ответы");
	КонецЕсли;
КонецПроцедуры

