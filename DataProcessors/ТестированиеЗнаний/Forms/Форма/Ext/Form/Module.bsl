&НаСервере
Перем Гсч;		// Генератор случайных чисел.

&НаКлиенте
Перем ГсчКлиент;

// Помещает картинку задания ЗаданиеВход во временное хранилище и 
// возвращает его адрес.
&НаСервере
Функция ВернутьАдресКартинки(ЗаданиеВход)
	РезультатФункции = "";
	КартинкаХранилище = ЗаданиеВход.КартинкаЗадания;
	КартинкаЗначение = КартинкаХранилище.Получить();
	Если КартинкаЗначение <> Неопределено Тогда
		РезультатФункции = ПоместитьВоВременноеХранилище(КартинкаЗначение, ЭтаФорма);
	Иначе
		Сборник = ЗаданиеВход.Владелец;
		КартинкаХранилище = Сборник.КартинкаСборника;
		КартинкаЗначение = КартинкаХранилище.Получить();
		Если КартинкаЗначение <> Неопределено Тогда
			РезультатФункции = ПоместитьВоВременноеХранилище(КартинкаЗначение, ЭтаФорма);
		Иначе
			// Картинка не задана. Не загружаем.
		КонецЕсли;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ВернутьАдресКартинки()

// Возвращает структуру данных для задания ЗаданиеВход.
&НаСервере
Функция ПолучитьВариантыОтветов(ЗаданиеВход)
	// Инициализация.
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("НомерПравильного", 0);
	РезультатФункции.Вставить("МассивОтветов", Новый Массив);
	ВыгрузкаОтветов = ЗаданиеВход.ОтветыЗаданий.Выгрузить();
	КоличествоОтветов = 6;
	Если Сборник.Сложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
		КоличествоОтветов = 6;
	ИначеЕсли Сборник.Сложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
		КоличествоОтветов = 4;
	Иначе
		КоличествоОтветов = 6;
	КонецЕсли;
	// Поиск правильного ответа.
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Правильность", Истина);
	НайденныеСтроки = ВыгрузкаОтветов.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() = 1 Тогда
		ПравильныйОтветСтрока = НайденныеСтроки[0];
		ПравильныйОтветТекст = ПравильныйОтветСтрока.ТекстОтвета;
		// Добавление неправильных ответов.
		МассивНеправильных = Новый Массив;
		ТекСборник = ЗаданиеВход.Владелец;
		Если ТекСборник.БратьОтветыИзТекущегоСборника Тогда
			// Ответы берутся только из текущего вопроса.
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаданияОтветыЗаданий.ТекстОтвета,
			|	ЗаданияОтветыЗаданий.Правильность
			|ИЗ
			|	Справочник.Задания.ОтветыЗаданий КАК ЗаданияОтветыЗаданий
			|ГДЕ
			|	ЗаданияОтветыЗаданий.Ссылка = &Ссылка
			|	И НЕ ЗаданияОтветыЗаданий.Ссылка.ПометкаУдаления
			|	И НЕ ЗаданияОтветыЗаданий.Правильность";
			Запрос.УстановитьПараметр("Ссылка", ЗаданиеВход);
			РезультатЗапроса = Запрос.Выполнить();
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				МассивНеправильных.Добавить(ВыборкаДетальныеЗаписи.ТекстОтвета);
			КонецЦикла;
		Иначе
			// Ответы берутся из всех вопросов.
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЗаданияОтветыЗаданий.ТекстОтвета
			|ИЗ
			|	Справочник.Задания.ОтветыЗаданий КАК ЗаданияОтветыЗаданий
			|ГДЕ
			|	ЗаданияОтветыЗаданий.ТекстОтвета <> &ТекстОтвета
			|	И НЕ ЗаданияОтветыЗаданий.Ссылка.ПометкаУдаления
			|	И ЗаданияОтветыЗаданий.Ссылка.Владелец = &Владелец";
			Запрос.УстановитьПараметр("Владелец", ЗаданиеВход.Владелец);
			Запрос.УстановитьПараметр("ТекстОтвета", ПравильныйОтветТекст);
			РезультатЗапроса = Запрос.Выполнить();
			ВыгрузкаНеправильных = РезультатЗапроса.Выгрузить();
			МассивВыгрузка = ВыгрузкаНеправильных.ВыгрузитьКолонку("ТекстОтвета");
			ВсегоНеправильных = МассивВыгрузка.Количество();
			ВерхняяГраница = 1;
			Если МассивВыгрузка.Количество() >= (КоличествоОтветов - 1) Тогда
				ВерхняяГраница = (КоличествоОтветов - 1);
			Иначе
				ВерхняяГраница = МассивВыгрузка.Количество();
			КонецЕсли;
			Для Счетчик = 1 По ВерхняяГраница Цикл
				НомерОтвета = Гсч.СлучайноеЧисло(0, ВсегоНеправильных-1);
				МассивНеправильных.Добавить(МассивВыгрузка[НомерОтвета]);
			КонецЦикла;
		КонецЕсли;
		МассивНеправильных.Добавить(ПравильныйОтветТекст);
		// Перемешивание итогового массива и формирование результата.
		МассивНеправильных = ОбщегоНазначенияКлиентСервер.СмешатьМассив(МассивНеправильных, Гсч);
		ПравильныйОтветНомер = МассивНеправильных.Найти(ПравильныйОтветТекст);
		Если ПравильныйОтветНомер <> Неопределено Тогда
			РезультатФункции.Вставить("НомерПравильного", ПравильныйОтветНомер + 1);
			РезультатФункции.Вставить("МассивОтветов", МассивНеправильных);
		Иначе
			РезультатФункции.Вставить("НомерПравильного", 0);
			РезультатФункции.Вставить("МассивОтветов", Новый Массив);
		КонецЕсли;
	Иначе
		// Не удалось однозначно определить правильный ответ.
		РезультатФункции.Вставить("НомерПравильного", 0);
		РезультатФункции.Вставить("МассивОтветов", Новый Массив);
	КонецЕсли;
	// Вывод результата.
	Возврат РезультатФункции;
КонецФункции		// ПолучитьВариантыОтветов()

// загружает в элемент на форме ЭлементВход ответ номер НомерОтветаВход из масива МассивОтветовВход.
//
// Параметры:
//	МассивОтветовВход - Массив - Массив, содержащий ответы на текущее задание.
//	НомерОтветаВход - Число - Номер текущего ответа.
//	ЭлементВход - ЭлементФормы - Элемент, куда будет загружен ответ.
//
&НаСервере
Процедура ЗагрузитьОтветВЭлемент(МассивОтветовВход, НомерОтветаВход, ЭлементВход)
	НовыйОтвет = "";
	ЗаголовокЭлемента = "";
	Если МассивОтветовВход.Количество() > НомерОтветаВход Тогда
		НовыйОтвет = СокрЛП(МассивОтветовВход[НомерОтветаВход]);
		ЗаголовокЭлемента = Строка(НомерОтветаВход + 1) + ": " + НовыйОтвет;
	Иначе
		НовыйОтвет = "---";
		ЗаголовокЭлемента = "---";
	КонецЕсли;
	ЭлементВход.Заголовок = ЗаголовокЭлемента;
	НоваяСтрока = НомераОтветов.Добавить();
	НоваяСтрока.НомерОтвета = НомерОтветаВход + 1;
	НоваяСтрока.ТекстОтвета = НовыйОтвет;
КонецПроцедуры

// Возвращает текстовое представление события формы При загрузке задания.
&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеСобытияФормы_ПриЗагрузкеЗадания()
	Возврат "СобытиеФормы_ПриЗагрузкеЗадания";
КонецФункции		 // ПредставлениеСобытияФормы_ПриЗагрузкеЗадания()

#Область ВыборВидаЭтапа

// Обработка этапа "Отдых".
// Восстанавливает игроку 30% от максимального здоровья, но не больше максимального.
//
&НаСервере
Процедура Отдых()
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	МаксимальноеЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
	Восстановление = Цел(МаксимальноеЗдоровье * 0.3);
	ВосстановитьЗдоровьеИгрока(Восстановление);
КонецПроцедуры		// Отдых()

// Обработка этапа "Сокровище".
// Игрок получает случайный положительный модификатор, которого у него ещё нет.
//
// Возвращаемое значение:
//  СправочникСсылка.Модификаторы - ссылка на добавленный модификатор или пустая ссылка.
//
&НаСервере
Функция ОбработатьЭтапСокровище()
Результат = Справочники.Модификаторы.ПустаяСсылка;
// Формируем массив текущих модификаторов игрока для исключения
ИсключаемыеМодификаторы = Новый Массив;
Для Каждого СтрокаМодификатора Из Модификаторы Цикл
ИсключаемыеМодификаторы.Добавить(СтрокаМодификатора.Модификатор);
КонецЦикла;
// Получаем случайный положительный модификатор, исключая имеющиеся
НовыйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Истина, Гсч, ИсключаемыеМодификаторы);
Если ЗначениеЗаполнено(НовыйМодификатор) Тогда
// Добавляем новый модификатор в таблицу модификаторов игрока
НоваяСтрока = Модификаторы.Добавить();
НоваяСтрока.Модификатор = НовыйМодификатор;
НоваяСтрока.ЕстьДлительность = Ложь;
НоваяСтрока.ОставшаясяДлительность = 0;
Результат = НовыйМодификатор;
Иначе
// Не удалось найти подходящий модификатор (возможно все уже получены)
КонецЕсли;
Возврат Результат;
КонецФункции// ОбработатьЭтапСокровище()

&НаКлиенте
Процедура ВыборЭтапа_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		// Вызываем метод для обработки выбранного вида этапа
		ОбработатьВыбранныйВидЭтапа(ВыбранноеЗначение);
	Иначе
		// Форма выбора этапа закрыта без выбора. Загружаем случайного противника.
		ИнициализироватьПротивника();
	КонецЕсли;
КонецПроцедуры		// ВыборЭтапа_Завершение()

&НаКлиенте
Процедура ОткрытьТорговца_ПослеЗакрытия(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	ВидПараметраЗолото = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото");
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		// Обработка структуры закрытия формы торговца
		Если ВыбранноеЗначение.Свойство("Золото") Тогда
			Золото = ВыбранноеЗначение.Золото;
			УстановитьПараметрИгрока(ВидПараметраЗолото, Золото);
		Иначе
			// Нет параметра Золото. Не изменяем текущее золото.
		КонецЕсли;
		// Обработка купленных модификаторов
		Если ВыбранноеЗначение.Свойство("КупленныеМодификаторы") Тогда
			СписокКупленныхМодификаторов = ВыбранноеЗначение.КупленныеМодификаторы;
			Для Каждого ТекСписокКупленныхМодификаторов Из СписокКупленныхМодификаторов Цикл
				// Проверяем, есть ли уже такой модификатор в таблице
				ТекМодификатор = ТекСписокКупленныхМодификаторов.Значение;
				СтруктураПоиска = Новый Структура;
				СтруктураПоиска.Вставить("Модификатор", ТекМодификатор);
				НайденныеСтроки = Модификаторы.НайтиСтроки(СтруктураПоиска);
				Если НайденныеСтроки.Количество() = 0 Тогда
					// Добавляем новый модификатор в таблицу
					НоваяСтрока = Модификаторы.Добавить();
					НоваяСтрока.Модификатор				 = ТекМодификатор;
					НоваяСтрока.ЕстьДлительность		 = Ложь;
					НоваяСтрока.ОставшаясяДлительность	 = 0;
				Иначе
					// У игрока уже есть такой модификатор.
				КонецЕсли;
			КонецЦикла;
		Иначе
			// Нет купленных модификаторов.
		КонецЕсли;
	Иначе
		ВыбратьСледующийЭтап();
	КонецЕсли;
КонецПроцедуры		// ОткрытьТорговца_ПослеЗакрытия()

// Обрабатывает выбранный вид этапа из структуры результата формы выбора этапа.
//
// Параметры:
//  ВыбранноеЗначение - Структура - структура с данными выбранного этапа
//                      (ВидЭтапа, Противник).
//
&НаКлиенте
Процедура ОбработатьВыбранныйВидЭтапа(ВыбранноеЗначение)
	НомерЭтапа	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "НомерЭтапа", 0);
	ВидЭтапа	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "ВидЭтапа", Неопределено);
	ВидПараметраЗолото = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото");
	// Проверка на завершение восхождения.
	Если ПройденПоследнийЭтап() Тогда
		ЗавершитьВосхождение();
	Иначе	
		Если ВидЭтапа = ПредопределенноеЗначение("Перечисление.ВидыЭтаповВосхождения.Противник") Тогда
			// Обработка этапа "Противник"
			ПустойПротивник = ПредопределенноеЗначение("Справочник.Противники.ПустаяСсылка");
			ВыбранныйПротивник = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Противник", ПустойПротивник);
			// Инициализируем стопки.
			СтопкаДобора.Очистить();
			РукаИгрока.Очистить();
			СтопкаСброса.Очистить();
			// Инициализация колоды игрока
			ИнициализироватьКолодуИгрока();
			ИнициализироватьСтопкуДобораИгрока();
			// Доберём руку.
			ДобратьРуку();
			// Инициализируем энергию игрока.
			ИнициализироватьЭнергиюИгрока();
			// Устанавливаем выбранного противника и инициализируем его.
			ИнициализироватьПротивника(ВыбранныйПротивник);
			// Отобразим задание из выбранного сборника.
			Если ЗначениеЗаполнено(Сборник) Тогда
				ОтобразитьСледующееЗадание(Сборник);
			Иначе
				// Сборник не выбран.
			КонецЕсли;		
		ИначеЕсли ВидЭтапа = ПредопределенноеЗначение("Перечисление.ВидыЭтаповВосхождения.Отдых") Тогда
			// Обработка этапа "Отдых"
			Отдых();
			// После отдыха снова вызываем выбор этапа
			ВыбратьСледующийЭтап();
		ИначеЕсли ВидЭтапа = ПредопределенноеЗначение("Перечисление.ВидыЭтаповВосхождения.Сокровище") Тогда
			// Обработка этапа "Сокровище"
			ПолученныйМодификатор = ОбработатьЭтапСокровище();
			// Открываем форму получения модификатора с параметром полученного модификатора
			ОткрытьФорму("Справочник.Модификаторы.Форма.ФормаПолученияМодификатора", 
			             Новый Структура("Модификатор", ПолученныйМодификатор), ЭтаФорма);
			// После получения сокровища снова вызываем выбор этапа
			ВыбратьСледующийЭтап();
		ИначеЕсли ВидЭтапа = ПредопределенноеЗначение("Перечисление.ВидыЭтаповВосхождения.Торговец") Тогда
			// Обработка этапа "Торговец"
			ОбработатьЭтапТорговец();
		Иначе
			// Неизвестный вид этапа. Загружаем случайного противника.
			ИнициализироватьПротивника();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры		// ОбработатьВыбранныйВидЭтапа()

// Обрабатывает этап "Торговец".
// Открывает форму торговца с передачей текущего золота и модификаторов игрока.
//
&НаКлиенте
Процедура ОбработатьЭтапТорговец()
	ВидПараметраЗолото = ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.Золото");
	ТекущееЗолото = ПолучитьЗначениеПараметраИгрока(ВидПараметраЗолото);
	// Получаем текущие модификаторы игрока в виде массива
	МассивМодификаторов = Новый Массив;
	Для Каждого СтрокаМодификатора Из Модификаторы Цикл
		МассивМодификаторов.Добавить(СтрокаМодификатора.Модификатор);
	КонецЦикла;
	ПараметрыФормыТорговца = Новый Структура;
	ПараметрыФормыТорговца.Вставить("Золото", ТекущееЗолото);
	ПараметрыФормыТорговца.Вставить("Модификаторы", МассивМодификаторов);
	ОписаниеОЗакрытииТорговца = Новый ОписаниеОповещения("ОткрытьТорговца_ПослеЗакрытия", ЭтотОбъект);
	ОткрытьФорму("Обработка.ТестированиеЗнаний.Форма.ФормаТорговца", ПараметрыФормыТорговца, ЭтаФорма, , , , ОписаниеОЗакрытииТорговца, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры		// ОбработатьЭтапТорговец()

// Вызывает форму выбора следующего этапа.
//
&НаКлиенте
Процедура ВыбратьСледующийЭтап()
	ПараметрыФормыВыбораЭтапа = Новый Структура;
	ПараметрыФормыВыбораЭтапа.Вставить("НомерЭтапа",			 НомерЭтапа);
	ПараметрыФормыВыбораЭтапа.Вставить("ВсегоЭтапов",			 ВсегоЭтапов);
	ПараметрыФормыВыбораЭтапа.Вставить("ПредыдущийПротивник",	 Противник);
	ПараметрыФормыВыбораЭтапа.Вставить("ПредыдущийВидЭтапа",	 ВидЭтапа);
	ОписаниеОЗакрытии = Новый ОписаниеОповещения("ВыборЭтапа_Завершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.ТестированиеЗнаний.Форма.ФормаВыбораЭтапа", ПараметрыФормыВыбораЭтапа, ЭтаФорма, , , , ОписаниеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры		// ВыбратьСледующийЭтап()

#КонецОбласти

#Область Модификаторы

// Возвращает признак активности модификатора МодификаторВход в таблице Модификаторы.
//
// Параметры:
//  МодификаторВход - СправочникСсылка.Модификаторы - модификатор для проверки.
//
// Возвращаемое значение:
//  Булево - Истина, если модификатор активен, Ложь в противном случае.
//
&НаСервере
Функция МодификаторАктивен(МодификаторВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Модификатор", МодификаторВход);
	НайденныеСтроки = Модификаторы.НайтиСтроки(СтруктураПоиска);
	Возврат НайденныеСтроки.Количество() > 0;
КонецФункции		// МодификаторАктивен()

// Увеличивает параметр Щит игрока на величину УвеличениеЩитаВход единиц.
// Учитывает модификатор "Латный наплечник", который увеличивает получаемый щит на 1.
//
&НаСервере
Процедура УвеличитьЩитИгрока(УвеличениеЩитаВход)
	// Применяем модификатор "Латный наплечник": увеличение щита на 1
	НовоеУвеличениеЩита = УвеличениеЩитаВход;
	Если МодификаторАктивен(Справочники.Модификаторы.ЛатныйНаплечник) Тогда
		НовоеУвеличениеЩита = НовоеУвеличениеЩита + 1;
	Иначе
		// Оставляем величину изменения щита прежним.
	КонецЕсли;
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	УвеличитьПараметрИгрока(ВидПараметраЩит, НовоеУвеличениеЩита);
КонецПроцедуры		// УвличитьЩитИгрока()

// Осуществляет применение модификатора Интуиция.
//
&НаСервере
Процедура ПрименитьМодификатор_Интуиция()
	МассивНеверных = Новый Массив;
	ЗначениеНайдено = Ложь;
	ВсегоОтветов = 6;
	Пока НЕ ЗначениеНайдено Цикл
		НомерОтвета = Гсч.СлучайноеЧисло(0, ВсегоОтветов - 1);
		Если НомерОтвета <> НомерПравильногоОтвета Тогда
			МассивНеверных.Добавить(НомерОтвета);
			ЗначениеНайдено = Истина;
		Иначе
			// Выполняем поиск далее.
		КонецЕсли;
	КонецЦикла;
	УбратьНеверныеОтветы(МассивНеверных, ЭтаФорма);
	НеверныеВариантыУбраны = Истина;
	УправлениеВидимостью();
КонецПроцедуры		// ПрименитьМодификатор_Интуиция()

// Осуществляет применение модификатора Перекус.
// Восстанавливает 3 очка здоровья игрока, но не более максимального здоровья.
//
&НаСервере
Процедура ПрименитьМодификатор_Перекус()
	ВосстановитьЗдоровьеИгрока(3);
КонецПроцедуры		// ПрименитьМодификатор_Перекус()

// Восстанавливает здоровье игрока на указанное значение, но не более максимального здоровья.
// Учитывает модификатор "Кровь гидры", который увеличивает восстановление на 30%.
//
// Параметры:
//  КоличествоВосстановления - Число - количество очков здоровья для восстановления.
//
&НаСервере
Процедура ВосстановитьЗдоровьеИгрока(КоличествоВосстановления)
	// Копируем входное значение в новую переменную для модификации
	ФактическоеВосстановление = КоличествоВосстановления;
	// Применяем модификатор "Кровь гидры": увеличение восстановления на 30%
	Если МодификаторАктивен(Справочники.Модификаторы.КровьГидры) Тогда
		ФактическоеВосстановление = ФактическоеВосстановление * 1.3;
		// Округляем до целых
		ФактическоеВосстановление = Цел(ФактическоеВосстановление);
	Иначе
		ФактическоеВосстановление = Цел(ФактическоеВосстановление);
	КонецЕсли;
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
	НовоеЗдоровье = Мин(ТекущееЗдоровье + ФактическоеВосстановление, МаксимальноеЗдоровье);
	УстановитьПараметрИгрока(ВидПараметраТекущееЗдоровье, НовоеЗдоровье);
	ТекущееЗдоровьеИгрока = НовоеЗдоровье;
КонецПроцедуры		// ВосстановитьЗдоровьеИгрока()

// Осуществляет применение модификатора Кожаные пластины.
// Уменьшает урон от противника на 1.
//
&НаСервере
Процедура ПрименитьМодификатор_КожаныеПластины()
	// Модификатор применяется пассивно при получении урона.
	// Проверка активности выполняется через функцию МодификаторАктивен в процедуре АтакаПротивника.
КонецПроцедуры		// ПрименитьМодификатор_КожаныеПластины()

// Осуществляет применение модификатора Кольчуга.
// Поглощает 25% от входящего урона игроку от противника.
//
&НаСервере
Процедура ПрименитьМодификатор_Кольчуга()
	// Модификатор применяется пассивно при получении урона.
	// Проверка активности выполняется через функцию МодификаторАктивен в процедуре НанестиУронИгроку.
КонецПроцедуры		// ПрименитьМодификатор_Кольчуга()

// Осуществляет применение модификатора Подсечка.
// Уменьшает максимальное здоровье противника на 10%.
//
&НаСервере
Процедура ПрименитьМодификатор_Подсечка()
	// Модификатор применяется пассивно при загрузке противника.
	// Проверка активности выполняется в процедуре ИнициализироватьПротивника.
КонецПроцедуры		// ПрименитьМодификатор_Подсечка()

// Осуществляет применение модификатора Туман.
// При поражении игрока (здоровье <= 0) игрок воскресает с 50% здоровья,
// после чего модификатор Туман удаляется из таблицы модификаторов.
// Действует только 1 раз.
//
&НаСервере
Процедура ПрименитьМодификатор_Туман()
	// Модификатор применяется пассивно при получении урона.
	// Проверка активности и обработка воскресения выполняется в процедуре ПроверитьПоражениеИгрока.
КонецПроцедуры		// ПрименитьМодификатор_Туман()

// Осуществляет применение модификатора ЛетучаяМышь.
// При нанесении урона игроком, игрок излечивает себе здоровье в размере 5% от нанесенного урона.
//
&НаСервере
Процедура ПрименитьМодификатор_ЛетучаяМышь(УронВход)
	// Рассчитываем восстановление здоровья: 10% от нанесенного урона
	Восстановление = УронВход * 0.10;
	Если Восстановление > 0 Тогда
		ВосстановитьЗдоровьеИгрока(Восстановление);
	Иначе
		// Нет очков восстановления. Ничего не делаем.
	КонецЕсли;
КонецПроцедуры		// ПрименитьМодификатор_ЛетучаяМышь()

// Осуществляет применение модификатора ВолчийКлык.
// При правильном ответе увеличивает параметр Ярость на 1.
// При неправильном ответе устанавливает Ярость в 0.
//
&НаСервере
Процедура ПрименитьМодификатор_ВолчийКлык(ЭтоВерныйОтвет)
	ВидПараметраЯрость = Перечисления.ВидыПараметровИгроков.Ярость;
	Если ЭтоВерныйОтвет Тогда
		УвеличитьПараметрИгрока(ВидПараметраЯрость, 1);
	Иначе
		УстановитьПараметрИгрока(ВидПараметраЯрость, 0);
	КонецЕсли;
КонецПроцедуры		// ПрименитьМодификатор_ВолчийКлык()

// Осуществляет применение модификатора ЦепкийКрюк.
// При нанесении урона игроком по щиту противника, игроку увеличивается параметр Щит в размере 20% от нанесенного урона по щиту.
//
// Параметры:
//  УронПоЩитуВход - Число - урон, нанесенный по щиту противника.
//
&НаСервере
Процедура ПрименитьМодификатор_ЦепкийКрюк(УронПоЩитуВход)
	// Рассчитываем увеличение щита: 20% от урона по щиту противника
	УвеличениеЩита = Цел(УронПоЩитуВход * 0.20);
	Если УвеличениеЩита > 0 Тогда
		УвеличитьЩитИгрока(УвеличениеЩита);
	Иначе
		// Нет очков увеличения щита. Ничего не делаем.
	КонецЕсли;
КонецПроцедуры		// ПрименитьМодификатор_ЦепкийКрюк()

// Осуществляет применение модификатора МодификаторВход.
// 
// Параметры:
//	МодификаторВход - СправочникСсылка.Модификаторы - модификатор для применения.
//	ЕстьДлительностьВход - Булево - признак наличия длительности.
//	ОставшаясяДлительностьВход - Число - оставшаяся длительность.
//
&НаСервере
Процедура ПрименитьВыбранныйМодификатор(МодификаторВход, ЕстьДлительностьВход, ОставшаясяДлительностьВход)
	Если МодификаторВход = Справочники.Модификаторы.Интуиция Тогда
		ПрименитьМодификатор_Интуиция();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.Перекус Тогда
		ПрименитьМодификатор_Перекус();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.КожаныеПластины Тогда
		ПрименитьМодификатор_КожаныеПластины();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.Кольчуга Тогда
		ПрименитьМодификатор_Кольчуга();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.Подсечка Тогда
		ПрименитьМодификатор_Подсечка();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.Туман Тогда
		ПрименитьМодификатор_Туман();
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.ЛетучаяМышь Тогда
		// Модификатор ЛетучаяМышь применяется при атаке игрока с передачей урона
		// Вызов осуществляется напрямую из процедуры АтакаИгрока
	ИначеЕсли МодификаторВход = Справочники.Модификаторы.ЦепкийКрюк Тогда
		// Модификатор ЦепкийКрюк применяется при атаке игрока по щиту противника
		// Вызов осуществляется напрямую из процедуры АтакаИгрока
	Иначе
		Сообщить("Неизвестный модификатор: " + МодификаторВход);
		// Неизвестный модификатор.
	КонецЕсли;	
КонецПроцедуры		// ПрименитьВыбранныйМодификатор()

// Применяет модификатор МодификаторВход, если он присутствует в таблице Модификаторы.
// 
// Параметры:
//	МодификаторВход - СправочникСсылка.Модификаторы - модификатор для применения.
//
&НаСервере
Процедура ПрименитьМодификаторПриНаличии(МодификаторВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Модификатор", МодификаторВход);
	НайденныеСтроки = Модификаторы.НайтиСтроки(СтруктураПоиска);
	Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
		ТекЕстьДлительность			 = ТекНайденныеСтроки.ЕстьДлительность;
		ТекОставшаясяДлительность	 = ТекНайденныеСтроки.ОставшаясяДлительность;
		ПрименитьВыбранныйМодификатор(МодификаторВход, ТекЕстьДлительность, ТекОставшаясяДлительность);		
	КонецЦикла;	
КонецПроцедуры		// ПрименитьМодификаторПриНаличии()

// Применяет модификаторы для наступившего события СобытиеВход.
//
// Параметры:
//	СобытиеВход - Строка - имя события.
//
&НаСервере
Процедура ПрименитьМодификаторыПриСобытии(СобытиеВход)
	ЭтоРежимВосхождение = (РежимВикторины = Перечисления.РежимыВикторины.Восхождение);
	Если ЭтоРежимВосхождение Тогда
		Если СобытиеВход = ПредставлениеСобытияФормы_ПриЗагрузкеЗадания() Тогда
			ПрименитьМодификаторПриНаличии(Справочники.Модификаторы.Интуиция);
			ПрименитьМодификаторПриНаличии(Справочники.Модификаторы.Перекус);
		Иначе	
			// Неизвестное событие. ничего не делаем.
		КонецЕсли;
	Иначе
		// Не используем модификаторы для других режимов викторины.
	КонецЕсли;
КонецПроцедуры		 // ПрименитьМодификаторы()

// Возвращает признак наличия проклятия у игрока.
// Проверяет таблицу ПараметрыИгрока на наличие параметра Проклятие со значением больше 0.
//
// Возвращаемое значение:
//  Булево - Истина, если проклятие активно, Ложь в противном случае.
//
&НаСервере
Функция ЕстьПроклятиеУИгрока()
	ВидПараметраПроклятие = Перечисления.ВидыПараметровИгроков.Проклятие;
	ЗначениеПроклятия = ПолучитьЗначениеПараметраИгрока(ВидПараметраПроклятие);
	Возврат ЗначениеПроклятия > 0;
КонецФункции		// ЕстьПроклятиеУИгрока()

#КонецОбласти

#Область РежимВосхождение

// Размещает случайного противника на форму.
//
&НаСервере
Процедура ЗагрузитьПротивника()
	Противник = Справочники.Противники.ПолучитьСлучайногоПротивника(ГСЧ);
КонецПроцедуры		// ЗагрузитьПротивника()

// Загружает таблицу цикла действий противника в реквизит формы ЦиклДействийПротивника.
//
&НаСервере
Процедура ЗагрузитьЦиклДействийПротивника(Противник)
	ЦиклДействийПротивника.Очистить();
	ТаблицаДействий = Справочники.Противники.ПолучитьТаблицуДействийЦикла(Противник);
	Для Каждого СтрокаДействия Из ТаблицаДействий Цикл
		НоваяСтрока = ЦиклДействийПротивника.Добавить();
		НоваяСтрока.ДействиеЦикла = СтрокаДействия.ДействиеЦикла;
		НоваяСтрока.МинимальнаяСила = СтрокаДействия.МинимальнаяСила;
		НоваяСтрока.МаксимальнаяСила = СтрокаДействия.МаксимальнаяСила;
		НоваяСтрока.ИдентификаторСтроки = Строка(Новый УникальныйИдентификатор);
	КонецЦикла;
КонецПроцедуры		// ЗагрузитьЦиклДействийПротивника()

// Возвращает начальное значение здоровья игрока по умолчанию.
//
&НаСервере
Функция НачальноеЗдоровьеИгрокаПоУмолчанию()
	Возврат 100;
КонецФункции

// Получает значение параметра игрока из таблицы ПараметрыИгрока по виду параметра.
//
// Параметры:
//  ВидПараметраВход - ПеречислениеСсылка.ВидыПараметровИгроков - вид параметра для поиска.
//
// Возвращаемое значение:
//  Число - значение параметра игрока, или 0 если параметр не найден.
//
&НаСервере
Функция ПолучитьЗначениеПараметраИгрока(ВидПараметраВход)
	РезультатФункции = 0;
