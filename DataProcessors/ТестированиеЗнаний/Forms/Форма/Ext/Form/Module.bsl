// Обрабатывает карту "Алебарда".
// Оставляет у противника половину его текущего здоровья, округление в большую сторону.
//
// Параметры:
//  КартаВход - СправочникСсылка.Карты - ссылка на карту.
//  ИдентификаторКартыВход - УникальныйИдентификатор - идентификатор карты в таблице РукаИгрока.
//
&НаСервере
Процедура ДействиеКарты_Алебарда(КартаВход, ИдентификаторКартыВход)
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	НовоеЗдоровье = Цел(ТекущееЗдоровьеПротивника / 2);
	Если НовоеЗдоровье <> ТекущееЗдоровьеПротивника / 2 Тогда
		НовоеЗдоровье = Цел(ТекущееЗдоровьеПротивника / 2) + 1;
	Иначе
		// Оставляем значение.
	КонецЕсли;
	УстановитьПараметрПротивника(ВидПараметраТекущееЗдоровье, НовоеЗдоровье);
КонецПроцедуры		// ДействиеКарты_Алебарда()

// Действие карты Закалка: наносит 6 урона игроку, даёт игроку 12 щита.
//
// Параметры:
//  КартаВход - СправочникСсылка.Карты - ссылка на карту.
//  ИдентификаторКартыВход - УникальныйИдентификатор - идентификатор карты в таблице РукаИгрока.
//
&НаКлиенте
Процедура ДействиеКарты_Закалка(КартаВход, ИдентификаторКартыВход)
	// Наносим 6 урона игроку
	НанестиУронИгроку(6);
	
	// Даём игроку 12 щита
	УвеличитьЩитИгрока(12);
КонецПроцедуры		// ДействиеКарты_Закалка()

// Действие карты Укрепление: проверяет, есть ли у игрока щит, если есть - игрок берёт одну карту, если нет - получает 3 щита.
//
// Параметры:
//  КартаВход - СправочникСсылка.Карты - ссылка на карту.
//  ИдентификаторКартыВход - УникальныйИдентификатор - идентификатор карты в таблице РукаИгрока.
//
&НаСервере
Процедура ДействиеКарты_Укрепление(КартаВход, ИдентификаторКартыВход)
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	ТекущийЩит = ПолучитьЗначениеПараметраИгрока(ВидПараметраЩит);
	Если ТекущийЩит > 0 Тогда
		// Щит активен - получает 2 щита и берёт карту
		УвеличитьЩитИгрока(2);
		КартаДляПеремещения = СтопкаДобора[0];
		ИдентификаторПеремещаемойКарты = КартаДляПеремещения.ИдентификаторКарты;
	Иначе
		// Щит неактивен - получает 3 щита
		УвеличитьЩитИгрока(3);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Укрепление()

// Выполняет действие карты ЩитИМеч.
// Наносит 5 единиц урона противнику и накладывает 3 единицы щита на игрока.
//
&НаСервере
Процедура ДействиеКарты_ЩитИМеч(КартаВход, ИдентифкаторКартыВход)
	// Наносим 5 единиц урона противнику
	НанестиУронПротивнику(5);
	// Накладываем 3 единицы щита на игрока
	УвеличитьЩитИгрока(3);
КонецПроцедуры		// ДействиеКарты_ЩитИМеч()

// Выполняет действие карты ОбходнойПуть.
// Перебрасывает текущее задание на случайное.
//
&НаСервере
Процедура ДействиеКарты_ОбходнойПуть(КартаВход, ИдентифкаторКартыВход)
	ПустойСборник = ПредопределенноеЗначение("Справочник.Сборники.ПустаяСсылка");
	НеверныеВариантыУбраны = Ложь;
	Элементы.ВыбратьВариант1.Доступность = Истина;
	Элементы.ВыбратьВариант2.Доступность = Истина;
	Элементы.ВыбратьВариант3.Доступность = Истина;
	Элементы.ВыбратьВариант4.Доступность = Истина;
	Элементы.ВыбратьВариант5.Доступность = Истина;
	Элементы.ВыбратьВариант6.Доступность = Истина;
	Элементы.ВыбратьВариант1.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант2.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант3.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант4.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант5.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант6.ЦветФона = Новый Цвет();
	РезультатСмены = СледующееЗадание_Сервер(ПустойСборник, РежимВикторины);	
	Сборник = РезультатСмены.Сборник;
	АдресКартинки = РезультатСмены.АдресКартинки;
	КоличествоЗаданных = КоличествоЗаданных + 1;
	ОтветДан = Ложь;
	ЭтаФорма.Заголовок = Строка(Сборник);
КонецПроцедуры		// ДействиеКарты_ОбходнойПуть()

// Выполняет действие выбранной карты.
//
// Параметры:
//	НайденнаяКарта - СправочникСсылка.Карты - разыгрываемая карта.
//	ИдентификаторКартыВход - Строка - Идентификатор разыгрываемой карты.
//
