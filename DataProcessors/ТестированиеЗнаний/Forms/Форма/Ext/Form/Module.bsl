&НаКлиенте
Процедура ДействиеКарты_Взрыв(КартаВход, ИдентифкаторКартыВход)
	УронКарты = 25;
	УронПротивникуПоКоличеству(УронКарты);
КонецПроцедуры		// ДействиеКарты_Взрыв()

// Осуществляет розыгрыш карты Адреналин.
// Карта выполняет сразу 3 действия:
// 1. Наносит 1 урон игроку;
// 2. Сбрасывает все карты из стопки РукаИгрока в стопку СтопкаСброса;
// 3. Добирает из стопки СтопкаДобора в стопку РукаИгрока пока в стопке РукаИгрока меньше 5 карт;
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Адреналин(КартаВход, ИдентифкаторКартыВход)
	// 1. Наносим 1 урон игроку
	НанестиУронИгроку(1);
	
	// 2. Сбрасываем все карты из РукаИгрока в СтопкаСброса
	Пока РукаИгрока.Количество() > 0 Цикл
		ПерваяКарта = РукаИгрока[0];
		ИдентификаторКарты = ПерваяКарта.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
	КонецЦикла;
	
	// 3. Добираем карты из СтопкаДобора в РукаИгрока пока в руке меньше 5 карт
	ДобратьРуку();
КонецПроцедуры		// ДействиеКарты_Адреналин()

// Разыгрывает карту "Без прикрас".
// Снимает все положительные параметры с противника и наносит игроку по 2 единицы урона за каждый снятый параметр.
&НаКлиенте
Процедура ДействиеКарты_БезПрикрас(КартаВход, ИдентифкаторКартыВход)
	// Получаем массив положительных параметров
	ПоложительныеПараметры = ПолучитьПоложительныеПараметры();
	// Размер урона за каждый снятый параметр
	РазмерУрона = 2;
	// Проходим по всем положительным параметрам и снимаем их с противника
	Для Каждого ВидПараметра Из ПоложительныеПараметры Цикл
		ЗначениеПараметра = ПолучитьЗначениеПараметраПротивника(ВидПараметра);
		Если ЗначениеПараметра > 0 Тогда
			УдалитьПараметрПротивника(ВидПараметра);
			// Наносим игроку урон за каждый снятый параметр
			НанестиУронИгроку(РазмерУрона);
		Иначе
			// Не требуется снимать параметр.
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры		// ДействиеКарты_БезПрикрас()

// Разыгрывает карту "Ложный маневр".
// Перемещает текущее действие противника на следующее по циклу.
&НаСервере
Процедура ДействиеКарты_ЛожныйМаневр(КартаВход, ИдентификаторКартыВход)
	ПереместитьДействиеПротивникаВпередПоЦиклу();
КонецПроцедуры		// ДействиеКарты_ЛожныйМаневр()

// Разыгрывает карту "Новый рассвет".
// Снимает все эффекты, кроме основных, с игрока и с противника.
&НаСервере
Процедура ДействиеКарты_НовыйРассвет(КартаВход, ИдентификаторКартыВход)
	// Очищаем параметры игрока, кроме основных
	ОчиститьПараметрыКромеОсновных(ПараметрыИгрока);
	// Очищаем параметры противника, кроме основных
	ОчиститьПараметрыКромеОсновных(ПараметрыПротивника);
КонецПроцедуры		// ДействиеКарты_НовыйРассвет()

// Разыгрывает карту "Опровержение".
// Убирает 1 случайный положительный параметр из таблицы ПараметрыПротивника.
&НаСервере
Процедура ДействиеКарты_Опровержение(КартаВход, ИдентификаторКартыВход)
	// Получаем список положительных параметров
	ПоложительныеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьПоложительныеПараметры();
	
	// Формируем массив строк с положительными параметрами у противника
	МассивПоложительныхСтрок = Новый Массив;
	Для Каждого СтрокаПараметра Из ПараметрыПротивника Цикл
		Если ПоложительныеПараметры.Найти(СтрокаПараметра.ВидПараметра) <> Неопределено Тогда
			МассивПоложительныхСтрок.Добавить(СтрокаПараметра);
		КонецЕсли;
	КонецЦикла;
	
	// Если есть положительные параметры, удаляем один случайный
	Если МассивПоложительныхСтрок.Количество() > 0 Тогда
		Индекс = Гсч.СлучайноеЧисло(0, МассивПоложительныхСтрок.Количество() - 1);
		СтрокаДляУдаления = МассивПоложительныхСтрок[Индекс];
		УдалитьПараметрПротивника(СтрокаДляУдаления.ВидПараметра);
	КонецЕсли;
КонецПроцедуры             // ДействиеКарты_Опровержение()

// Разыгрывает карту "Очищение".
// Удаляет 3 случайных отрицательных параметра игрока из таблицы ПараметрыИгрока.
&НаСервере
Процедура ДействиеКарты_Очищение(КартаВход, ИдентификаторКартыВход)
	// Получаем список отрицательных параметров
	ОтрицательныеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьОтрицательныеПараметры();
	// Формируем массив строк с отрицательными параметрами у игрока
	МассивОтрицательныхСтрок = Новый Массив;
	Для Каждого СтрокаПараметра Из ПараметрыИгрока Цикл
		Если ОтрицательныеПараметры.Найти(СтрокаПараметра.ВидПараметра) <> Неопределено Тогда
			МассивОтрицательныхСтрок.Добавить(СтрокаПараметра);
		КонецЕсли;
	КонецЦикла;
	// Удаляем до 3 случайных отрицательных параметров
	КоличествоДляУдаления = 3;
	Пока КоличествоДляУдаления > 0 И МассивОтрицательныхСтрок.Количество() > 0 Цикл
		Индекс = Гсч.СлучайноеЧисло(0, МассивОтрицательныхСтрок.Количество() - 1);
		СтрокаДляУдаления = МассивОтрицательныхСтрок[Индекс];
		УдалитьПараметрИгрока(СтрокаДляУдаления.ВидПараметра);
		МассивОтрицательныхСтрок.Удалить(Индекс);
		КоличествоДляУдаления = КоличествоДляУдаления - 1;
	КонецЦикла;
КонецПроцедуры		// ДействиеКарты_Очищение()

// Обработка карты "ЛовкостьРук".
// Перемещает две карты из таблицы СтопкаДобора в таблицу РукаИгрока.
