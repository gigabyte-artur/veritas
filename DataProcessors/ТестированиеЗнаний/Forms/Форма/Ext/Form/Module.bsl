#КонецОбласти

#Область ДействияИгрока

// Возвращает размер урона, наносимого игроком.
// 
&НаСервере
Функция ПолучитьРазмерУронаИгрока()
	// Инициализация.
	ВидПараметраЯрость = Перечисления.ВидыПараметровИгроков.Ярость;
	ВидПараметраСила = Перечисления.ВидыПараметровИгроков.Сила;
	БазовыйУрон = 10;
	// Добавляем бонус от параметра Сила игрока
	РезультатФункции = БазовыйУрон;
	ЗначениеСилы = ПолучитьЗначениеПараметраИгрока(ВидПараметраСила);
	РезультатФункции = РезультатФункции + ЗначениеСилы;
	// Применяем параметр Ярость: увеличение урона на 5% за каждую единицу Ярости
	ЗначениеЯрости = ПолучитьЗначениеПараметраИгрока(ВидПараметраЯрость);
	Если ЗначениеЯрости > 0 Тогда
		КоэффициентЯрости = 1 + (ЗначениеЯрости * 0.05);
		РезультатФункции = РезультатФункции * КоэффициентЯрости;
	Иначе
		// Нет Ярости.
	КонецЕсли;
	// Применяем модификатор "Заточка": увеличение урона на 1
	Если МодификаторАктивен(Справочники.Модификаторы.Заточка) Тогда
		РезультатФункции = РезультатФункции + 1;
	Иначе
		// Нет заточки.
	КонецЕсли;
	// Проверяем наличие проклятия у игрока
	Если ЕстьПроклятиеУИгрока() Тогда
		// Уменьшаем урон на 25%
		РезультатФункции = РезультатФункции * 0.75;
	Иначе
		// Проклятия нет, урон не уменьшаем.
	КонецЕсли;
	// Округлим до целых.
	РезультатФункции = Цел(РезультатФункции);
	Возврат РезультатФункции;
КонецФункции		// ПолучитьРазмерУронаИгрока()

// наносит урон противнику по количеству, отрабатывая все модификаторы.
//
// Параметры:
//	УронВход - Число - Размер наносимого урона.
//
&НаКлиенте
Процедура УронПротивникуПоКоличеству(УронВход)
	// Вызываем метод нанесения урона противнику
	РезультатУрона = НанестиУронПротивнику(УронВход);
	УронПоЩиту = РезультатУрона.УронПоЩиту;
	УронПоЗдоровью = РезультатУрона.УронПоЗдоровью;
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ПредопределенноеЗначение("Перечисление.ВидыПараметровИгроков.ТекущееЗдоровье"));
	// Применяем модификатор "ЛетучаяМышь": излечение 5% от нанесенного урона
	Если МодификаторАктивен(ПредопределенноеЗначение("Справочник.Модификаторы.ЛетучаяМышь")) Тогда
		ПрименитьМодификатор_ЛетучаяМышь(УронПоЗдоровью);
	КонецЕсли;
	// Применяем модификатор "ЦепкийКрюк": увеличение щита на 20% от урона по щиту
	Если МодификаторАктивен(ПредопределенноеЗначение("Справочник.Модификаторы.ЦепкийКрюк")) Тогда
		ПрименитьМодификатор_ЦепкийКрюк(УронПоЩиту);
	КонецЕсли;
	// Применяем модификатор "ПарныеКлинки": 10% шанс на вторую атаку
	Если МодификаторАктивен(ПредопределенноеЗначение("Справочник.Модификаторы.ПарныеКлинки")) Тогда
		ШансВторойАтаки = ГсчКлиент.СлучайноеЧисло(1, 100);
		Если ШансВторойАтаки <= 10 Тогда
			// Проводим вторую атаку
			АтакаИгрока();
		КонецЕсли;
	КонецЕсли;
	РезультатПроверки = ПроверитьПобеды();
	ПротивникПобежден	 = РезультатПроверки.ПротивникПобежден;
	ИгрокПобежден		 = РезультатПроверки.ИгрокПобежден;
	Если ИгрокПобежден Тогда
		// Проверяем поражение игрока с учетом модификатора "Туман"
		ПроверитьПоражениеИгрока();
		// Если игрок все еще доступен (воскрес благодаря Туману), продолжаем игру
		Если ЭтаФорма.Доступность = Ложь Тогда
			Возврат;
		КонецЕсли;
	Иначе
		Если ПротивникПобежден Тогда
			ОбработатьПобедуНадПротивником();
		Иначе
			// Не требуется обработка победы над противником, т.к. не побежден.
			ОтобразитьСледующееЗадание(Сборник);
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры		// УронПротивникуПоКоличеству()

// Выполняет атаку игрока по противнику.
// Уменьшает текущее здоровье противника на величину урона игрока.
// Если у противника есть щит, урон сначала поглощается щитом.
// При активном модификаторе "ЛетучаяМышь" игрок излечивает 5% от нанесенного урона.
// При активном модификаторе "ЦепкийКрюк" игроку увеличивается щит на 20% от урона по щиту противника.
&НаКлиенте
Процедура АтакаИгрока()
	Урон = ПолучитьРазмерУронаИгрока();
	УронПротивникуПоКоличеству(Урон);
КонецПроцедуры		// АтакаИгрока()

// Возвращает признак победы над противником (здоровье <= 0).
//
// Возвращаемое значение:
//  Булево - Истина, если противник побежден, Ложь в противном случае.
//
&НаСервере
Функция ПротивникБылПобежден()
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметра);
	Возврат ТекущееЗдоровье <= 0;
КонецФункции		// ПротивникБылПобежден()

// Выполняет действия при победе над противником.
&НаКлиенте
Процедура ОбработатьПобедуНадПротивником()  
	// Для режима Восхождение открываем форму выбора этапа
	Если РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение") Тогда
		Если ПройденПоследнийЭтап() Тогда
			// Последний этап пройден, завершаем восхождение
			ЗавершитьВосхождение();
		Иначе
			ОчиститьПараметрыИгрокаКромеБазовых();
			ПоказатьПредупреждение(,"Текущий противник побежден!");
			// Выдаем награды за победу
			ВыдатьНаградыЗаПобеду(Противник);
			ВыбратьСледующийЭтап();
		КонецЕсли;
	Иначе	
		ИнициализироватьПротивника();
	КонецЕсли;
КонецПроцедуры		// ОбработатьПобедуНадПротивником()

// Проверяет, пройден ли последний этап восхождения.
//
// Возвращаемое значение:
//  Булево - Истина, если последний этап пройден, Ложь в противном случае.
//
&НаКлиенте
Функция ПройденПоследнийЭтап()
	Возврат НомерЭтапа >= ВсегоЭтапов;
КонецФункции		// ПройденПоследнийЭтап()

// Выдает награды за победу над противником.
//
// Параметры:
//  ПобежденныйПротивник - СправочникСсылка.Противники - побежденный противник.
//
&НаСервере
Процедура ВыдатьНаградыЗаПобеду(ПобежденныйПротивник)
	// Начисляем золото за победу
	НачислитьИгрокуЗолотоЗаПобеду(ПобежденныйПротивник);
	// Возвращаем похищенное золото
	ВернутьПохищенноеЗолото(ПобежденныйПротивник);
КонецПроцедуры		// ВыдатьНаградыЗаПобеду()

// Возвращает похищенное золото от противника игроку.
// Увеличивает параметр Золото игрока на величину параметра Золото противника,
// после чего параметр Золото противника обнуляется.
//
// Параметры:
//  ПобежденныйПротивник - СправочникСсылка.Противники - побежденный противник.
//
&НаСервере
Процедура ВернутьПохищенноеЗолото(ПобежденныйПротивник)
	ВидПараметраЗолото = Перечисления.ВидыПараметровИгроков.Золото;
	// Получаем значение золота противника
	ЗолотоПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраЗолото);
	Если ЗолотоПротивника > 0 Тогда
		// Увеличиваем золото игрока на величину золота противника
		УвеличитьПараметрИгрока(ВидПараметраЗолото, ЗолотоПротивника);
		// Обнуляем золото противника
		УстановитьПараметрПротивника(ВидПараметраЗолото, 0);
		Сообщить("Вы вернули " + Строка(ЗолотоПротивника) + " золотых монет, похищенных противником!");
	Иначе
		// Золото не было похиищено. Нечего возвращать.
	КонецЕсли;
КонецПроцедуры		// ВернутьПохищенноеЗолото()

// Обрабатывает побег противника из боя.
// Бой завершается, игрок переходит на следующий этап, но не получает награды за бой.
//
&НаСервере
Процедура ОбработатьПобегПротивника()
	Сообщить("Противник сбежал из боя!");
	ПротивникСбежал = Истина;
КонецПроцедуры		// ОбработатьПобегПротивника()

// Начисляет игроку золото за победу над противником.
//
// Параметры:
//  ПротивникВход - СправочникСсылка.Противники - побежденный противник.
//
&НаСервере
Процедура НачислитьИгрокуЗолотоЗаПобеду(ПротивникВход)
	// Начисление игроку золота за победу над противником
	// Случайная величина от 20 до 40 единиц
	МинЗолото = 20;
	МаксЗолото = 40;
	НачисленоЗолота = Гсч.СлучайноеЧисло(МинЗолото, МаксЗолото);
	// Получаем текущее значение золота игрока и увеличиваем его
	ВидПараметраЗолото = Перечисления.ВидыПараметровИгроков.Золото;
	УвеличитьПараметрИгрока(ВидПараметраЗолото, НачисленоЗолота);
	Сообщить("Игрок получил " + Строка(НачисленоЗолота) + " золотых монет за победу!");
КонецПроцедуры		// НачислитьИгрокуЗолотоЗаПобеду()

// Выполняет действия игрока после успешного ответа.
&НаКлиенте
Процедура ДействияИгрока()
	АтакаИгрока();
КонецПроцедуры		// ДействияИгрока()

#КонецОбласти
 
// Выполняет проверку победы над противником и поражения игрока.
&НаСервере
Функция ПроверитьПобеды()
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("ПротивникПобежден",	 ПротивникБылПобежден());
	РезультатФункции.Вставить("ИгрокПобежден",		 ИгрокБылПобежден());
	Возврат РезультатФункции;
КонецФункции		// ПроверитьПобеды()

// Отображает текущее состояние противника в реквизитах формы.
&НаСервере
Процедура ОтобразитьСостояниеПротивника()
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
КонецПроцедуры		// ОтобразитьСостояниеПротивника()

// Отображает текущее состояние игрока в реквизитах формы.
&НаСервере
Процедура ОтобразитьСостояниеИгрока()
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
КонецПроцедуры		// ОтобразитьСостояниеИгрока()

#Область ДействияПротивника

// Возвращает размер урона, наносимого противником.
// Учитывает модификатор "Проклятие", который уменьшает урон на 25%.
// Увеличивает урон на величину параметра Сила противника.
&НаСервере
Функция ПолучитьРазмерУронаПротивника()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	РезультатФункции = 10; // Значение по умолчанию
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение урона в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РезультатФункции = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		РезультатФункции = 10;
	КонецЕсли;
	// Добавляем бонус от параметра Сила противника
	ВидПараметраСила = Перечисления.ВидыПараметровИгроков.Сила;
	ЗначениеСилы = ПолучитьЗначениеПараметраПротивника(ВидПараметраСила);
	РезультатФункции = РезультатФункции + ЗначениеСилы;
	// Проверяем наличие проклятия у противника
	Если ЕстьПроклятиеУПротивника() Тогда
		// Уменьшаем урон на 25%
		РезультатФункции = РезультатФункции * 0.75;
		// Округляем до целых
		РезультатФункции = Цел(РезультатФункции);
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьРазмерУронаПротивника()

// Выполняет атаку противника по игроку.
// Уменьшает текущее здоровье игрока на величину урона противника.
// Если активен модификатор "Кожаные пластины", урон уменьшается на 1.
&НаСервере
Процедура АтакаПротивника()
	НанестиУронПротивником();
КонецПроцедуры		// АтакаПротивника()

// Восстанавливает здоровье противника.
// Противник излечивает недостающее здоровью на величину от минимальной до максимальной силы текущего действия,
// но не более своего максимального здоровья.
&НаСервере
Процедура ЛечениеПротивника()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение лечения в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РазмерЛечения = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		// Значение по умолчанию, если действие не найдено
		РазмерЛечения = 5;
	КонецЕсли;
	// Получаем текущее и максимальное здоровье противника
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
	// Вычисляем недостающее здоровье
	НедостающееЗдоровье = МаксимальноеЗдоровье - ТекущееЗдоровье;
	// Лечение не может превышать недостающее здоровье и не может быть больше максимального здоровья
	ФактическоеЛечение = Мин(РазмерЛечения, НедостающееЗдоровье);
	// Восстанавливаем здоровье противника
	НовоеЗдоровье = ТекущееЗдоровье + ФактическоеЛечение;
	УстановитьПараметрПротивника(ВидПараметраТекущееЗдоровье, НовоеЗдоровье);
КонецПроцедуры		// ЛечениеПротивника()

// Выполняет действие противника Вампиризм.
// Противник наносит урон от минимальной до максимальной силы текущего действия,
// после чего излечивает себе 25% от нанесённого игроку урона, но не более своего максимального здоровья.
&НаСервере
Процедура Вампиризм()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение урона в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РазмерУрона = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		// Значение по умолчанию, если действие не найдено
		РазмерУрона = 5;
	КонецЕсли;
	// Наносим урон игроку
	НанестиУронИгроку(РазмерУрона);
	// Вычисляем лечение для противника (25% от нанесённого урона)
	РазмерЛечения = Цел(РазмерУрона * 0.25);
	// Получаем текущее и максимальное здоровье противника
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
	// Вычисляем недостающее здоровье
	НедостающееЗдоровье = МаксимальноеЗдоровье - ТекущееЗдоровье;
	// Лечение не может превышать недостающее здоровье
	ФактическоеЛечение = Мин(РазмерЛечения, НедостающееЗдоровье);
	// Восстанавливаем здоровье противника
	НовоеЗдоровье = ТекущееЗдоровье + ФактическоеЛечение;
	УстановитьПараметрПротивника(ВидПараметраТекущееЗдоровье, НовоеЗдоровье);
КонецПроцедуры		// Вампиризм()

// Противник просто пропускает текущий ход (спит).
//
&НаСервере
Процедура ОбработатьСон()
	// Пустая процедура - противник спит и ничего не делает в этот ход.
КонецПроцедуры		// ОбработатьСон()

// Выполняет действие противника УкрастьЗолото.
// Противник крадет случайное количество золота у игрока от МинимальнаяСила до МаксимальнаяСила текущего действия,
// но не более общего количества золота игрока.
// Похищенное золото добавляется к золоту противника.
&НаСервере
Процедура УкрастьЗолото()
	// Получаем текущее действие противника из таблицы ЦиклДействийПротивника
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		// Генерируем случайное значение украденного золота в диапазоне от МинимальнаяСила до МаксимальнаяСила
		РазмерКражи = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		// Значение по умолчанию, если действие не найдено
		РазмерКражи = 5;
	КонецЕсли;
	// Получаем текущее золото игрока
	ВидПараметраЗолото = Перечисления.ВидыПараметровИгроков.Золото;
	ЗолотоИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраЗолото);
	// Количество похищенного золота не может быть больше общего количества золота игрока
	ФактическаяКража = Мин(РазмерКражи, ЗолотоИгрока);
	// Уменьшаем золото у игрока через метод УвеличитьПараметрИгрока с отрицательным значением
	УвеличитьПараметрИгрока(ВидПараметраЗолото, -ФактическаяКража);
	// Увеличиваем золото у противника
	ЗолотоПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраЗолото);
	НовоеЗолотоПротивника = ЗолотоПротивника + ФактическаяКража;
	УстановитьПараметрПротивника(ВидПараметраЗолото, НовоеЗолотоПротивника);
КонецПроцедуры		// УкрастьЗолото()

// Наносит урон игроку от противника.
// Учитывает модификатор "Кожаные пластины", который уменьшает урон на 1.
//
&НаСервере
Процедура НанестиУронПротивником()
	Урон = ПолучитьРазмерУронаПротивника();
	НанестиУронИгроку(Урон);
КонецПроцедуры		// НанестиУронПротивником()

// Наносит урон игроку.
&НаСервере
Процедура НанестиУронИгроку(УронВход)
	НовыйУрон = УронВход;
	// Обработка щита игрока: урон сначала приходится по щиту
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	ЗначениеЩита = ПолучитьЗначениеПараметраИгрока(ВидПараметраЩит);
	УронПоЩиту = 0;
	Если ЗначениеЩита > 0 Тогда
		Если ЗначениеЩита >= НовыйУрон Тогда
			НовоеЗначениеЩита = ЗначениеЩита - НовыйУрон;
			УстановитьПараметрИгрока(ВидПараметраЩит, НовоеЗначениеЩита);
			УронПоЩиту = НовыйУрон; // Щит полностью поглотил урон
			НовыйУрон = 0; // Щит полностью поглотил урон, дальнейшие действия не требуются.
		Иначе
			ОстатокУрона = НовыйУрон - ЗначениеЩита;
			УронПоЩиту = ЗначениеЩита; // Урон по щиту равен значению щита
			УстановитьПараметрИгрока(ВидПараметраЩит, 0);
			НовыйУрон = ОстатокУрона;
		КонецЕсли;
	Иначе
		// Щита нет, урон наносится по здоровью (дальнейшие действия не требуются).
	КонецЕсли;
	// Применяем урон по здоровью только если щит не поглотил весь урон
	Если НовыйУрон > 0 Тогда
		ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
		ТекущееЗначение = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
		// Применяем модификатор "Кожаные пластины": уменьшаем урон на 1
		Если МодификаторАктивен(Справочники.Модификаторы.КожаныеПластины) Тогда
			НовыйУрон = Макс(0, НовыйУрон - 1);
		Иначе
			// Не требуется изменение урона.
		КонецЕсли;
		// Применяем модификатор "Кольчуга": поглощает 25% от входящего урона
		Если МодификаторАктивен(Справочники.Модификаторы.Кольчуга) Тогда
			НовыйУрон = Цел(НовыйУрон * 0.75);
		Иначе
			// Кольчуга не активна. Не наносим урон.
		КонецЕсли;
		НовоеЗначение = ТекущееЗначение - НовыйУрон;
		Если НовоеЗначение < 0 Тогда
			НовоеЗначение = 0;
		Иначе
			// Значение здоровья корректно, оставляем как есть
		КонецЕсли;
		УстановитьПараметрИгрока(ВидПараметра, НовоеЗначение);
	КонецЕсли;
	// Проверяем поражение игрока после нанесения урона (для обработки модификатора "Туман")
	ПроверитьПоражениеИгрока();
КонецПроцедуры		// НанестиУронИгроку()

// Наносит урон игроку от взрыва бомбы (без учета модификаторов).
// Урон выбирается случайным образом между МинимальнаяСила и МаксимальнаяСила
// для того действия противника, в результате которого на игрока наложен параметр Бомба.
&НаСервере
Процедура НанестиУронИгрокуОтБомбы()
	// Получаем идентификатор действия противника из строки параметра "Бомба"
	ВидПараметраБомба = Перечисления.ВидыПараметровИгроков.Бомба;
	ИдентификаторДействия = "";
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ВидПараметра", ВидПараметраБомба);
	НайденныеСтроки = ПараметрыИгрока.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		ИдентификаторДействия = НайденныеСтроки[0].ИдентификаторДействияПротивника;
	КонецЕсли;
	// Получаем МинимальнаяСила и МаксимальнаяСила из таблицы ЦиклДействийПротивника
	МинСила		 = 5; // Значение по умолчанию
	МаксСила	 = 5;
	Если ЗначениеЗаполнено(ИдентификаторДействия) Тогда
		СтруктураПоискаДействия = Новый Структура;
		СтруктураПоискаДействия.Вставить("ИдентификаторСтроки", ИдентификаторДействия);
		НайденныеДействия = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоискаДействия);
		Если НайденныеДействия.Количество() > 0 Тогда
			МинСила		 = НайденныеДействия[0].МинимальнаяСила;
			МаксСила	 = НайденныеДействия[0].МаксимальнаяСила;
		Иначе
			// Оставляем значения по умолчанию.
		КонецЕсли;
	КонецЕсли;
	// Генерируем случайный урон в диапазоне от МинСила до МаксСила.
	УронОтБомбы = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	// Применяем урон по здоровью через метод НанестиУронИгроку()
	НанестиУронИгроку(УронОтБомбы);
КонецПроцедуры		// НанестиУронИгрокуОтБомбы()

// Проверяет параметр "Бомба" и наносит урон, если значение <= 0.
// 
// Параметры:
//  ЗначениеБомбы - Число - текущее значение параметра "Бомба".
//
&НаСервере
Процедура ПроверитьБомбу(ЗначениеБомбы)
	Если ЗначениеБомбы <= 0 Тогда
		НанестиУронИгрокуОтБомбы();
	Иначе
		// Бомба продолжает тикать. Ничего не происходит.
	КонецЕсли;
КонецПроцедуры		// ПроверитьБомбу()

// Выполняет атаку противника "Удар на удачу".
// Имеет 50% шанс промаха. При попадании наносит урон как обычная атака.
&НаСервере
Процедура УдарНаУдачу()
	// Генерируем случайное число от 0 до 99
	Шанс = Гсч.СлучайноеЧисло(0, 99);
	Если Шанс < 50 Тогда
		// Попадание (50% шанс)
		НанестиУронПротивником();
	Иначе
		// Промах (50% шанс)
		// Урон не наносится
	КонецЕсли;
КонецПроцедуры// УдарНаУдачу()

// Возвращает текущее действие противника из таблицы ЦиклДействийПротивника
// по идентификатору ИдентификаторТекущегоДействияПротивника.
//
// Возвращаемое значение:
//  ПеречислениеСсылка.ВариантыДействийПротивников - ссылка на вариант действия, или пустая ссылка если не найдено.
//
&НаСервере
Функция ПолучитьТекущееДействиеПротивника()
	РезультатФункции = Перечисления.ВариантыДействийПротивников.ПустаяСсылка();
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		РезультатФункции = НайденныеСтроки[0].ДействиеЦикла;
	Иначе
		Сообщить("Действие противника с идентификатором " + ИдентификаторТекущегоДействияПротивника + " не найдено");
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТекущееДействиеПротивника()

// Перемещает действие противника вперед по циклу.
// Устанавливает идентификатор текущего действия на значение из следующей строки таблицы.
// Если достигнут конец таблицы - устанавливает значение из первой строки.
&НаСервере
Процедура ПереместитьДействиеПротивникаВпередПоЦиклу()
	Если ЦиклДействийПротивника.Количество() > 0 Тогда
		ТекущийИндекс = -1;
		Для Индекс = 0 По ЦиклДействийПротивника.Количество() - 1 Цикл
			Если ЦиклДействийПротивника[Индекс].ИдентификаторСтроки = ИдентификаторТекущегоДействияПротивника Тогда
				ТекущийИндекс = Индекс;
				Прервать;
			Иначе
				// Продолжаем поиск
			КонецЕсли;
		КонецЦикла;
		Если ТекущийИндекс >= 0 Тогда
			СледующийИндекс = ТекущийИндекс + 1;
			Если СледующийИндекс >= ЦиклДействийПротивника.Количество() Тогда
				СледующийИндекс = 0;
			Иначе
				// Индекс в пределах таблицы
			КонецЕсли;
			ИдентификаторТекущегоДействияПротивника = ЦиклДействийПротивника[СледующийИндекс].ИдентификаторСтроки;
		Иначе
			// Текущее действие не найдено, сбрасываем на первое
			ИдентификаторТекущегоДействияПротивника = ЦиклДействийПротивника[0].ИдентификаторСтроки;
		КонецЕсли;
	Иначе
		// Таблица пуста, оставляем как есть
	КонецЕсли;
КонецПроцедуры		// ПереместитьДействиеПротивникаВпередПоЦиклу()

// Выполняет действия противника после неуспешного ответа.
&НаСервере
Функция ДействияПротивника()
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("ВариантДействия", Перечисления.ВариантыДействийПротивников.ПустаяСсылка());
	// Получение текущего действия противника
	ТекущееДействие = ПолучитьТекущееДействиеПротивника();
	// Обработка выбранного действия
	ОбработатьВыбранноеДействиеПротивника(ТекущееДействие);
	// Перемещение к следующему действию по циклу
	ПереместитьДействиеПротивникаВпередПоЦиклу();
	// Вывод состояний.
	ПроверитьПобеды();
	ОтобразитьСостояниеИгрока();
	ОтобразитьСостояниеПротивника();
	РезультатФункции.Вставить("ВариантДействия", ТекущееДействие);
	Возврат РезультатФункции;
КонецФункции		// ДействияПротивника()

// Возвращает структуру параметров для открытия формы действия противника.
//
// Параметры:
//  ВариантДействия - ПеречислениеСсылка.ВариантыДействийПротивников - вариант действия противника.
//
// Возвращаемое значение:
//  Структура - содержащая параметры: ВариантДействия, Противник, 
//  ТекущееЗдоровьеИгрока, МаксимальноеЗдоровьеИгрока, 
//  ТекущееЗдоровьеПротивника, МаксимальноеЗдоровьеПротивника.
//
&НаСервере
Функция ПолучитьПараметрыОткрытияФормыПротивника(ВариантДействияВход)
	Результат = Новый Структура;
	// Вариант действия противника
	Результат.Вставить("ВариантДействия",					 ВариантДействияВход);
	// Противник
	Результат.Вставить("Противник",							 Противник);
	// Здоровье игрока
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ТекущееЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
	Результат.Вставить("ТекущееЗдоровьеИгрока",				 ТекущееЗдоровьеИгрока);
	Результат.Вставить("МаксимальноеЗдоровьеИгрока",		 МаксимальноеЗдоровьеИгрока);
	// Здоровье противника
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
	Результат.Вставить("ТекущееЗдоровьеПротивника",			 ТекущееЗдоровьеПротивника);
	Результат.Вставить("МаксимальноеЗдоровьеПротивника",	 МаксимальноеЗдоровьеПротивника);
	Возврат Результат;
КонецФункции		// ПолучитьПараметрыОткрытияФормыПротивника()

// Обрабатывает выбранное действие противника.
//
// Параметры:
//  ВидДействияВход - ПеречислениеСсылка.ВариантыДействийПротивников - текущее действие противника.
//
&НаСервере
// Обрабатывает действие противника "Увеличить силу".
// Увеличивает параметр Сила у противника на случайное значение между 
// МинимальнаяСила и МаксимальнаяСила из таблицы ЦиклДействийПротивника.
// Обрабатывает увеличение силы противника при действии "УвеличитьСилу".
// Использует значения МинимальнаяСила и МаксимальнаяСила из таблицы ЦиклДействийПротивника
// для текущего действия противника.
//
&НаСервере
Процедура ОбработатьУвеличениеСилыПротивника()
	ВидПараметраСила = Перечисления.ВидыПараметровИгроков.Сила;
	// Поиск строки в таблице ЦиклДействийПротивника по идентификатору текущего действия
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		ПриращениеСилы = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		ПриращениеСилы = 1; // Значение по умолчанию
	КонецЕсли;
	ЗначениеСилы = ПолучитьЗначениеПараметраПротивника(ВидПараметраСила);
	НовоеЗначениеСилы = ЗначениеСилы + ПриращениеСилы;
	УстановитьПараметрПротивника(ВидПараметраСила, НовоеЗначениеСилы);
КонецПроцедуры		// ОбработатьУвеличениеСилыПротивника()

// Обрабатывает увеличение неуклюжести игрока при действии противника "НаложитьНеуклюжесть".
// Использует значения МинимальнаяСила и МаксимальнаяСила из таблицы ЦиклДействийПротивника
// для текущего действия противника.
//
&НаСервере
Процедура ОбработатьУвеличениеНеуклюжестиПротивником()
	ВидПараметраНеуклюжесть = Перечисления.ВидыПараметровИгроков.Неуклюжесть;
	// Поиск строки в таблице ЦиклДействийПротивника по идентификатору текущего действия
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторСтроки", ИдентификаторТекущегоДействияПротивника);
	НайденныеСтроки = ЦиклДействийПротивника.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		МинСила = НайденныеСтроки[0].МинимальнаяСила;
		МаксСила = НайденныеСтроки[0].МаксимальнаяСила;
		ПриращениеНеуклюжести = Гсч.СлучайноеЧисло(МинСила, МаксСила);
	Иначе
		ПриращениеНеуклюжести = 1; // Значение по умолчанию
	КонецЕсли;
	УвеличитьПараметрИгрока(ВидПараметраНеуклюжесть, ПриращениеНеуклюжести);
КонецПроцедуры		// ОбработатьУвеличениеНеуклюжестиПротивником()

// Возвращает признак наличия проклятия у противника.
// Проверяет таблицу ПараметрыПротивника на наличие параметра Проклятие со значением больше 0.
//
// Возвращаемое значение:
//  Булево - Истина, если проклятие активно, Ложь в противном случае.
//
&НаСервере
Функция ЕстьПроклятиеУПротивника()
	ВидПараметраПроклятие = Перечисления.ВидыПараметровИгроков.Проклятие;
	ЗначениеПроклятия = ПолучитьЗначениеПараметраПротивника(ВидПараметраПроклятие);
	Возврат ЗначениеПроклятия > 0;
КонецФункции		// ЕстьПроклятиеУПротивника()

// Обрабатывает выбранное действие противника.
// Параметры:
//  ВидДействияВход - ПеречислениеСсылка.ВариантыДействийПротивников - вид действия противника.
//
&НаСервере
Процедура ОбработатьВыбранноеДействиеПротивника(ВидДействияВход)
	// Инициализация.
	ВариантДействияАтака             = Перечисления.ВариантыДействийПротивников.Атака;
	ВариантДействияНаложитьЩит       = Перечисления.ВариантыДействийПротивников.НаложитьЩит;
	ВариантДействияНаложитьПроклятие = Перечисления.ВариантыДействийПротивников.НаложитьПроклятие;
	ВариантДействияУдарНаУдачу       = Перечисления.ВариантыДействийПротивников.УдарНаУдачу;
	ВариантДействияАктивироватьБомбу   = Перечисления.ВариантыДействийПротивников.АктивироватьБомбу;
	ВариантДействияУвеличитьСилу       = Перечисления.ВариантыДействийПротивников.УвеличитьСилу;
	ВариантДействияНаложитьНеуклюжесть = Перечисления.ВариантыДействийПротивников.НаложитьНеуклюжесть;
	ВариантДействияЛечение             = Перечисления.ВариантыДействийПротивников.Лечение;
	ВариантДействияСон                 = Перечисления.ВариантыДействийПротивников.Сон;
	ВариантДействияВампиризм           = Перечисления.ВариантыДействийПротивников.Вампиризм;
	ВариантДействияУкрастьЗолото       = Перечисления.ВариантыДействийПротивников.УкрастьЗолото;
	ВариантДействияСбежатьИзБоя        = Перечисления.ВариантыДействийПротивников.СбежатьИзБоя;
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	ВидПараметраПроклятие = Перечисления.ВидыПараметровИгроков.Проклятие;
	ВидПараметраБомба = Перечисления.ВидыПараметровИгроков.Бомба;
	ВидПараметраНеуклюжесть = Перечисления.ВидыПараметровИгроков.Неуклюжесть;
	// Проверка вида действия: если атака - выполнять атаку
	Если ЗначениеЗаполнено(ВидДействияВход) Тогда
		Если ВидДействияВход = ВариантДействияАтака Тогда
			АтакаПротивника();
		ИначеЕсли ВидДействияВход = ВариантДействияНаложитьЩит Тогда
			// Противник накладывает на себя щит
			ЗначениеЩита = ПолучитьЗначениеПараметраПротивника(ВидПараметраЩит);
			НовоеЗначениеЩита = ЗначениеЩита + ПолучитьЗначениеЩитаПротивника();
			УстановитьПараметрПротивника(ВидПараметраЩит, НовоеЗначениеЩита);
		ИначеЕсли ВидДействияВход = ВариантДействияНаложитьПроклятие Тогда
			// Противник накладывает проклятие на игрока на 2 хода
			УвеличитьПараметрИгрока(ВидПараметраПроклятие, 2, ИдентификаторТекущегоДействияПротивника);
		ИначеЕсли ВидДействияВход = ВариантДействияУдарНаУдачу Тогда
			// Противник наносит удар на удачу с 50% шансом промаха
			УдарНаУдачу();
		ИначеЕсли ВидДействияВход = ВариантДействияАктивироватьБомбу Тогда
			// Противник активирует бомбу на игроке (устанавливает значение 3)
			УвеличитьПараметрИгрока(ВидПараметраБомба, 3, ИдентификаторТекущегоДействияПротивника);
		ИначеЕсли ВидДействияВход = ВариантДействияУвеличитьСилу Тогда
			ОбработатьУвеличениеСилыПротивника();
		ИначеЕсли ВидДействияВход = ВариантДействияНаложитьНеуклюжесть Тогда
			ОбработатьУвеличениеНеуклюжестиПротивником();
		ИначеЕсли ВидДействияВход = ВариантДействияЛечение Тогда
			// Противник излечивает себя
			ЛечениеПротивника();
		ИначеЕсли ВидДействияВход = ВариантДействияВампиризм Тогда
			// Противник наносит урон игроку и излечивает себе 25% от нанесённого урона
			Вампиризм();
		ИначеЕсли ВидДействияВход = ВариантДействияСон Тогда
			// Противник просто пропускает текущий ход (спит)
			ОбработатьСон();
		ИначеЕсли ВидДействияВход = ВариантДействияУкрастьЗолото Тогда
			// Противник крадет золото у игрока
			УкрастьЗолото();
		ИначеЕсли ВидДействияВход = ВариантДействияСбежатьИзБоя Тогда
			// Противник сбегает из боя: бой завершается, игрок переходит на следующий этап без наград
			ОбработатьПобегПротивника();
		Иначе
			// Другие виды действий могут быть обработаны здесь
			Сообщить("Неизвестный вид действия противника: " + Строка(ВидДействияВход));
		КонецЕсли;
	Иначе
		// Действие не найдено, выполняем атаку по умолчанию
		АтакаПротивника();
	КонецЕсли;
КонецПроцедуры		// ОбработатьВыбранноеДействиеПротивника()

// Возвращает признак победы над игроком (здоровье <= 0).
//
// Возвращаемое значение:
//  Булево - Истина, если игрок побежден, Ложь в противном случае.
//
&НаСервере
Функция ИгрокБылПобежден()
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
	Возврат ТекущееЗдоровье <= 0;
КонецФункции		// ИгрокБылПобежден()

// Очищает все параметры игрока кроме текущего и макисмльаного здоровья.
//
&НаСервере
Процедура ОчиститьПараметрыИгрокаКромеБазовых()
	ВидПараметрТекущееЗдоровье		 = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметрМаксимальноеЗдоровье	 = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ВидПараметрЗолото				 = Перечисления.ВидыПараметровИгроков.Золото;
	Для Каждого ТекПараметрыИгрока Из ПараметрыИгрока Цикл
		ТекВидПараметра = ТекПараметрыИгрока.ВидПараметра;
		ЭтоПропускаемыйПараметр = (ТекВидПараметра = ВидПараметрТекущееЗдоровье ИЛИ 
			ТекВидПараметра = ВидПараметрМаксимальноеЗдоровье ИЛИ ТекВидПараметра = ВидПараметрЗолото);
		Если ЭтоПропускаемыйПараметр Тогда
			Продолжить;
		КонецЕсли;
		// Удаляем параметр
		УдалитьПараметрИгрока(ТекВидПараметра);
	КонецЦикла;
КонецПроцедуры		// ОчиститьПараметрыИгрокаКромеБазовых()

// Проверяет, побежден ли игрок (здоровье <= 0).
// Если побежден и активен модификатор "Туман" - игрок воскресает с 50% здоровья,
// модификатор "Туман" удаляется. Иначе игра заканчивается.
//
// Параметры:
//  КоличествоЗдоровья - Число - количество здоровья, которое остаётся у игрока после воскрешения.
//
&НаСервере
Процедура ВоскрешениеИгрока(КоличествоЗдоровья)
	// Очищаем все параметры игрока, кроме здоровья
	ОчиститьПараметрыИгрокаКромеБазовых();
	// Устанавливаем новое значение здоровья
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	УстановитьПараметрИгрока(ВидПараметра, КоличествоЗдоровья);
	ТекущееЗдоровьеИгрока = КоличествоЗдоровья;
КонецПроцедуры		// ВоскрешениеИгрока()

// Удаляет модификатор из таблицы Модификаторы.
//
// Параметры:
//  МодификаторВход - СправочникСсылка.Модификаторы - ссылка на модификатор, который будет удалён.
//
&НаСервере
Процедура УдалитьМодификатор(МодификаторВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Модификатор", МодификаторВход);
	НайденныеСтроки = Модификаторы.НайтиСтроки(СтруктураПоиска);
	Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
		Модификаторы.Удалить(ТекНайденныеСтроки);
	КонецЦикла;
КонецПроцедуры		// УдалитьМодификатор()

// Проверяет возможное поражение игрока. В случае поражения игра заканчивается.
//
Процедура ПроверитьПоражениеИгрока()
	ВидПараметра = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
	Если ТекущееЗдоровье <= 0 Тогда
		// Проверяем наличие модификатора "Туман"
		Если МодификаторАктивен(Справочники.Модификаторы.Туман) Тогда
			// Воскрешаем игрока с 50% от максимального здоровья
			МаксимальноеЗдоровье = ПолучитьМаксимальноеЗдоровьеИгрока();
			НовоеЗдоровье = Цел(МаксимальноеЗдоровье * 0.5);
			ВоскрешениеИгрока(НовоеЗдоровье);
			// Удаляем модификатор "Туман" из таблицы модификаторов
			УдалитьМодификатор(Справочники.Модификаторы.Туман);
			Сообщить("Туман спас вас! Вы воскресли с 50% здоровья.");
		Иначе
			// Модификатор "Туман" не активен - игра заканчивается
			Сообщить("Вы были побеждены! Игра окончена.");
			ЭтаФорма.Доступность = Ложь;
		КонецЕсли;
	Иначе
		// Игрок не побежден.
	КонецЕсли;
КонецПроцедуры		// ПроверитьПоражениеИгрока()

#КонецОбласти

#Область Карты

// Выполняет действие карты Защита.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
Процедура ДействиеКарты_Защита(КартаВход, ИдентифкаторКартыВход)
	ЗащитаКарты = 6;
	УвеличитьЩитИгрока(ЗащитаКарты);
КонецПроцедуры		// ДействиеКарты_Защита()

// Выполняет действие карты Удар.
// Наносит противнику 10 единиц урона.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Удар(КартаВход, ИдентифкаторКартыВход)
	УронКарты = 10;
	УронПротивникуПоКоличеству(УронКарты);
КонецПроцедуры		// ДействиеКарты_Удар()

// Осуществляет розыгрыш карты Адреналин.
// Карта выполняет сразу 3 действия:
// 1. Наносит 1 урон игроку;
// 2. Сбрасывает все карты из стопки РукаИгрока в стопку СтопкаСброса;
// 3. Добирает из стопки СтопкаДобора в стопку РукаИгрока пока в стопке РукаИгрока меньше 5 карт;
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Адреналин(КартаВход, ИдентифкаторКартыВход)
	// 1. Наносим 1 урон игроку
	НанестиУронИгроку(1);
	
	// 2. Сбрасываем все карты из РукаИгрока в СтопкаСброса
	Пока РукаИгрока.Количество() > 0 Цикл
		ПерваяКарта = РукаИгрока[0];
		ИдентификаторКарты = ПерваяКарта.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
	КонецЦикла;
	
	// 3. Добираем карты из СтопкаДобора в РукаИгрока пока в руке меньше 5 карт
	ДобратьРуку();
КонецПроцедуры		// ДействиеКарты_Адреналин()

// Наносит урон противнику, учитывая его щит.
// Щит поглощает урон первым, остаток урона наносится по здоровью.
//
// Параметры:
//  КоличествоУрона - Число - количество урона, которое наносится противнику.
//
// Возвращаемое значение:
//  Структура - структура с полями:
//    - УронПоЩиту - Число - количество урона, поглощённое щитом.
//    - УронПоЗдоровью - Число - количество урона, нанесённое по здоровью.
//
&НаСервере
Функция НанестиУронПротивнику(КоличествоУрона)
	// Инициализация
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	// Получение размера щита противника.
	ЗначениеЩита = ПолучитьЗначениеПараметраПротивника(ВидПараметраЩит);
	УронПоЩиту = 0;
	ОстаточныйУрон = КоличествоУрона;
	// Проверка урона по щиту.
	Если ЗначениеЩита > 0 Тогда
		Если ЗначениеЩита >= КоличествоУрона Тогда
			НовоеЗначениеЩита = ЗначениеЩита - КоличествоУрона;
			УстановитьПараметрПротивника(ВидПараметраЩит, НовоеЗначениеЩита);
			УронПоЩиту = КоличествоУрона;
			ОстаточныйУрон = 0;
		Иначе
			ОстатокУрона = КоличествоУрона - ЗначениеЩита;
			УронПоЩиту = ЗначениеЩита;
			УстановитьПараметрПротивника(ВидПараметраЩит, 0);
			ОстаточныйУрон = ОстатокУрона;
		КонецЕсли;
	Иначе
		// Щита нет, весь урон наносится по здоровью.
	КонецЕсли;
	// Наносим остаточный урон по здоровью.
	ВидПараметраЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ТекущееЗдоровье = ПолучитьЗначениеПараметраПротивника(ВидПараметраЗдоровье);
	НовоеЗдоровье = ТекущееЗдоровье - ОстаточныйУрон;
	Если НовоеЗдоровье < 0 Тогда
		НовоеЗдоровье = 0;
	КонецЕсли;
	УстановитьПараметрПротивника(ВидПараметраЗдоровье, НовоеЗдоровье);
	// Формируем и возвращаем результат.
	Результат = Новый Структура;
	Результат.Вставить("УронПоЩиту", УронПоЩиту);
	Результат.Вставить("УронПоЗдоровью", ОстаточныйУрон);
	Возврат Результат;
КонецФункции		// НанестиУронПротивнику()

// Обсуществляет розыгрыш карты КартаВход.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую нужно разыграть.
//
&НаКлиенте
Процедура РазыгратьКарту(ИдентификаторКартыВход)
	НайденнаяКарта = ПредопределенноеЗначение("Справочник.Карты.ПустаяСсылка");
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("ИдентификаторКарты", ИдентификаторКартыВход);
	НайденныеСтроки = РукаИгрока.НайтиСтроки(СтруктураПоиска);
	Для Каждого ТекНайденныеСтроки Из НайденныеСтроки Цикл
		НайденнаяКарта = ТекНайденныеСтроки.Карта;
	КонецЦикла;
	Если ЗначениеЗаполнено(НайденнаяКарта) Тогда
		Если НайденнаяКарта = ПредопределенноеЗначение("Справочник.Карты.Защита") Тогда
			ДействиеКарты_Защита(НайденнаяКарта, ИдентификаторКартыВход);
		ИначеЕсли НайденнаяКарта = ПредопределенноеЗначение("Справочник.Карты.Удар") Тогда
			ДействиеКарты_Удар(НайденнаяКарта, ИдентификаторКартыВход);
		ИначеЕсли НайденнаяКарта = ПредопределенноеЗначение("Справочник.Карты.Адреналин") Тогда
			ДействиеКарты_Адреналин(НайденнаяКарта, ИдентификаторКартыВход);
		Иначе
			Сообщить("Неизвестная карта: " + Строка(НайденнаяКарта));
		КонецЕсли;
		ПереместиКартуИзСтопки(ИдентификаторКартыВход, "РукаИгрока", "СтопкаСброса", ЭтаФорма);
	Иначе
		Сообщить("Карта " + Строка(ИдентификаторКартыВход) + " не найден.");
	КонецЕсли;
КонецПроцедуры		// РазыгратьКарту()

#КонецОбласти

&НаКлиенте
Процедура НачатьЗадание()
	Если ДостигнутКонецРаунда() Тогда
		Сообщить("Задано " + Строка(КоличествоЗаданных) + " вопросов. Верно отвечено: " + Строка(КоличествоВерных));
		ОтобразитьСледующееЗадание(Сборник);
	Иначе
		ОтобразитьСледующееЗадание(Сборник);
	КонецЕсли;
	УменьшитьПараметрыИгроков();
	УменьшитьПараметрыПротивников();
КонецПроцедуры

// Осуществляет обработку верного ответа для режима викторины Восхождение.
//
&НаКлиенте
Процедура ОбработатьВерныйОтветВосхождение()
	ДействияИгрока();
	ОтобразитьСостояниеИгрока();
	ОтобразитьСостояниеПротивника();
КонецПроцедуры		// ОбработатьВерныйОтветВосхождение()

// Фиксирует ответ пользователя номер НомерОтветаВход.
&НаКлиенте
Процедура ВыбратьВариантОтвета(НомерОтветаВход)
	// Инициализация.
	ВероятностьПодсказки = 11;
	НовыйНомерПравильногоОтвета = ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтвета, Сложность);
	ЭтоВосхождение = (РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение"));
	ЭтоВерныйОтвет = (НомерОтветаВход = НовыйНомерПравильногоОтвета);
	НовыйОпыт = 0;
	МодификаторВолчийКлык = ПредопределенноеЗначение("Справочник.Модификаторы.ВолчийКлык");
	// Обработка ответа.
	Если ЭтоВерныйОтвет Тогда
		Если ЭтоВосхождение Тогда
			ОбработатьВерныйОтветВосхождение();
		Иначе
			ОтобразитьСледующееЗадание(Сборник);
		КонецЕсли;	
		Если НЕ ОтветДан Тогда
			КоличествоВерных = КоличествоВерных + 1;
			СерияПравильных = СерияПравильных + 1;
			НовыйОпыт = 3;
			// Применяем модификатор "ВолчийКлык" при правильном ответе.
			Если ЭтоВосхождение Тогда
				Если МодификаторАктивен(МодификаторВолчийКлык) Тогда
					ПрименитьМодификатор_ВолчийКлык(Истина);
				Иначе
					// Нет модификатора, не увеличиваем Ярость.
				КонецЕсли;
			Иначе
				// Не требуется применения модифкаторов для прочих режимов.
			КонецЕсли;	
		Иначе
			// Не увеличиваем количество верных ответов.
		КонецЕсли;
	Иначе      
		СтруктураПараметров = Новый Структура;
		ВыбранноеЧисло = ГсчКлиент.СлучайноеЧисло(1, 100);
		Если (ВыбранноеЧисло < ВероятностьПодсказки) Тогда
			ТекстВопроса = НСтр("ru = 'Ответ неверный. Хотите использовать подсказку?'");
			Режим = РежимДиалогаВопрос.ДаНет;
			Оповещение = Новый ОписаниеОповещения("ПодтверждениеИспользованиеПодсказкиЗавершение", ЭтаФорма, СтруктураПараметров);
			ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
		Иначе                       
			ОбработкаНеправильногоОтвета();
		КонецЕсли;
	КонецЕсли;
	ОбработатьДостиженияВыборОтвета();
	НачислитьОпыт(НовыйОпыт, ТекПользователь);
	ЗаписатьОтветВРезультаты(Сборник, ТекПользователь, ЭтоВерныйОтвет);
КонецПроцедуры		// ВыбратьВариантОтвета()

// Преобразует номер правильного ответа ИсходныйНомерПравильногоОтветаВход
// в номер ответа на командах формы, ориентируясь на сложность сборника 
// СборникВход.
&НаКлиенте
Функция ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СложностьВход)
	РезультатФункции = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(ИсходныйНомерПравильногоОтветаВход, СложностьВход);
	Возврат РезультатФункции;
КонецФункции		// ПреобразоватьНомерПравильногоОтвета()

// Управляет видимостью элементов на форме.
&НаСервере
Процедура УправлениеВидимостью()
	// Количество ответов.
	СложностьСборника = Сборник.Сложность;
	Если (НЕ ЗначениеЗаполнено(СложностьСборника)) ИЛИ (СложностьСборника = Перечисления.СложностиСборников.ШестьОтветов) Тогда
		Элементы.ВыбратьВариант3.Видимость = Истина;
		Элементы.ВыбратьВариант6.Видимость = Истина;
	ИначеЕсли (СложностьСборника = Перечисления.СложностиСборников.ЧетыреОтвета) Тогда
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;	
	Иначе
		Элементы.ВыбратьВариант3.Видимость = Ложь;
		Элементы.ВыбратьВариант6.Видимость = Ложь;
	КонецЕсли;	
	// Не показывать пустой вопрос.
	ПустоеЗадание = (СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "" ИЛИ СокрЛП(ВыбранноеЗадание.ТекстВопросаЗадания) = "-");
	Элементы.ЗаданиеТекстВопросаЗадания.Видимость = НЕ ПустоеЗадание;
	Элементы.УбратьНевернуюПоловину.Доступность = НЕ НеверныеВариантыУбраны;
	// Скрывать подсказки для режима Восхождение.
	ЭтоРежимВосхождение = (РежимВикторины = Перечисления.РежимыВикторины.Восхождение);
	Элементы.ГруппаПодменюПодсказки.Видимость = НЕ (ЭтоРежимВосхождение);
	// Отображение информации об игре в режиме Восхождение.
	Элементы.ГруппаСтраницаОбИгре.Видимость = ЭтоРежимВосхождение;
	Если ЭтоРежимВосхождение Тогда
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	Иначе
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	КонецЕсли;
КонецПроцедуры		// УправлениеВидимостью()

// Возвращает текст вопроса задания ЗаданиеВход.
&НаСервереБезКонтекста
Функция ПолучитьТекстВопроса(ЗаданиеВход)
	РезультатФункции = ЗаданиеВход.ТекстВопросаЗадания;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьТекстВопроса()

// Возвращает массив номеров неправильных ответов, которые необходимо
// удалить для подсказки 50/50.
&НаСервере
Функция ПолучитьМассивНеправильныхОтветовКУдалению(НомерПравильногоОтветаВход, СборникВход)
	РезультатФункции = Новый Массив;
	НовыйНомерПравильногоОтвета = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(НомерПравильногоОтветаВход, Сложность);
	Если Сложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
		РезультатФункции = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 6);
	ИначеЕсли Сложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
		ВремРезультат = Обработки.ТестированиеЗнаний.ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, 4);
		Для Каждого ТекВремРезультат Из ВремРезультат Цикл
			НовыйНомер = ОбщегоНазначенияКлиентСервер.ПреобразоватьНомерПравильногоОтвета(ТекВремРезультат, Сложность);
			РезультатФункции.Добавить(НовыйНомер);
		КонецЦикла;	
	Иначе
		РезультатФункции = Новый Массив;
		ТекстСообщения = НСтр("ru = 'Неизвестный вариант сложности: %Сложность%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Сложность%", Строка(Сложность));
		Сообщить(ТекстСообщения);
	КонецЕсли;	
	Возврат РезультатФункции;
КонецФункции		// ПолучитьМассивНеправильныхОтветовКУдалению()

// Получает и выводит следующее задание на форму.
&НаКлиенте
Процедура ОтобразитьСледующееЗадание(СборникВход)
	НеверныеВариантыУбраны = Ложь;
	Элементы.ВыбратьВариант1.Доступность = Истина;
	Элементы.ВыбратьВариант2.Доступность = Истина;
	Элементы.ВыбратьВариант3.Доступность = Истина;
	Элементы.ВыбратьВариант4.Доступность = Истина;
	Элементы.ВыбратьВариант5.Доступность = Истина;
	Элементы.ВыбратьВариант6.Доступность = Истина;
	Элементы.ВыбратьВариант1.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант2.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант3.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант4.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант5.ЦветФона = Новый Цвет();
	Элементы.ВыбратьВариант6.ЦветФона = Новый Цвет();
	РезультатСмены = СледующееЗадание_Сервер(СборникВход, РежимВикторины);	
	Сборник = РезультатСмены.Сборник;
	АдресКартинки = РезультатСмены.АдресКартинки;
	КоличествоЗаданных = КоличествоЗаданных + 1;
	ОтветДан = Ложь;
	ЭтаФорма.Заголовок = Строка(Сборник);
	ДобавитьТекущуюДатуВСтек();
КонецПроцедуры

// Блокирует команды с неверными ответами по номерам массива МассивНеверных.
&НаКлиентеНаСервереБезКонтекста
Процедура УбратьНеверныеОтветы(МассивНеверных, Форма)
	Если МассивНеверных.Найти(1) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант1.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(2) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант2.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(3) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант3.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(4) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант4.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(5) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант5.Доступность = Ложь;
	КонецЕсли;
	Если МассивНеверных.Найти(6) <> Неопределено Тогда
		Форма.Элементы.ВыбратьВариант6.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры		// УбратьНеверныеОтветы()

// Добавляет в стек ДатыОтветов текущую дату
&НаКлиенте
Процедура ДобавитьТекущуюДатуВСтек()
	РазмерСтекаДат = 20;
	ТекДата = ТекущаяДата();
	НовыйСписокДаты = Новый СписокЗначений;
	НовыйСписокДаты.Добавить(ТекДата);
	Если ДатыОтветов.Количество() < РазмерСтекаДат Тогда
		Для Каждого ТекДатыОтветов Из ДатыОтветов Цикл
			НовыйСписокДаты.Добавить(ТекДатыОтветов.Значение);
		КонецЦикла;	
	Иначе
		Для Счетчик = 0 По РазмерСтекаДат - 2 Цикл
			ТекДатыОтветов = ДатыОтветов.Получить(Счетчик);
			НовыйСписокДаты.Добавить(ТекДатыОтветов.Значение);
		КонецЦикла;
	КонецЕсли;
	МассивДат = НовыйСписокДаты.ВыгрузитьЗначения();
	ДатыОтветов.ЗагрузитьЗначения(МассивДат);
КонецПроцедуры		// ДобавитьТекущуюДатуВСтек()

// Выполняет удаление половины неправильных ответов на вопрос.
&НаКлиенте
Процедура ОбработкаУбратьНевернуюПоловину()
	МассивНеверных = ПолучитьМассивНеправильныхОтветовКУдалению(НомерПравильногоОтвета, Сборник);
	УбратьНеверныеОтветы(МассивНеверных, ЭтаФорма);
	НеверныеВариантыУбраны = Истина;
	УправлениеВидимостью();
КонецПроцедуры		// ОбработкаУбратьНевернуюПоловину()

&НаКлиенте
Процедура НастройкиВикторины_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		ТекПользователь		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Пользователь", ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка"));
		НовыйСборник		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Сборник", ПредопределенноеЗначение("Справочник.Сборники.ПустаяСсылка"));
		РежимВикторины		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "РежимВикторины", ПредопределенноеЗначение("Перечисление.РежимыВикторины.ОдинСборникБезОстановки"));
		ВыбранныеСборники	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "ВыбранныеСборники", Новый СписокЗначений);
		Если НовыйСборник <> Сборник Тогда
			Сборник = НовыйСборник;
			УправлениеВидимостью();
			КоличествоВерных = 0;
			КоличествоЗаданных = 0;
			ОтобразитьСледующееЗадание(Сборник);
		Иначе
			// Сборник не изменился. Не отображаем новый вопрос.
		КонецЕсли;
	Иначе
		// Не изменяем значения настроек.
	КонецЕсли;
КонецПроцедуры		// НастройкиВикторины_Завершение()

// Добавляет модификаторы по умолчанию в таблицу Модификаторы.
//
&НаСервере
Процедура ЗагрузитьМодификаторыПоУмолчанию()
	Модификаторы.Очистить();
	// Загрузим один положительный и один отрицательный модификатор.
	ПоложительныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Истина, Гсч);
	Если ЗначениеЗаполнено(ПоложительныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ПоложительныйМодификатор;
	Иначе
		// Положительный модификатор не найден.
	КонецЕсли;
	ОтрицательныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Ложь, Гсч);
	Если ЗначениеЗаполнено(ОтрицательныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ОтрицательныйМодификатор;
	Иначе
		// Отрицательный модификатор не найден.
	КонецЕсли;
КонецПроцедуры		// ЗагрузитьМодификаторыПоУмолчанию()

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Инициализация.
	КоличествоВерных = 0;	
	КоличествоЗаданных = 0;
	СерияПравильных = 0;
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	// Считывание параметров.
	Если ЗначениеЗаполнено(Параметры.Сборник) Тогда
		Сборник = Параметры.Сборник;
	Иначе
		// Параметры не переданы. Не требуется обновлять сборник.
	КонецЕсли;
	ВыбранныеСборники = Параметры.ВыбранныеСборники;
	// Считвание констант.
	КоличествоЗаданийВРаунде = Константы.КоличествоЗаданийВРаунде.Получить();
	Если НЕ ЗначениеЗаполнено(КоличествоЗаданийВРаунде) Тогда
		КоличествоЗаданийВРаунде = 100;
	Иначе
		// Значение установлено.
	КонецЕсли;
	ВероятностьПовтораНеправильного = Константы.ВероятностьПовтораНеправильного.Получить();
	// Инициализация игры для режима "Восхождение"
	Если РежимВикторины = Перечисления.РежимыВикторины.Восхождение Тогда
		ИнициализироватьРежимВосхождение();
	Иначе
		// Для прочих вариантов не инициализируем.
	КонецЕсли;
	// Управление видимостью.
	УправлениеВидимостью();
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВариант1(Команда)
	ВыбратьВариантОтвета(1);
КонецПроцедуры

