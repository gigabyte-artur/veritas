&НаКлиенте
Процедура ВыборПользователя_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
    Если ВыбранноеЗначение <> Неопределено Тогда
        ТекПользователь = ВыбранноеЗначение;
		ОтобразитьСледующееЗадание(Сборник);
	Иначе
		Если ЭтаФорма.Открыта() Тогда
			ЭтаФорма.Закрыть();
		Иначе
		КонецЕсли;
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВводНачальныхНастроек_Завершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	// Инициализация.
	ПустойПользователь		 = ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка");
	ПустойРежимВикторины	 = ПредопределенноеЗначение("Перечисление.РежимыВикторины.ПустаяСсылка");
	ПустойСборник			 = ПредопределенноеЗначение("Справочник.Сборники.ПустаяСсылка");
	РежимВикториныВосхождение = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение");  
	// Получим данные из оповещения.
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		Пользователь		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Пользователь", ПустойПользователь);
		РежимВикторины		 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "РежимВикторины", ПустойРежимВикторины);
		Сборник				 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "Сборник", ПустойСборник);
		ВыбранныеСборники	 = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВыбранноеЗначение, "ВыбранныеСборники", Новый СписокЗначений);
	Иначе
		Пользователь		 = ПустойПользователь;
		РежимВикторины		 = ПустойРежимВикторины;
		Сборник				 = ПустойСборник;
		ВыбранныеСборники	 = Новый СписокЗначений;
	КонецЕсли;
	// Модификаторы, загружаем только в режиме восхождения.
	ЭтоРежимВосхождение = (РежимВикторины = РежимВикториныВосхождение);
	Если ЭтоРежимВосхождение Тогда
		ИнициализироватьРежимВосхождение();
	Иначе
		Модификаторы.Очистить();
	КонецЕсли;
	// Отобразим задание из выбранного сборника.
	Если ЗначениеЗаполнено(Сборник) Тогда
		ОтобразитьСледующееЗадание(Сборник);
	Иначе
		// Сборник не выбран.
	КонецЕсли;	
КонецПроцедуры		// ВводНачальныхНастроек_Завершение()

