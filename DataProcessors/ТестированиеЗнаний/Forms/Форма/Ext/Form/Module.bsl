// Определяет, достигнут ли конец раунда при включенном режиме.
&НаКлиенте
Функция ДостигнутКонецРаунда()
	РезультатФункции = Ложь;
	ЭтоРежимИспытание = (РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Испытание"));
	ДостигнутПределЗаданных = (КоличествоЗаданных >= КоличествоЗаданийВРаунде);
	РезультатФункции = (ЭтоРежимИспытание И ДостигнутПределЗаданных);
	Возврат РезультатФункции;
КонецФункции		// ДостигнутКонецРаунда()

// Изменяет фон у команды ответа сборника СборникВход с номером 
// НомерОтветаВход.
&НаКлиенте
Процедура ПодсветитьПравильныйОтвет(НомерОтветаВход, СборникВход)
	ВыбранныйЭлемент = Неопределено;
	Сложность = ОбщегоНазначенияВызовСервера.ПолучитьЗначениеРеквизита(СборникВход, "Сложность");
	Если Сложность = ПредопределенноеЗначение("Перечисление.СложностиСборников.ШестьОтветов") Тогда
		Если НомерОтветаВход = 1 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант1;
		ИначеЕсли НомерОтветаВход = 2 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант2;
		ИначеЕсли НомерОтветаВход = 3 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант3;
		ИначеЕсли НомерОтветаВход = 4 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант4;
		ИначеЕсли НомерОтветаВход = 5 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант5;
		ИначеЕсли НомерОтветаВход = 6 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант6;
		Иначе
			ВыбранныйЭлемент = Неопределено;
		КонецЕсли;
	ИначеЕсли Сложность = ПредопределенноеЗначение("Перечисление.СложностиСборников.ЧетыреОтвета") Тогда
		Если НомерОтветаВход = 1 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант1;
		ИначеЕсли НомерОтветаВход = 2 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант2;
		ИначеЕсли НомерОтветаВход = 3 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант4;
		ИначеЕсли НомерОтветаВход = 4 Тогда
			ВыбранныйЭлемент = Элементы.ВыбратьВариант5;
		Иначе
			ВыбранныйЭлемент = Неопределено;
		КонецЕсли;
	Иначе
		ВыбранныйЭлемент = Неопределено;
	КонецЕсли;
	Если ВыбранныйЭлемент <> Неопределено Тогда
		ВыбранныйЭлемент.ЦветФона = WebЦвета.СветлоНебесноГолубой;
	Иначе
		Сообщить(НСтр("ru = 'Не удалось определить элемент для подстветки привильного ответа'"));
	КонецЕсли;
КонецПроцедуры		// ПодсветитьПравильныйОтвет()

// Устанавливает достижения, привязанные к выбору правильного ответа.
&НаКлиенте
Процедура ОбработатьДостиженияВыборОтвета()
	ДостижениеСтоОтветов(КоличествоЗаданных);
	ДостижениеТридцатьБезОшибок(КоличествоВерных);
	ДостижениеСерияДвадцатьПравильных(СерияПравильных);
	ДостижениеДвадцатьВопросовЗаШестьдесятСекунд(ДатыОтветов.ВыгрузитьЗначения());
КонецПроцедуры		// ОбработатьДостиженияВыборОтвета()

// Вызывается при окончании обработки неправильного ответа.
&НаКлиенте
Процедура ОбработкаНеправильногоОтвета()
	// Инициализация.
	ЭтоРежимВосхождения = (РежимВикторины = ПредопределенноеЗначение("Перечисление.РежимыВикторины.Восхождение"));
	Если НЕ ОтветДан Тогда
		НовыйОпыт = 1;
		ПоказатьПредупреждение(, "Правильный ответ №" + Строка(НомерПравильногоОтвета), 15);
		ПодсветитьПравильныйОтвет(НомерПравильногоОтвета, Сборник);
		Если ЭтоРежимВосхождения Тогда
			ДействияПротивника();
			ОтобразитьСледующееЗадание(Сборник);
		Иначе
			// Подсветим правильный ответ.
			ОтветДан = Истина;
			СерияПравильных = 0;
			// Добавим задание в таблицу к повтору.
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Вопрос", ВыбранноеЗадание);
			НайденныеСтроки = ВопросыКПовторениям.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтроки.Количество() = 0 Тогда
				НоваяСтрока = ВопросыКПовторениям.Добавить();
				НоваяСтрока.Вопрос = ВыбранноеЗадание;
			Иначе
				// Вопрос уже присутсвует.
			КонецЕсли;	
		КонецЕсли;
	Иначе
		НовыйОпыт = 0;
	КонецЕсли;
КонецПроцедуры		// ОбработкаНеправильногоОтвета()

&НаКлиенте
Процедура ПодтверждениеИспользованиеПодсказкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработкаУбратьНевернуюПоловину();
	Иначе
		ОбработкаНеправильногоОтвета();
	КонецЕсли;
КонецПроцедуры		// ПодтверждениеИспользованиеПодсказкиЗавершение()

