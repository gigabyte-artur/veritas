&НаСервере
Перем Гсч;		// Генератор случайных чисел.

&НаКлиенте
Перем ГсчКлиент;

// Возвращает признак активности модификатора МодификаторВход в таблице Модификаторы.
//
// Параметры:
//  МодификаторВход - СправочникСсылка.Модификаторы - модификатор для проверки.
//
// Возвращаемое значение:
//  Булево - Истина, если модификатор активен, Ложь в противном случае.
//
&НаСервере
Функция МодификаторАктивен(МодификаторВход)
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Модификатор", МодификаторВход);
	НайденныеСтроки = Модификаторы.НайтиСтроки(СтруктураПоиска);
	Возврат НайденныеСтроки.Количество() > 0;
КонецФункции		// МодификаторАктивен()

// Помещает картинку задания ЗаданиеВход во временное хранилище и 
// возвращает его адрес.
&НаСервере
Функция ВернутьАдресКартинки(ЗаданиеВход)
	РезультатФункции = "";
	КартинкаХранилище = ЗаданиеВход.КартинкаЗадания;
	КартинкаЗначение = КартинкаХранилище.Получить();
	Если КартинкаЗначение <> Неопределено Тогда
		РезультатФункции = ПоместитьВоВременноеХранилище(КартинкаЗначение, ЭтаФорма);
	Иначе
		Сборник = ЗаданиеВход.Владелец;
		КартинкаХранилище = Сборник.КартинкаСборника;
		КартинкаЗначение = КартинкаХранилище.Получить();
		Если КартинкаЗначение <> Неопределено Тогда
			РезультатФункции = ПоместитьВоВременноеХранилище(КартинкаЗначение, ЭтаФорма);
		Иначе
			// Картинка не задана. Не загружаем.
		КонецЕсли;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ВернутьАдресКартинки()

// Возвращает структуру данных для задания ЗаданиеВход.
&НаСервере
Функция ПолучитьВариантыОтветов(ЗаданиеВход)
	// Инициализация.
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("НомерПравильного", 0);
	РезультатФункции.Вставить("МассивОтветов", Новый Массив);
	ВыгрузкаОтветов = ЗаданиеВход.ОтветыЗаданий.Выгрузить();
	КоличествоОтветов = 6;
	Если Сборник.Сложность = Перечисления.СложностиСборников.ШестьОтветов Тогда
		КоличествоОтветов = 6;
	ИначеЕсли Сборник.Сложность = Перечисления.СложностиСборников.ЧетыреОтвета Тогда
		КоличествоОтветов = 4;
	Иначе
		КоличествоОтветов = 6;
	КонецЕсли;
	// Поиск правильного ответа.
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Правильность", Истина);
	НайденныеСтроки = ВыгрузкаОтветов.НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() = 1 Тогда
		ПравильныйОтветСтрока = НайденныеСтроки[0];
		ПравильныйОтветТекст = ПравильныйОтветСтрока.ТекстОтвета;
		// Добавление неправильных ответов.
		МассивНеправильных = Новый Массив;
		ТекСборник = ЗаданиеВход.Владелец;
		Если ТекСборник.БратьОтветыИзТекущегоСборника Тогда
			// Ответы берутся только из текущего вопроса.
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаданияОтветыЗаданий.ТекстОтвета,
			|	ЗаданияОтветыЗаданий.Правильность
			|ИЗ
			|	Справочник.Задания.ОтветыЗаданий КАК ЗаданияОтветыЗаданий
			|ГДЕ
			|	ЗаданияОтветыЗаданий.Ссылка = &Ссылка
			|	И НЕ ЗаданияОтветыЗаданий.Ссылка.ПометкаУдаления
			|	И НЕ ЗаданияОтветыЗаданий.Правильность";
			Запрос.УстановитьПараметр("Ссылка", ЗаданиеВход);
			РезультатЗапроса = Запрос.Выполнить();
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				МассивНеправильных.Добавить(ВыборкаДетальныеЗаписи.ТекстОтвета);
			КонецЦикла;
		Иначе
			// Ответы берутся из всех вопросов.
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЗаданияОтветыЗаданий.ТекстОтвета
			|ИЗ
			|	Справочник.Задания.ОтветыЗаданий КАК ЗаданияОтветыЗаданий
			|ГДЕ
			|	ЗаданияОтветыЗаданий.ТекстОтвета <> &ТекстОтвета
			|	И НЕ ЗаданияОтветыЗаданий.Ссылка.ПометкаУдаления
			|	И ЗаданияОтветыЗаданий.Ссылка.Владелец = &Владелец";
			Запрос.УстановитьПараметр("Владелец", ЗаданиеВход.Владелец);
			Запрос.УстановитьПараметр("ТекстОтвета", ПравильныйОтветТекст);
			РезультатЗапроса = Запрос.Выполнить();
			ВыгрузкаНеправильных = РезультатЗапроса.Выгрузить();
			МассивВыгрузка = ВыгрузкаНеправильных.ВыгрузитьКолонку("ТекстОтвета");
			ВсегоНеправильных = МассивВыгрузка.Количество();
			ВерхняяГраница = 1;
			Если МассивВыгрузка.Количество() >= (КоличествоОтветов - 1) Тогда
				ВерхняяГраница = (КоличествоОтветов - 1);
			Иначе
				ВерхняяГраница = МассивВыгрузка.Количество();
			КонецЕсли;
			Для Счетчик = 1 По ВерхняяГраница Цикл
				НомерОтвета = Гсч.СлучайноеЧисло(0, ВсегоНеправильных-1);
				МассивНеправильных.Добавить(МассивВыгрузка[НомерОтвета]);
			КонецЦикла;
		КонецЕсли;
		МассивНеправильных.Добавить(ПравильныйОтветТекст);
		// Перемешивание итогового массива и формирование результата.
		МассивНеправильных = ОбщегоНазначенияКлиентСервер.СмешатьМассив(МассивНеправильных, Гсч);
		ПравильныйОтветНомер = МассивНеправильных.Найти(ПравильныйОтветТекст);
		Если ПравильныйОтветНомер <> Неопределено Тогда
			РезультатФункции.Вставить("НомерПравильного", ПравильныйОтветНомер + 1);
			РезультатФункции.Вставить("МассивОтветов", МассивНеправильных);
		Иначе
			РезультатФункции.Вставить("НомерПравильного", 0);
			РезультатФункции.Вставить("МассивОтветов", Новый Массив);
		КонецЕсли;
	Иначе
		// Не удалось однозначно определить правильный ответ.
		РезультатФункции.Вставить("НомерПравильного", 0);
		РезультатФункции.Вставить("МассивОтветов", Новый Массив);
	КонецЕсли;
	// Вывод результата.
	Возврат РезультатФункции;
КонецФункции		// ПолучитьВариантыОтветов()

&НаСервере
Процедура ЗагрузитьОтветВЭлемент(МассивОтветовВход, НомерОтветаВход, ЭлементВход)
	Если МассивОтветовВход.Количество() > НомерОтветаВход Тогда
		ЭлементВход.Заголовок = Строка(НомерОтветаВход + 1) + ": " + СокрЛП(МассивОтветовВход[НомерОтветаВход]);
	Иначе	
		ЭлементВход.Заголовок = "---";
	КонецЕсли;
КонецПроцедуры

