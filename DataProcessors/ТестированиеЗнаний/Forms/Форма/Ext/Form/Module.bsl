// Возвращает случайное задание, заготовленное к повтору
&НаСервере
Функция ВернутьВопросКПовтору()
	РезультатФункции = Новый Структура;
	ВерхняяГраница = ВопросыКПовторениям.Количество();
	Если ВерхняяГраница > 0 Тогда
		ВыбранныйИндекс = ГСЧ.СлучайноеЧисло(0, ВерхняяГраница-1);
		СтрокаВопроса = ВопросыКПовторениям[ВыбранныйИндекс];
		НовоеЗадание = СтрокаВопроса.Вопрос;
		ЗагрузитьЗадание(НовоеЗадание);
		НовыйАдресКартинки = ВернутьАдресКартинки(НовоеЗадание);
		РезультатФункции.Вставить("Сборник", НовоеЗадание.Владелец);
		РезультатФункции.Вставить("Задание", НовоеЗадание);
		РезультатФункции.Вставить("АдресКартинки", НовыйАдресКартинки);
		ВопросыКПовторениям.Удалить(СтрокаВопроса);
	Иначе
		РезультатФункции = Новый Структура;
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		 // ВернутьВопросКПовтору()

// Загружает случайное задание из сборника СборникВход
// в режиме викторины РежимВикториныВход. Возвращает структуру, 
// содержащую данные по заданию.
&НаСервере
Функция СледующееЗадание_Сервер(СборникВход, РежимВикториныВход = Неопределено)
	РезультатФункции = Новый Структура;
	ВыбранноеЧисло = Гсч.СлучайноеЧисло(1, 100);
	Если (ВыбранноеЧисло < ВероятностьПовтораНеправильного) И (ВопросыКПовторениям.Количество() > 0) Тогда
		РезультатФункции = ВернутьВопросКПовтору();
	Иначе
		Если РежимВикториныВход = Перечисления.РежимыВикторины.ОдинСборникБезОстановки Тогда
			РезультатФункции = ПолучитьДанныеЗаданияПоСборнику(СборникВход);
		ИначеЕсли РежимВикториныВход = Перечисления.РежимыВикторины.СлучайныйСборник Тогда
			НовыйСборник = Обработки.ТестированиеЗнаний.ПолучитьСлучайныйСборник(ВыбранныеСборники, ГСЧ);
			Сборник = НовыйСборник;
			РезультатФункции = ПолучитьДанныеЗаданияПоСборнику(НовыйСборник);
		ИначеЕсли РежимВикториныВход = Перечисления.РежимыВикторины.Восхождение Тогда
			НовыйСборник = Обработки.ТестированиеЗнаний.ПолучитьСлучайныйСборник(ВыбранныеСборники, ГСЧ);
			Сборник = НовыйСборник;
			РезультатФункции = ПолучитьДанныеЗаданияПоСборнику(НовыйСборник);		
		Иначе
			РезультатФункции = ПолучитьДанныеЗаданияПоСборнику(СборникВход);	
		КонецЕсли;
	КонецЕсли;
	УправлениеВидимостью();
	Возврат РезультатФункции;
КонецФункции		// СледующееЗадание_Сервер()

// Устанавливает достижение Сто вопросов отвечено.
&НаСервереБезКонтекста
Процедура ДостижениеСтоОтветов(КоличествоЗаданныхВход)
	Если ДостиженияКлиентСервер.ЕстьДостижениеСтоОтветов(КоличествоЗаданныхВход) Тогда
		ТекПользователь = ОбщегоНазначенияВызовСервера.ТекущийПользователь();
		ОбщегоНазначенияВызовСервера.ПроверитьИВыдатьДостижениеПользователю(ТекПользователь, Перечисления.Достижения.СтоВопросовСыграно);
	Иначе
		// Критерий не пройден. Не добаляем достижение.
	КонецЕсли;
КонецПроцедуры		// ДостижениеСтоОтветов()

// Устанавливает достижение Тридцать правильных ответов.
&НаКлиенте
Процедура ДостижениеТридцатьБезОшибок(КоличествоВерныхВход)
	Если КоличествоВерныхВход >= 30 Тогда
		ТекПользователь = ОбщегоНазначенияВызовСервера.ТекущийПользователь();
		ВыбранноеДостижение = ПредопределенноеЗначение("Перечисление.Достижения.ТридцатьВопросовБезОшибок");
		ОбщегоНазначенияВызовСервера.ПроверитьИВыдатьДостижениеПользователю(ТекПользователь, ВыбранноеДостижение);
	Иначе
		// Критерий не пройден. Не добаляем достижение.
	КонецЕсли;
КонецПроцедуры		// ДостижениеТридцатьБезОшибок()

// Устанавливает достижение Серия двадцать.
&НаКлиенте
Процедура ДостижениеСерияДвадцатьПравильных(СерияВерныхВход)
	Если СерияВерныхВход >= 20 Тогда
		ТекПользователь = ОбщегоНазначенияВызовСервера.ТекущийПользователь();
		ВыбранноеДостижение = ПредопределенноеЗначение("Перечисление.Достижения.СерияДвадцатьПравильных");
		ОбщегоНазначенияВызовСервера.ПроверитьИВыдатьДостижениеПользователю(ТекПользователь, ВыбранноеДостижение);
	Иначе
		// Критерий не пройден. Не добаляем достижение.
	КонецЕсли;
