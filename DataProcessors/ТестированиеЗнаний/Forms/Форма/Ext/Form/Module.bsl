КонецПроцедуры		// УдалитьПараметрИгрока()

// Увеличивает значение параметра игрока на указанное приращение.
// Используется для увеличения параметров (например, Проклятие, Бомба, Неуклюжесть).
//
// Параметры:
//  ВидПараметраВход - ПеречислениеСсылка.ВидыПараметровИгроков - вид параметра для увеличения.
//  ПриращениеВход - Число - значение, на которое увеличивается параметр.
//  ИдентификаторДействияПротивникаВход - Строка - идентификатор текущего действия противника (необязательный).
//
&НаСервере
Процедура УвеличитьПараметрИгрока(ВидПараметраВход, ПриращениеВход, ИдентификаторДействияПротивникаВход = "")
	ТекущееЗначение = ПолучитьЗначениеПараметраИгрока(ВидПараметраВход);
	НовоеЗначение = ТекущееЗначение + ПриращениеВход;
	УстановитьПараметрИгрока(ВидПараметраВход, НовоеЗначение, ИдентификаторДействияПротивникаВход);
КонецПроцедуры		// УвеличитьПараметрИгрока()

// Уменьшает значения уменьшаемых параметров игрока на 1 за ход.
// Использует функцию перечисления ВидыПараметровИгроков.ПолучитьУменьшаемыеПараметрыИгроков().
// При достижении значения параметра "Бомба" 0 или ниже - наносится урон игроку.
&НаСервере
Процедура УменьшитьПараметрыИгроков()
	УменьшаемыеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьУменьшаемыеПараметрыИгроков();
	Для каждого ВидПараметра Из УменьшаемыеПараметры Цикл
		ЗначениеПараметра = ПолучитьЗначениеПараметраИгрока(ВидПараметра);
		Если ЗначениеПараметра > 0 Тогда
			НовоеЗначение = ЗначениеПараметра - 1;
			Если НовоеЗначение <= 0 Тогда
				УдалитьПараметрИгрока(ВидПараметра);
			Иначе
				УстановитьПараметрИгрока(ВидПараметра, НовоеЗначение);
			КонецЕсли;
			// Проверка параметра "Бомба": если значение стало 0 или ниже - наносим урон
			Если ВидПараметра = Перечисления.ВидыПараметровИгроков.Бомба Тогда
				ПроверитьБомбу(НовоеЗначение);
			Иначе
				// Параметр не бомба, просто уменьшаем
			КонецЕсли;
		Иначе
			// Значение параметра уже 0 или меньше, пропускаем
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры		// УменьшитьПараметрыИгроков()

// Уменьшает значения уменьшаемых параметров противника на 1 за ход.
// Использует функцию перечисления ВидыПараметровИгроков.ПолучитьУменьшаемыеПараметрыИгроков().
&НаСервере
Процедура УменьшитьПараметрыПротивников()
	УменьшаемыеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьУменьшаемыеПараметрыИгроков();
	Для каждого ВидПараметра Из УменьшаемыеПараметры Цикл
		ЗначениеПараметра = ПолучитьЗначениеПараметраПротивника(ВидПараметра);
		Если ЗначениеПараметра > 0 Тогда
			НовоеЗначение = ЗначениеПараметра - 1;
			Если НовоеЗначение <= 0 Тогда
				УдалитьПараметрПротивника(ВидПараметра);
			Иначе
				УстановитьПараметрПротивника(ВидПараметра, НовоеЗначение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры		// УменьшитьПараметрыПротивников()

// Инициализирует энергию игрока.
// 
&НаСервере
Процедура ИнициализироватьЭнергиюИгрока()
	ВидПараметраЭнергия = Перечисления.ВидыПараметровИгроков.Энергия;
	НачальнаяЭнергия = 3;
	УстановитьПараметрИгрока(ВидПараметраЭнергия, НачальнаяЭнергия);
КонецПроцедуры		// ИнициализироватьЭнергиюИгрока()
	
// Осуществляет инициализацию игрока.
&НаСервере
Процедура ИнициализироватьИгрока()
	// Инициализация параметров игрока
	ПараметрыИгрока.Очистить();
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ВидПараметраЩит = Перечисления.ВидыПараметровИгроков.Щит;
	ЗначениеЗдоровья = НачальноеЗдоровьеИгрокаПоУмолчанию();
	УстановитьПараметрИгрока(ВидПараметраТекущееЗдоровье, ЗначениеЗдоровья);
	УстановитьПараметрИгрока(ВидПараметраМаксимальноеЗдоровье, ЗначениеЗдоровья);
	// Инициализация щита игрока нулевым значением
	УстановитьПараметрИгрока(ВидПараметраЩит, 0);
	// Инициализация золота игрока значением 100
	ВидПараметраЗолото = Перечисления.ВидыПараметровИгроков.Золото;
	УстановитьПараметрИгрока(ВидПараметраЗолото, 100);
	// Считывание значений здоровья из таблицы параметров и размещение в реквизиты формы
	ТекущееЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеИгрока = ПолучитьЗначениеПараметраИгрока(ВидПараметраМаксимальноеЗдоровье);
	// Инициализация колоды игрока
	ИнициализироватьКолодуИгрока();
	// Инициализация энергии.
	ИнициализироватьЭнергиюИгрока();
	// Инициализация стопки добора игрока
	ИнициализироватьСтопкуДобораИгрока();
	// Перемешивание стопки добора
	ПеремешатьСтопку(СтопкаДобора);
	// Добор карт в руку
	ДобратьРуку();
КонецПроцедуры		// ИнициализироватьИгрока()

// Копирует все строки из таблицы КолодаИгрока в таблицу СтопкаДобора.
&НаСервере
Процедура ИнициализироватьСтопкуДобораИгрока()
	СтопкаДобора.Очистить();
	Для Каждого СтрокаКолоды Из КолодаИгрока Цикл
		НоваяСтрока = СтопкаДобора.Добавить();
		НоваяСтрока.Карта = СтрокаКолоды.Карта;
		НоваяСтрока.ИдентификаторКарты = СтрокаКолоды.ИдентификаторКарты;
	КонецЦикла;
КонецПроцедуры		// ИнициализироватьСтопкуДобораИгрока()

// Очищает список КолодаИгрока и заполняет его предопределенными картами.
&НаСервере
Процедура ИнициализироватьКолодуИгрока()
	// Инициализация.
	КолодаИгрока.Очистить();
	КартаЗащита		 = Справочники.Карты.Защита;
	КартаУдар		 = Справочники.Карты.Удар;
	КартаАдреналин	 = Справочники.Карты.Адреналин;
	// Добавляем 5 карт "Защита"
	Для Счетчик = 1 По 5 Цикл
		НоваяСтрока = КолодаИгрока.Добавить();
		НоваяСтрока.Карта = КартаЗащита;
		НоваяСтрока.ИдентификаторКарты = Строка(Новый УникальныйИдентификатор());
	КонецЦикла;
	// Добавляем 4 карты "Удар"
	Для Счетчик = 1 По 4 Цикл
		НоваяСтрока = КолодаИгрока.Добавить();
		НоваяСтрока.Карта = КартаУдар;
		НоваяСтрока.ИдентификаторКарты = Строка(Новый УникальныйИдентификатор());
	КонецЦикла;
	// Добавляем 1 карту "Адреналин"
	Для Счетчик = 1 По 1 Цикл
		НоваяСтрока = КолодаИгрока.Добавить();
		НоваяСтрока.Карта = КартаАдреналин;
		НоваяСтрока.ИдентификаторКарты = Строка(Новый УникальныйИдентификатор());
	КонецЦикла;
КонецПроцедуры		// ИнициализироватьКолодуИгрока()

// Перемешивает таблицу-стопку карт ТаблицаИзм.
//
// Параметры:
//	ТаблицаИзм - ТаблицаФормы - Таблица, которую нужно перемешать.
//
&НаСервере
Процедура ПеремешатьСтопку(ТаблицаИзм)
	ВременнаяТаблица = ТаблицаИзм.Выгрузить();
	ВременнаяТаблица.Колонки.Добавить("НомерКарты");
	Для Каждого ТекВременнаяТаблица Из ВременнаяТаблица Цикл
		ТекВременнаяТаблица.НомерКарты = ГСЧ.СлучайноеЧисло(0, 9999);
	КонецЦикла;
	ВременнаяТаблица.Сортировать("НомерКарты возр");
	ТаблицаИзм.Очистить();
	ТаблицаИзм.Загрузить(ВременнаяТаблица);
КонецПроцедуры		// ПеремешатьСтопку()

// Перемещает все карты из стопки СтопкаСброса в стопку СтопкаДобора,
// после чего перемешивает стопку СтопкаДобора.
//
&НаСервере
Процедура ПеремешатьСбросВДобор()
	// Перемещаем все карты из СтопкаСброса в СтопкаДобора
	Пока СтопкаСброса.Количество() > 0 Цикл
		ПерваяКарта = СтопкаСброса[0];
		ИдентификаторКарты = ПерваяКарта.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "СтопкаСброса", "СтопкаДобора", ЭтаФорма);
	КонецЦикла;
	// Перемешиваем стопку добора
	ПеремешатьСтопку(СтопкаДобора);
КонецПроцедуры		// ПеремешатьСбросВДобор()

// Перемещает карту с указанным ИдентификаторКарты из стопки-источника в стопку-приёмник.
//
// Параметры:
//  ИдентификаторКарты - УникальныйИдентификатор - идентификатор карты для перемещения.
//  СтопкаИсточник - ТаблицаФормы - таблица, из которой будет удалена карта.
//  СтопкаПриёмник - ТаблицаФормы - таблица, в которую будет добавлена копия карты.
//
&НаКлиентеНаСервереБезКонтекста
Процедура ПереместиКартуИзСтопки(ИдентификаторКарты, СтопкаИсточникИмя, СтопкаПриемникИмя, Форма)
	СтруктураПоиска = Новый Структура("ИдентификаторКарты", ИдентификаторКарты);
	НайденныеСтроки = Форма[СтопкаИсточникИмя].НайтиСтроки(СтруктураПоиска);
	Если НайденныеСтроки.Количество() > 0 Тогда
		СтрокаКарты = НайденныеСтроки[0];
		// Добавляем копию карты в стопку-приёмник
		НоваяСтрока = Форма[СтопкаПриемникИмя].Добавить();
		НоваяСтрока.Карта = СтрокаКарты.Карта;
		НоваяСтрока.ИдентификаторКарты = СтрокаКарты.ИдентификаторКарты;
		// Удаляем карту из стопки-источника
		Форма[СтопкаИсточникИмя].Удалить(СтрокаКарты);
	Иначе
		// Нет карты в споке-источнике. Ничего не делаем.
	КонецЕсли;
КонецПроцедуры		// ПереместиКартуИзСтопки()

// Добирает карты из стопки добора в руку игрока, пока в руке меньше 5 карт.
// Использует метод ПереместиКартуИзСтопки() для перемещения карт.
//
&НаСервере
Процедура ДобратьРуку()
	Пока РукаИгрока.Количество() < 5 И СтопкаДобора.Количество() > 0 Цикл
		ПерваяКарта = СтопкаДобора[0];
		ИдентификаторКарты = ПерваяКарта.ИдентификаторКарты;
		ПереместиКартуИзСтопки(ИдентификаторКарты, "СтопкаДобора", "РукаИгрока", ЭтаФорма);
	КонецЦикла;
КонецПроцедуры		// ДобратьРуку()

// Осуществляет инициализацию противника.
//
// Параметры:
//  ПротивникВход - СправочникСсылка.Противники - противник для инициализации (необязательный).
//                  Если не задан (Неопределено), будет загружен случайный противник.
//
&НаСервере
Процедура ИнициализироватьПротивника(ПротивникВход = Неопределено)
	ПараметрыПротивника.Очистить();
	Если ПротивникВход = Неопределено Тогда
		ЗагрузитьПротивника();
	Иначе
		Противник = ПротивникВход;
	КонецЕсли;
	ЗагрузитьЦиклДействийПротивника(Противник);
	// Установка идентификатора текущего действия противника
	Если ЦиклДействийПротивника.Количество() > 0 Тогда
		ИдентификаторТекущегоДействияПротивника = ЦиклДействийПротивника[0].ИдентификаторСтроки;
	Иначе
		Сообщить("У противника " + Строка(Противник) + " не задан цикл действий");
		ИдентификаторТекущегоДействияПротивника = "";
	КонецЕсли;
	// Инициализация параметров противника
	ВидПараметраТекущееЗдоровье = Перечисления.ВидыПараметровИгроков.ТекущееЗдоровье;
	ВидПараметраМаксимальноеЗдоровье = Перечисления.ВидыПараметровИгроков.МаксимальноеЗдоровье;
	ЗначениеЗдоровья = Противник.МаксимальноеЗдоровье;
	// Применение модификатора "Подсечка": уменьшение максимального здоровья на 10%
	Если МодификаторАктивен(Справочники.Модификаторы.Подсечка) Тогда
		ЗначениеЗдоровья = Цел(ЗначениеЗдоровья * 0.9);
	Иначе
		// Оставляем здоровье противника.
	КонецЕсли;
	УстановитьПараметрПротивника(ВидПараметраТекущееЗдоровье, ЗначениеЗдоровья);
	УстановитьПараметрПротивника(ВидПараметраМаксимальноеЗдоровье, ЗначениеЗдоровья);
	// Считывание значений здоровья из таблицы параметров и размещение в реквизиты формы
	ТекущееЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраТекущееЗдоровье);
	МаксимальноеЗдоровьеПротивника = ПолучитьЗначениеПараметраПротивника(ВидПараметраМаксимальноеЗдоровье);
КонецПроцедуры		// ИнициализироватьПротивника()

// Осуществляет инициализацию нового восхождения.
&НаСервере
Процедура ИнициализироватьРежимВосхождение()
	ЗагрузитьМодификаторыПоУмолчанию();
	// Инициализация игрока
	ИнициализироватьИгрока();
	// Инициализация противника
	ИнициализироватьПротивника();
	// Инициализация реквизитов этапов
	НомерЭтапа = 1;
	ВсегоЭтапов = 30;
	ВидЭтапа = Перечисления.ВидыЭтаповВосхождения.Противник;
КонецПроцедуры		// ИнициализироватьРежимВосхождение()

