Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Инициализация.
	КоличествоВерных = 0;	
	КоличествоЗаданных = 0;
	СерияПравильных = 0;
	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	// Считывание параметров.
	Если ЗначениеЗаполнено(Параметры.Сборник) Тогда
		Сборник = Параметры.Сборник;
	Иначе
		// Параметры не переданы. Не требуется обновлять сборник.
	КонецЕсли;
	ВыбранныеСборники = Параметры.ВыбранныеСборники;
	// Считвание констант.
	КоличествоЗаданийВРаунде = Константы.КоличествоЗаданийВРаунде.Получить();
	Если НЕ ЗначениеЗаполнено(КоличествоЗаданийВРаунде) Тогда
		КоличествоЗаданийВРаунде = 100;
	Иначе
		// Значение установлено.
	КонецЕсли;
	ВероятностьПовтораНеправильного = Константы.ВероятностьПовтораНеправильного.Получить();
	// Инициализация игры для режима "Восхождение"
	Если РежимВикторины = Перечисления.РежимыВикторины.Восхождение Тогда
		ИнициализироватьРежимВосхождение();
	Иначе
		// Для прочих вариантов не инициализируем.
	КонецЕсли;
	// Управление видимостью.
	УправлениеВидимостью();
КонецПроцедуры

