&НаКлиенте
Процедура ИскатьВИнтернете(Команда)
	ТекстВопроса = ПолучитьТекстВопроса(ВыбранноеЗадание);
	ТекстВопроса = СтрЗаменить(ТекстВопроса, """", "");		// Удалим кавычки.
	Если СокрЛП(ТекстВопроса) <> "" Тогда
		ТекстПоиска = "https://www.google.com/search?q=";
		ТекстПоиска = ТекстПоиска + Строка(ТекстВопроса);
		ЗапуститьПриложение(ТекстПоиска);
	Иначе
		Сообщить("Текст вопроса пустой");
	КонецЕсли;
КонецПроцедуры

