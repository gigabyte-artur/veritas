// Добавляет модификаторы по умолчанию в таблицу Модификаторы.
//
&НаСервере
Процедура ЗагрузитьМодификаторыПоУмолчанию()
	Модификаторы.Очистить();
	// Загрузим один положительный и один отрицательный модификатор.
	ПоложительныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Истина, Гсч);
	Если ЗначениеЗаполнено(ПоложительныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ПоложительныйМодификатор;
	Иначе
		// Положительный модификатор не найден.
	КонецЕсли;
	ОтрицательныйМодификатор = Справочники.Модификаторы.ВернутьМодификатор(Ложь, Гсч);
	Если ЗначениеЗаполнено(ОтрицательныйМодификатор) Тогда
		НоваяСтрока = Модификаторы.Добавить();
		НоваяСтрока.Модификатор = ОтрицательныйМодификатор;
	Иначе
		// Отрицательный модификатор не найден.
	КонецЕсли;
КонецПроцедуры		// ЗагрузитьМодификаторыПоУмолчанию()

