// Выполняет действие карты Единички.
// Последовательно выполняет действия:
// 1. Игрок излечивает 1 здоровья;
// 2. Игрок получает 1 щита;
// 3. Игрок наносит 1 урона противнику;
// 4. Игрок добирает 1 карту из таблицы СтопкаДобора в таблицу РукаИгрока.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Единички(КартаВход, ИдентифкаторКартыВход)
	// 1. Игрок излечивает 1 здоровья
	ВосстановитьЗдоровьеИгрока(1);
	// 2. Игрок получает 1 щита
	УвеличитьЩитИгрока(1);
	// 3. Игрок наносит 1 урона противнику
	НанестиУронПротивнику(1);
	// 4. Игрок добирает 1 карту из СтопкаДобора в РукаИгрока
	ДобратьКартуВРуку();
КонецПроцедуры		// ДействиеКарты_Единички()

// Выполняет действие карты Пасхалка.
// Случайно выбирает и выполняет одно из следующих действий:
// 1. Игрок излечивает 5 единиц здоровья;
// 2. Игрок получает 5 единиц щита;
// 3. Игрок наносит 8 урона противнику;
// 4. Игрок добирает 2 карты из таблицы СтопкаДобора в таблицу РукаИгрока.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Пасхалка(КартаВход, ИдентифкаторКартыВход)
	// Случайный выбор действия от 0 до 3
	НомерДействия = Гсч.СлучайноеЧисло(0, 3);
	
	Если НомерДействия = 0 Тогда
		// 1. Игрок излечивает 5 единиц здоровья
		ВосстановитьЗдоровьеИгрока(5);
	ИначеЕсли НомерДействия = 1 Тогда
		// 2. Игрок получает 5 единиц щита
		УвеличитьЩитИгрока(5);
	ИначеЕсли НомерДействия = 2 Тогда
		// 3. Игрок наносит 8 урона противнику
		НанестиУронПротивнику(8);
	Иначе
		// 4. Игрок добирает 2 карты из СтопкаДобора в РукаИгрока
		ДобратьВРукуКарты(2);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Пасхалка()

// Выполняет действие карты Рулетка.
// Случайный эффект:
// 1) Игрок получает +10 щита;
// 2) Игрок наносит 10 урона противнику;
// 3) Игрок берёт 3 карты из добора;
// 4) Игрок теряет 3 единицы здоровья.
//
// Параметры:
//	НайденнаяКарта - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентификаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаКлиенте
Процедура ДействиеКарты_Рулетка(НайденнаяКарта, ИдентификаторКартыВход)
	НомерДействия = ГсчКлиент.СлучайноеЧисло(0, 3);

	Если НомерДействия = 0 Тогда
		УвеличитьЩитИгрока(10);
	ИначеЕсли НомерДействия = 1 Тогда
		НанестиУронПротивнику(10);
	ИначеЕсли НомерДействия = 2 Тогда
		ДобратьВРукуКарты(3);
	Иначе
		НанестиУронИгроку(3);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Рулетка()

// Выполняет действие карты Поправка.
// Снимает с игрока 1 негативный эффект.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
//	ИдентифкаторКартыВход - Строка - Идентификатор карты, которую разыгрываем.
//
&НаСервере
Процедура ДействиеКарты_Поправка(КартаВход, ИдентифкаторКартыВход)
	// Получаем список отрицательных параметров из модуля менеджера перечисления ВидыПараметровИгроков
	ОтрицательныеПараметры = Перечисления.ВидыПараметровИгроков.ПолучитьОтрицательныеПараметры();
	// Формируем массив строк с отрицательными параметрами у игрока
	МассивОтрицательныхСтрок = Новый Массив;
	Для Каждого СтрокаПараметра Из ПараметрыИгрока Цикл
		Если ОтрицательныеПараметры.Найти(СтрокаПараметра.ВидПараметра) <> Неопределено Тогда
			МассивОтрицательныхСтрок.Добавить(СтрокаПараметра);
		КонецЕсли;
	КонецЦикла;
	// Удаляем 1 случайный отрицательный параметр (если есть)
	Если МассивОтрицательныхСтрок.Количество() > 0 Тогда
		Индекс = Гсч.СлучайноеЧисло(0, МассивОтрицательныхСтрок.Количество() - 1);
		СтрокаДляУдаления = МассивОтрицательныхСтрок[Индекс];
		УдалитьПараметрИгрока(СтрокаДляУдаления.ВидПараметра);
	КонецЕсли;
КонецПроцедуры		// ДействиеКарты_Поправка()

// Выполняет действие карты Взрыв.
// Наносит противнику 25 единиц урона.
//
// Параметры:
//	КартаВход - СправочникСсылка.Карты - Карта, которую разыгрываем.
