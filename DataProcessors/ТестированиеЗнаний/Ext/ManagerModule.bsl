
// Определяет, все ли элементы в массиве МассивОтветовВход уникальны.
Функция ОпределитьПовторяющиесяОтветы(МассивОтветовВход) Экспорт
	РезультатФункции = Истина;
	Свертка = ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивОтветовВход);
	РазмерностиСовпадают = (Свертка.Количество() = МассивОтветовВход.Количество());
	РезультатФункции = (НЕ РазмерностиСовпадают);
	Возврат РезультатФункции;
КонецФункции		// ОпределитьПовторяющиесяОтветы()

// Возвращает случайное задание, принадлежающее сборнику СборникВход.
Функция НайтиСлучайноеЗадание(СборникВход, Гсч) Экспорт
	РезультатФункции = Справочники.Задания.ПустаяСсылка();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Задания.Ссылка,
		|	Задания.Владелец
		|ИЗ
		|	Справочник.Задания КАК Задания
		|ГДЕ
		|	Задания.Владелец = &Владелец
		|	И НЕ Задания.ПометкаУдаления";
	Запрос.УстановитьПараметр("Владелец", СборникВход);
	РезультатЗапроса = Запрос.Выполнить();
	Выгрузка = РезультатЗапроса.Выгрузить();
	МассивЗаданий = Выгрузка.ВыгрузитьКолонку("Ссылка");
	КоличествоЗаданий = МассивЗаданий.Количество();
	Если КоличествоЗаданий > 0 Тогда
		ИндексЗадания = гсч.СлучайноеЧисло(0, КоличествоЗаданий - 1);
		РезультатФункции = МассивЗаданий[ИндексЗадания];
	Иначе
		ТекстСообщения = "Не найдено ни одного задания для сборника %Сборник%";
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Сборник%", Строка(СборникВход));
		Сообщить(ТекстСообщения);
		РезультатФункции = Справочники.Задания.ПустаяСсылка();
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции

// Возвращает случайный сборник из доступных.
Функция ПолучитьСлучайныйСборник(ВыбранныеСборникиВход, ГСЧ) Экспорт
	РезультатФункции = Справочники.Сборники.ПустаяСсылка();
	Запрос = Новый Запрос;
	Если ВыбранныеСборникиВход.Количество() > 0 Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Сборники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сборники КАК Сборники
		|ГДЕ
		|	НЕ Сборники.ПометкаУдаления
		|	И Сборники.Ссылка В(&Ссылка)";
		Запрос.УстановитьПараметр("Ссылка", ВыбранныеСборникиВход);
	Иначе
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Сборники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сборники КАК Сборники
		|ГДЕ
		|	НЕ Сборники.ПометкаУдаления";
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	Выгрузка = РезультатЗапроса.Выгрузить();
	МассивСборников = Выгрузка.ВыгрузитьКолонку("Ссылка");
	МассивСборников = ОбщегоНазначенияКлиентСервер.СмешатьМассив(МассивСборников, Гсч);
	Если МассивСборников.Количество() > 0 Тогда
		РезультатФункции = МассивСборников[0];
	Иначе
		РезультатФункции = Справочники.Сборники.ПустаяСсылка();
	КонецЕсли;
	Возврат РезультатФункции;
КонецФункции		// ПолучитьСлучайныйСборник()

// Добавляет в регистр РезультатыТестированияЗнаний запись об отвеченном задании
// в сборнике СборникВход по пользователю ПользовательВход. Когда ВерноВход
// Истина, будет записан результат верного ответа, иначе - неверного.
Процедура ЗаписатьОтветВРезультаты(СборникВход, ПользовательВход, ВерноВход) Экспорт
	МенеджерЗаписи = РегистрыСведений.РезультатыТестированияЗнаний.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период				 = ТекущаяДата();
	МенеджерЗаписи.Сборник				 = СборникВход;
	МенеджерЗаписи.Пользователь			 = ПользовательВход;
	МенеджерЗаписи.ЗаданоВопросов		 = 1;
	Если ВерноВход Тогда
		МенеджерЗаписи.ОтвеченоВерно	 = 1;
	Иначе
		МенеджерЗаписи.ОтвеченоВерно	 = 0;
	КонецЕсли;
	МенеджерЗаписи.Записать();
КонецПроцедуры

// Возвращает массив номеров неправильных ответов для количества 
// ответов КоличествоОтветовВход, игнорируя правильный ответ
// НомерПравильногоОтветаВход.
Функция ПолучитьМассивОтветовКУдалениюПоКоличеству(НомерПравильногоОтветаВход, ГСЧ, КоличествоОтветовВход) Экспорт
	РезультатФункции = Новый Массив;
	Счетчик = 1;
	НоваяГраница = Цел(КоличествоОтветовВход / 2) + 1;
	Пока Счетчик < НоваяГраница Цикл
		Найдено = Ложь;
		Пока НЕ Найдено Цикл
			НомерНеправильногоОтвета = ГСЧ.СлучайноеЧисло(1, КоличествоОтветовВход);
			Добавлен = (РезультатФункции.Найти(НомерНеправильногоОтвета) <> Неопределено);
			СовпадаетСПравильным = (НомерНеправильногоОтвета = НомерПравильногоОтветаВход);
			Если (НЕ Добавлен) И (НЕ СовпадаетСПравильным) Тогда
				Найдено = Истина;
				РезультатФункции.Добавить(НомерНеправильногоОтвета);
			Иначе
				Найдено = Ложь;
			КонецЕсли;
		КонецЦикла;	
		Счетчик = Счетчик + 1;
	КонецЦикла;	
	Возврат РезультатФункции;
КонецФункции		// ПолучитьМассивОтветовКУдалениюПоКоличеству()	

// Возвращает номера этапов для элитной сложности.
//
// Возвращаемое значение:
//	Массив - Массив номеров этапов эличной сложности.
//
Функция МассивЭтаповЭлитныхПротивников() Экспорт
	РезультатФункции = Новый Массив;
	РезультатФункции.Добавить(10);
	РезультатФункции.Добавить(20);
	РезультатФункции.Добавить(30);
	Возврат РезультатФункции;
КонецФункции		 // МассивЭтаповЭлитныхПротивников()

// Определяет, является ли этап этапом элитной сложности.
//
// Параметры:
//	НомерЭтапаВход - Число - номер этапа, который нужно проверить.
//
// Возвращаемое значение:
//	Булево - Истина, если этап является этапом элитной сложности.
//
Функция ЭтоЭтапЭлитнойСложности(НомерЭтапаВход) Экспорт
	РезультатФункции = Ложь;
	ЭтапыЭличнойСложности = Обработки.ТестированиеЗнаний.МассивЭтаповЭлитныхПротивников();
	РезультатФункции = (ЭтапыЭличнойСложности.Найти(НомерЭтапаВход) <> Неопределено);
	Возврат РезультатФункции;	
КонецФункции		 // ЭтоЭтапЭлитнойСложности()

#Область КолесоСудьбы

// Возвращает структуру весов символов для колеса судьбы (сумма 100).
Функция ВернутьВесаКолесаСудьбы() Экспорт
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("Здоровье", 24);
	РезультатФункции.Вставить("Щит",      20);
	РезультатФункции.Вставить("Энергия",  19);
	РезультатФункции.Вставить("Золото",   18);
	РезультатФункции.Вставить("Карта",    12);
	РезультатФункции.Вставить("Вишенка",   4);
	РезультатФункции.Вставить("Реликвия",  2);
	РезультатФункции.Вставить("Риск",      1);
	Возврат РезультатФункции;
КонецФункции

// Генерирует поле 3x5 символов с учётом весов.
// Возвращает Массив из 3-х Массивов по 5 строк-имён символов.
Функция СгенерироватьПолеКолесаСудьбы(ГСЧ) Экспорт
	Веса = ВернутьВесаКолесаСудьбы();
	МассивСимволов = Новый Массив;
	Для Каждого Эл Из Веса Цикл
		Для Сч = 1 По Эл.Значение Цикл
			МассивСимволов.Добавить(Эл.Ключ);
		КонецЦикла;
	КонецЦикла;
	Всего = МассивСимволов.Количество();
	РезультатФункции = Новый Массив;
	Для Стр = 1 По 3 Цикл
		Строка = Новый Массив;
		Для Кол = 1 По 5 Цикл
			Строка.Добавить(МассивСимволов[ГСЧ.СлучайноеЧисло(0, Всего - 1)]);
		КонецЦикла;
		РезультатФункции.Добавить(Строка);
	КонецЦикла;
	Возврат РезультатФункции;
КонецФункции

// Заполняет структуру результата базовыми наградами по имени символа.
Процедура ЗаполнитьНаградыПоСимволу(Результат, ИмяСимвола) Экспорт
	Если ИмяСимвола = "Здоровье" Тогда
		Результат.НаградаЗдоровье = 8;
	ИначеЕсли ИмяСимвола = "Щит" Тогда
		Результат.НаградаЩит = 6;
	ИначеЕсли ИмяСимвола = "Энергия" Тогда
		Результат.НаградаЭнергия = 2;
	ИначеЕсли ИмяСимвола = "Золото" Тогда
		Результат.НаградаЗолото = 10;
	ИначеЕсли ИмяСимвола = "Карта" Тогда
		Результат.НаградаКарта = 1;
	ИначеЕсли ИмяСимвола = "Вишенка" Тогда
		Результат.НаградаЗдоровье = 4;
		Результат.НаградаЗолото = 3;
	ИначеЕсли ИмяСимвола = "Реликвия" Тогда
		Результат.НаградаЗдоровье = 12;
		Результат.НаградаЩит = 10;
		Результат.НаградаЭнергия = 2;
		Результат.НаградаЗолото = 10;
	КонецЕсли;
КонецПроцедуры

// Проверяет сгенерированное поле 3x5 на комбинации.
// Возвращает Структура с полным разбором результата.
Функция ПроверитьПолеКолесаСудьбы(Поле) Экспорт
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("ТипРезультата",       "Проигрыш");
	РезультатФункции.Вставить("Символ",              "");
	РезультатФункции.Вставить("Множитель",           1.0);
	РезультатФункции.Вставить("НаградаЗдоровье",     0);
	РезультатФункции.Вставить("НаградаЩит",          0);
	РезультатФункции.Вставить("НаградаЭнергия",      0);
	РезультатФункции.Вставить("НаградаЗолото",       0);
	РезультатФункции.Вставить("НаградаКарта",        0);
	РезультатФункции.Вставить("Выигрыш",             Ложь);
	РезультатФункции.Вставить("КоличествоРиска",     0);
	РезультатФункции.Вставить("ЭффектРиска",         "");
	РезультатФункции.Вставить("РядыСовпадений",      Новый Массив);

	// Подсчёт Риска по всему полю 3x5.
	КоличествоРиска = 0;
	Для Каждого Строка Из Поле Цикл
		Для Каждого Символ Из Строка Цикл
			Если Символ = "Риск" Тогда
				КоличествоРиска = КоличествоРиска + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	РезультатФункции.КоличествоРиска = КоличествоРиска;

	// --- Джекпот: 5 подряд по горизонтали ---
	СимволДжекпота = "";
	Для Каждого Строка Из Поле Цикл
		Если Строка[0] = Строка[1] И Строка[1] = Строка[2] И Строка[2] = Строка[3] И Строка[3] = Строка[4] Тогда
			СимволДжекпота = Строка[0];
			Прервать;
		КонецЕсли;
	КонецЦикла;
	// Уголок: левый-верх, правый-верх, центр, левый-низ, правый-низ.
	Если СимволДжекпота = "" Тогда
		ЛВ = Поле[0][0]; ПВ = Поле[0][4]; Ц = Поле[1][2]; ЛН = Поле[2][0]; ПН = Поле[2][4];
		Если ЛВ = ПВ И ПВ = Ц И Ц = ЛН И ЛН = ПН Тогда
			СимволДжекпота = ЛВ;
		КонецЕсли;
	КонецЕсли;
	Если СимволДжекпота <> "" Тогда
		РезультатФункции.ТипРезультата = "Джекпот";
		РезультатФункции.Символ = СимволДжекпота;
		РезультатФункции.Множитель = 2.0;
		РезультатФункции.Выигрыш = Истина;
		ЗаполнитьНаградыПоСимволу(РезультатФункции, СимволДжекпота);
		Возврат РезультатФункции;
	КонецЕсли;

	// --- Бонус: 4 подряд по горизонтали ---
	СимволБонуса = "";
	Для Каждого Строка Из Поле Цикл
		Для Поз = 0 По 1 Цикл
			Если Строка[Поз] = Строка[Поз + 1] И Строка[Поз + 1] = Строка[Поз + 2] И Строка[Поз + 2] = Строка[Поз + 3] Тогда
				СимволБонуса = Строка[Поз];
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если СимволБонуса <> "" Тогда Прервать; КонецЕсли;
	КонецЦикла;
	Если СимволБонуса <> "" Тогда
		РезультатФункции.ТипРезультата = "Бонус";
		РезультатФункции.Символ = СимволБонуса;
		РезультатФункции.Множитель = 1.5;
		РезультатФункции.Выигрыш = Истина;
		ЗаполнитьНаградыПоСимволу(РезультатФункции, СимволБонуса);
		Возврат РезультатФункции;
	КонецЕсли;

	// --- База: 3 подряд по горизонтали ИЛИ 3 по вертикали ---
	СимволБазы = "";
	Для Каждого Строка Из Поле Цикл
		Для Поз = 0 По 2 Цикл
			Если Строка[Поз] = Строка[Поз + 1] И Строка[Поз + 1] = Строка[Поз + 2] Тогда
				СимволБазы = Строка[Поз];
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если СимволБазы <> "" Тогда Прервать; КонецЕсли;
	КонецЦикла;
	Если СимволБазы = "" Тогда
		Для Кол = 0 По 4 Цикл
			Если Поле[0][Кол] = Поле[1][Кол] И Поле[1][Кол] = Поле[2][Кол] Тогда
				СимволБазы = Поле[0][Кол];
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если СимволБазы <> "" Тогда
		РезультатФункции.ТипРезультата = "База";
		РезультатФункции.Символ = СимволБазы;
		РезультатФункции.Множитель = 1.0;
		РезультатФункции.Выигрыш = Истина;
		ЗаполнитьНаградыПоСимволу(РезультатФункции, СимволБазы);
		Возврат РезультатФункции;
	КонецЕсли;

	// --- Near-Miss: первые 2 на любой строке совпадают, 3-й — Вишенка ---
	СимволNM = "";
	Для Каждого Строка Из Поле Цикл
		Если Строка[0] = Строка[1] И Строка[2] = "Вишенка" Тогда
			СимволNM = Строка[0];
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если СимволNM <> "" Тогда
		РезультатФункции.ТипРезультата = "NearMiss";
		РезультатФункции.Символ = "Вишенка";
		РезультатФункции.НаградаЗолото = 5;
		РезультатФункции.Выигрыш = Истина;
		Возврат РезультатФункции;
	КонецЕсли;

	Возврат РезультатФункции;
КонецФункции

// Главный серверный метод одного спина.
// Принимает ГСЧ и счётчик жалости. Возвращает Структура с полем, результатом проверки,
// применёнными рисками и итоговыми наградами.
Функция ВыполнитьСпинКолесаСудьбы(ГСЧ, СчетчикЖалости) Экспорт
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("Поле",             Новый Массив);
	РезультатФункции.Вставить("ТипРезультата",    "Проигрыш");
	РезультатФункции.Вставить("Символ",           "");
	РезультатФункции.Вставить("Множитель",        1.0);
	РезультатФункции.Вставить("НаградаЗдоровье",  0);
	РезультатФункции.Вставить("НаградаЩит",       0);
	РезультатФункции.Вставить("НаградаЭнергия",   0);
	РезультатФункции.Вставить("НаградаЗолото",    0);
	РезультатФункции.Вставить("НаградаКарта",     0);
	РезультатФункции.Вставить("Выигрыш",          Ложь);
	РезультатФункции.Вставить("КоличествоРиска",  0);
	РезультатФункции.Вставить("ЭффектРиска",      "");
	РезультатФункции.Вставить("СброситьЖалость",  Ложь);

	МаксПопыток = Мин(СчетчикЖалости, 2);
	ЛучшийРезультат = Неопределено;
	ЛучшееПоле = Неопределено;

	Для НомерПопытки = 0 По МаксПопыток Цикл
		Поле = СгенерироватьПолеКолесаСудьбы(ГСЧ);
		Проверка = ПроверитьПолеКолесаСудьбы(Поле);
		Если Проверка.Выигрыш Тогда
			ЛучшийРезультат = Проверка;
			ЛучшееПоле = Поле;
			Прервать;
		ИначеЕсли ЛучшийРезультат = Неопределено Тогда
			ЛучшийРезультат = Проверка;
			ЛучшееПоле = Поле;
		КонецЕсли;
	КонецЦикла;

	Если ЛучшийРезультат = Неопределено Тогда
		ЛучшееПоле = СгенерироватьПолеКолесаСудьбы(ГСЧ);
		ЛучшийРезультат = ПроверитьПолеКолесаСудьбы(ЛучшееПоле);
	КонецЕсли;

	РезультатФункции.Поле = ЛучшееПоле;
	РезультатФункции.ТипРезультата   = ЛучшийРезультат.ТипРезультата;
	РезультатФункции.Символ          = ЛучшийРезультат.Символ;
	РезультатФункции.Множитель       = ЛучшийРезультат.Множитель;
	РезультатФункции.Выигрыш         = ЛучшийРезультат.Выигрыш;
	РезультатФункции.КоличествоРиска = ЛучшийРезультат.КоличествоРиска;

	// Применить множитель к базовым наградам.
	РезультатФункции.НаградаЗдоровье = Цел(ЛучшийРезультат.НаградаЗдоровье * ЛучшийРезультат.Множитель);
	РезультатФункции.НаградаЩит      = Цел(ЛучшийРезультат.НаградаЩит      * ЛучшийРезультат.Множитель);
	РезультатФункции.НаградаЭнергия  = Цел(ЛучшийРезультат.НаградаЭнергия  * ЛучшийРезультат.Множитель);
	РезультатФункции.НаградаЗолото   = Цел(ЛучшийРезультат.НаградаЗолото   * ЛучшийРезультат.Множитель);
	РезультатФункции.НаградаКарта    = Цел(ЛучшийРезультат.НаградаКарта    * ЛучшийРезультат.Множитель);

	// Обработка глобального Риска.
	Если ЛучшийРезультат.КоличествоРиска = 3 Тогда
		РезультатФункции.ЭффектРиска = "Обнуление";
		РезультатФункции.НаградаЗдоровье = 0;
		РезультатФункции.НаградаЩит = 0;
		РезультатФункции.НаградаЭнергия = 0;
		РезультатФункции.НаградаЗолото = 0;
		РезультатФункции.НаградаКарта = 0;
		РезультатФункции.СброситьЖалость = Ложь;
	ИначеЕсли ЛучшийРезультат.КоличествоРиска = 4 Тогда
		РезультатФункции.ЭффектРиска = "Выбор";
		РезультатФункции.СброситьЖалость = ЛучшийРезультат.Выигрыш;
	ИначеЕсли ЛучшийРезультат.КоличествоРиска >= 5 Тогда
		РезультатФункции.ЭффектРиска = "УронИИскажение";
		РезультатФункции.СброситьЖалость = Ложь;
		РезультатФункции.НаградаЗдоровье = -2;
		РезультатФункции.НаградаЩит = 0;
		РезультатФункции.НаградаЭнергия = -1;
		РезультатФункции.НаградаЗолото = 0;
		РезультатФункции.НаградаКарта = 0;
	Иначе
		РезультатФункции.СброситьЖалость = ЛучшийРезультат.Выигрыш;
	КонецЕсли;

	Возврат РезультатФункции;
КонецФункции

#КонецОбласти
