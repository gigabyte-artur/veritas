// Сохраняет данные восхождения пользователя.
//
// Параметры:
//  ДанныеВосхождения - Структура - данные для сохранения:
//   - Пользователь - СправочникСсылка.Пользователи - пользователь
//   - ПараметрыИгрока - Таблица - параметры игрока
//   - КолодаИгрока - Таблица - колода игрока
//   - Модификаторы - Таблица - модификаторы
//   - НомерЭтапа - Число - номер этапа
//  ПользовательВход - СправочникСсылка.Пользователи - (необязательно) пользователь для сохранения
Процедура СохранитьВосхождениеПользователя(ДанныеВосхождения, ПользовательВход = Неопределено) Экспорт
	Попытка
		ТекПользователь = ОбщегоНазначенияВызовСервера.ТекущийПользователь();
		ПользовательРабочий = ТекПользователь;
		Если ЗначениеЗаполнено(ПользовательВход) Тогда
			ПользовательРабочий = ПользовательВход;
		Иначе
			ПользовательРабочий = ТекПользователь;
		КонецЕсли;
		Запись = РегистрыСведений.СохраненияВосхождения.СоздатьМенеджерЗаписи();
		Запись.Пользователь = ПользовательРабочий;
		Запись.ХранилищеСохранения = Новый ХранилищеЗначения(ДанныеВосхождения);
		Запись.Записать();
	Исключение
		Сообщить("Не удалось сохранить восхождение пользователя " + Строка(ПользовательРабочий));
	КонецПопытки;
КонецПроцедуры
	
	// Получает сохранение восхождения пользователя.
	//
	// Параметры:
	//  ПользовательВход - СправочникСсылка.Пользователи - пользователь для поиска сохранения
	//
	// Возвращаемое значение:
	//  Структура - результат поиска:
	//   - СохранениеНайдено - Булево - флаг найденного сохранения
	//   - ХранилищеСохранения - ХранилищеЗначения - хранилище с данными сохранения (если найдено)
	Функция ПолучитьСохранениеВосхождения(ПользовательВход) Экспорт
		Результат = Новый Структура();
		Результат.Вставить("СохранениеНайдено", Ложь);
		Результат.Вставить("ХранилищеСохранения", Неопределено);
		
		Попытка
			ТекПользователь = ОбщегоНазначенияВызовСервера.ТекущийПользователь();
			ПользовательРабочий = ТекПользователь;
			Если ЗначениеЗаполнено(ПользовательВход) Тогда
				ПользовательРабочий = ПользовательВход;
			КонецЕсли;
			
			Запись = РегистрыСведений.СохраненияВосхождения.СоздатьМенеджерЗаписи();
			Запись.Пользователь = ПользовательРабочий;
			
			Если Запись.Прочитать() Тогда
				Результат.СохранениеНайдено = Истина;
				Результат.ХранилищеСохранения = Запись.ХранилищеСохранения;
			КонецЕсли;
		Исключение
			Сообщить("Не удалось получить сохранение восхождения пользователя " + Строка(ПользовательРабочий));
		КонецПопытки;
		
		Возврат Результат;
	КонецФункции

